# odoo-semantic-webui.service — systemd unit cho FastAPI Web UI admin
# Đặt tại: /etc/systemd/system/odoo-semantic-webui.service
# Sau khi copy:
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now odoo-semantic-webui
#
# FastAPI bind 127.0.0.1:8003 — KHÔNG expose ra Internet (không có auth riêng
# layer trước Astro). Truy cập từ xa qua SSH tunnel hoặc nginx proxy + IP allowlist.
#
# Canonical layout = ADR-0027. Operators on non-canonical layouts use drop-in
# overrides — see docs/deploy/install-runbook.md.

[Unit]
Description=Odoo Semantic MCP — FastAPI Web UI admin (LAN-only :8003)
Documentation=https://github.com/Viindoo/odoo-semantic-server
After=network-online.target docker.service odoo-semantic-mcp.service
Wants=network-online.target
# DB tier lives in docker containers; hard dep matches mcp.service.
Requires=docker.service
# Stop runaway crash-loop after 5 failures in 60s window.
StartLimitBurst=5
StartLimitIntervalSec=60
OnFailure=osm-alert@%n

[Service]
Type=simple
User=odoo-semantic
Group=odoo-semantic
WorkingDirectory=/home/odoo-semantic/odoo-semantic-mcp
Environment="ODOO_SEMANTIC_CONF=/home/odoo-semantic/etc/odoo-semantic.conf"
# Main .env first (PG_DSN, NEO4J_PASSWORD), then webui.env (FERNET_KEY,
# WEBUI_SESSION_SECRET, MFA encryption key). Both optional via `-` prefix.
# Without these the Web UI falls back to dev-only defaults (logged WARN).
# Order matters: webui.env wins on conflict, since it loads last.
EnvironmentFile=-/home/odoo-semantic/odoo-semantic-mcp/.env
EnvironmentFile=-/home/odoo-semantic/etc/webui.env
# Option B preferred: inject FERNET_KEY bằng systemd credential store (xem deploy.md §12).
# Fallback: EnvironmentFile= ở trên vẫn hoạt động nếu LoadCredential chưa cấu hình.
LoadCredential=FERNET_KEY:/etc/credstore/FERNET_KEY
ExecStart=/home/odoo-semantic/.venv/odoo-semantic-mcp/bin/python -m src.web_ui
Restart=on-failure
RestartSec=5
# Web UI starts quickly. 60s is generous.
TimeoutStartSec=60
# Allow in-flight API requests (including long indexer-spawn calls) to complete.
TimeoutStopSec=30
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
# Writable XDG data dir holds indexer clones + known_hosts; moved from
# /home/odoo-semantic/repos per ADR-0027 operational path-migration (2026-05-25).
# App dir carve-out covers audit log writes; indexer subprocess spawned from
# Web UI inherits this unit's cgroup + sandbox restrictions.
ReadWritePaths=/home/odoo-semantic/odoo-semantic-mcp
ReadWritePaths=/home/odoo-semantic/.local/share/odoo-semantic-mcp
PrivateTmp=true

[Install]
WantedBy=multi-user.target

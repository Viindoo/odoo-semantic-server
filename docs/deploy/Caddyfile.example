# Caddyfile.example — Caddy reverse proxy (auto-TLS)
# Caddy tự lấy cert Let's Encrypt — không cần certbot.
# Thay semantic.example.com bằng domain thật.
# Docs: https://caddyserver.com/docs/caddyfile/directives/reverse_proxy

semantic.example.com {
    # Security headers.
    # CSP composition: the application middleware (Astro `site/src/middleware.ts`
    # + FastAPI `_SecurityHeadersMiddleware`) emits a tighter, per-path CSP on
    # SSR responses. Per W3C CSP3 §4.1 multiple CSP headers are intersected per
    # directive (most restrictive wins), so the edge CSP below is intentionally
    # a PERMISSIVE SUPERSET of every grant the middleware ever makes —
    # otherwise the edge would silently strip middleware-granted permissions
    # (e.g. hCaptcha origins on /signup, 'unsafe-inline' inline modules on
    # admin pages). Prerendered routes (/, /pricing, /bootstrap, /benchmarks)
    # do not run through middleware, so this edge CSP is their only CSP.
    # See `docs/deploy/nginx-m8.conf` for the full rationale.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://js.hcaptcha.com https://newassets.hcaptcha.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.hcaptcha.com https://newassets.hcaptcha.com; frame-src 'self' https://newassets.hcaptcha.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
        Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
        # Remove server identification header
        -Server
    }

    # MCP protocol (SSE streaming — disable buffering)
    reverse_proxy /mcp* 127.0.0.1:8002 {
        flush_interval -1   # -1 = disable buffering, bắt buộc cho SSE streaming
    }

    # FastAPI JSON API
    reverse_proxy /api/* 127.0.0.1:8003

    # Client setup + health check endpoints
    reverse_proxy /install/* 127.0.0.1:8002
    reverse_proxy /health 127.0.0.1:8002

    # Astro SSR (landing + admin pages)
    reverse_proxy /* 127.0.0.1:4321
}

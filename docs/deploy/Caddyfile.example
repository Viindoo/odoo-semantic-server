# Caddyfile.example — Caddy reverse proxy (auto-TLS)
# Caddy tự lấy cert Let's Encrypt — không cần certbot.
# Thay semantic.example.com bằng domain thật.
# Docs: https://caddyserver.com/docs/caddyfile/directives/reverse_proxy

semantic.example.com {
    # Security headers — transport / framing / sniffing / referrer only.
    # Content-Security-Policy + Permissions-Policy are OWNED BY THE APPLICATION
    # MIDDLEWARE (Astro `site/src/middleware.ts` + FastAPI
    # `src/web_ui/app.py::_SecurityHeadersMiddleware`). DO NOT add CSP or
    # Permissions-Policy here — per W3C CSP3 §4.1 multiple CSP headers are
    # intersected (most restrictive wins per directive), so an edge CSP would
    # silently strip the hCaptcha origins / `unsafe-inline` that the
    # middleware grants on a per-path basis. See nginx-m8.conf for the full
    # rationale.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        # Remove server identification header
        -Server
    }

    # MCP protocol (SSE streaming — disable buffering)
    reverse_proxy /mcp* 127.0.0.1:8002 {
        flush_interval -1   # -1 = disable buffering, bắt buộc cho SSE streaming
    }

    # FastAPI JSON API
    reverse_proxy /api/* 127.0.0.1:8003

    # Client setup + health check endpoints
    reverse_proxy /install/* 127.0.0.1:8002
    reverse_proxy /health 127.0.0.1:8002

    # Astro SSR (landing + admin pages)
    reverse_proxy /* 127.0.0.1:4321
}

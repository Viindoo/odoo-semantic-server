# odoo-semantic-mcp.service — systemd unit cho MCP server
# Đặt tại: /etc/systemd/system/odoo-semantic-mcp.service
# Sau khi copy:
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now odoo-semantic-mcp

[Unit]
Description=Odoo Semantic MCP Server
After=network.target docker.service
# Hard dependency on docker — if docker is not up, this service must not
# attempt to start (DB tier lives in compose containers). Without this,
# After= only orders boot but does not block on docker availability.
Requires=docker.service
# Rate-limit the restart loop: at most 5 failures within a 60s window,
# then systemd parks the unit in `failed` state instead of `activating
# (auto-restart)` for hours. OnFailure= below fires when this limit is hit.
StartLimitBurst=5
StartLimitIntervalSec=60
# Fire alert unit when the service enters `failed` (after StartLimit* trips
# or any hard exit not auto-retried). `%n` resolves to this unit's full name
# including the `.service` suffix, so do not append another one here.
OnFailure=osm-alert@%n

[Service]
Type=simple
User=odoo-semantic
WorkingDirectory=/opt/odoo-semantic-mcp
# Config file nằm ngoài repo — không commit vào git
Environment="ODOO_SEMANTIC_CONF=/etc/odoo-semantic/odoo-semantic.conf"
ExecStart=/home/odoo-semantic/.venv/odoo-semantic-mcp/bin/python -m src.mcp.server
Restart=on-failure
RestartSec=5
# MCP server starts quickly (no indexing at startup). 60s is generous.
TimeoutStartSec=60
# Allow in-flight MCP requests to drain before force-kill.
TimeoutStopSec=30
StandardOutput=journal
StandardError=journal
# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only

[Install]
WantedBy=multi-user.target

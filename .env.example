# .env.example
# Env vars dùng bởi:
#   • docker-compose.yml (start Neo4j + PostgreSQL containers)
#   • Python app runtime — env var override INI ở odoo-semantic.conf
#     (precedence: env var → INI file → fallback)

# Thay [db-server] bằng IP/hostname của DB server khi tách tier.
# Khi chạy all-in-one, giữ nguyên localhost.

# ── DB TIER — Neo4j ──────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
# Tách DB tier:  NEO4J_URI=bolt://192.168.1.10:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=""                        # bắt buộc điền (xem note `""` ở §PostgreSQL bên dưới)

# Chỉ cần set khi Neo4j chạy trên server riêng (xem docker-compose.yml):
# NEO4J_ADVERTISED_HOST=192.168.1.10

# ── DB TIER — PostgreSQL ─────────────────────────────────────────────
# Format:        postgresql://odoo_semantic:<password>@localhost:5432/odoo_semantic
# Tách DB tier:  postgresql://odoo_semantic:<password>@192.168.1.10:5432/odoo_semantic
# Để trống PG_DSN khi muốn các Python tool đọc từ odoo-semantic.conf —
# giá trị từ systemd EnvironmentFile= hoặc shell export sẽ luôn thắng.
#
# `PG_DSN=""` (quoted-empty) thay vì bare `PG_DSN=` là CỐ Ý: python-dotenv
# parse `KEY=  # comment` (value rỗng + inline comment) thành value `'# comment'`
# vì coi `#` là phần của value khi không có ký tự trước nó. `""` đảm bảo
# value thực sự rỗng. Áp dụng cùng pattern cho NEO4J_PASSWORD/PG_PASSWORD
# bên dưới + trên (defense-in-depth, tránh tái lập bug khi init_dotenv()
# fire trong subprocess CLI).
PG_DSN=""                                # bắt buộc điền
PG_PASSWORD=""                           # bắt buộc điền


# ── DOCKER IMAGE VERSIONS (nguồn sự thật duy nhất) ──────────────────
# Khi bump version: sửa ở đây VÀ cập nhật .github/workflows/nightly-smoke.yml
# (CI service containers không đọc được .env.example lúc parse — phải hardcode).
# docker-compose.yml đọc hai biến này qua ${NEO4J_IMAGE:-...} và ${PG_IMAGE:-...}.
NEO4J_IMAGE=neo4j:5.26.25
PG_IMAGE=pgvector/pgvector:0.8.2-pg16

# ── TEST (pytest integration tests) ──────────────────────────────────
NEO4J_TEST_URI=bolt://localhost:7687
NEO4J_TEST_USER=neo4j
NEO4J_TEST_PASSWORD=password

# ── EMBEDDER (optional) ──────────────────────────────────────────────
# EMBEDDER_AUTH_TOKEN=
# Optional Bearer token sent as `Authorization: Bearer <token>` to Ollama.
# Only needed when Ollama sits behind an authenticated reverse proxy.

# EMBEDDER_BACKEND: embedding provider. Default "ollama".
# Values: ollama|qwen|qwen3 (Ollama /api/embed), openai|tei|voyage|vllm|litellm (/v1/embeddings), fake|test (tests).
# See docs/adr/0045-embedding-provider-abstraction.md.
# EMBEDDER_BACKEND=ollama

# EMBEDDER_NUM_CTX: embedder model context window in tokens. Default 4096.
# Raise only if your model supports a larger window (e.g. text-embedding-3-large = 8192).
# EMBEDDER_NUM_CTX=4096

# EMBEDDER_TOKEN_BUDGET: target per-chunk token budget (below num_ctx for safety margin). Default 3500.
# EMBEDDER_TOKEN_BUDGET=3500

# EMBEDDER_CHARS_PER_TOKEN: chars/token ratio for cheap pre-split estimate (over-estimate → safe over-split). Default 3.0.
# EMBEDDER_CHARS_PER_TOKEN=3.0

# EMBEDDER_TRUNCATE_CHARS_PER_TOKEN: worst-case chars/token for last-resort truncation choke-point. Default 2.0.
# EMBEDDER_TRUNCATE_CHARS_PER_TOKEN=2.0

# EMBEDDER_TIMEOUT_READ_QUERY: read timeout (seconds) for a single query embed (MCP real-time path). Default 30.
# Separate from EMBEDDER_TIMEOUT (1200s batch). Keeps MCP responsive during an embed overload.
# EMBEDDER_TIMEOUT_READ_QUERY=30

# EMBEDDER_MAX_CONCURRENCY: max concurrent in-flight embed requests (indexer + MCP). Default 4.
# asyncio.Semaphore ceiling; also drives uvicorn limit_concurrency (×16 by default).
# EMBEDDER_MAX_CONCURRENCY=4

# MCP_LIMIT_CONCURRENCY: uvicorn limit_concurrency override. Default = EMBEDDER_MAX_CONCURRENCY * 16 = 64.
# Increase only if serving many parallel MCP clients; decrease if server is RAM-constrained.
# MCP_LIMIT_CONCURRENCY=64

# ── TIMEOUT / PERFORMANCE TUNING ─────────────────────────────────────
# All values in seconds. Defaults are safe for v17+ heavy reindex.
# See docs/operations/timeouts.md for full knob list + rationale.

# EMBEDDER_TIMEOUT: per-batch HTTP timeout for Ollama /api/embed (indexer path).
# Default 1200s (20 min). Increase on very slow CPU-only servers.
# For real-time MCP query embed use EMBEDDER_TIMEOUT_READ_QUERY (default 30s).
# EMBEDDER_TIMEOUT=1200

# TIMEOUT_GIT_CLONE: subprocess timeout for full git clone.
# v17+ odoo/odoo has 1M+ commits; clone on slow link can take 30+ min.
# Default 3600s (1h). Increase for very large repos or slow network.
# TIMEOUT_GIT_CLONE=3600

# TIMEOUT_GIT_DIFF: timeout for git diff/rev-parse (incremental indexer).
# Default 30s. Rarely needs tuning.
# TIMEOUT_GIT_DIFF=30

# TIMEOUT_GIT_SCAN: timeout for git rev-parse HEAD during scan.
# Default 30s. Rarely needs tuning.
# TIMEOUT_GIT_SCAN=30

# EMBEDDER_MAX_BATCH: texts per Ollama /api/embed call.
# Default 50. Increase only if Ollama is local + has plenty of RAM/VRAM.
# EMBEDDER_MAX_BATCH=50

# NEO4J_WRITE_BATCH_SIZE: rows per Neo4j write transaction.
# Default 500. Decrease if Neo4j GC pauses cause tx timeouts.
# NEO4J_WRITE_BATCH_SIZE=500

# APPLY_PRESET_TIMEOUT: subprocess timeout for apply-preset route.
# Default 120s. Increase for very large profiles.
# APPLY_PRESET_TIMEOUT=120

# ── SECURITY ─────────────────────────────────────────────────────────
# FERNET_KEY: required for SSH private key encryption.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Back up separately from DB backups. If lost, SSH keys are unrecoverable.
FERNET_KEY=

# WEBUI_SESSION_SECRET: required for Web UI session cookie signing (M7 W16).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# If unset, web_ui falls back to a per-process random secret — sessions are
# invalidated on every restart and users get logged out repeatedly.
WEBUI_SESSION_SECRET=

# WEBUI_SECURE_COOKIE: session cookie Secure flag.
# Default ON (cookie is Secure). Set to 0 only for local HTTP dev.
# WARNING: WEBUI_SECURE_COOKIE=0 in production allows session hijacking.
# WEBUI_SECURE_COOKIE=0

# BCRYPT_ROUNDS: bcrypt password-hashing cost factor. Default 12 (ADR-0011).
# Leave UNSET in production (default 12 applies). Test/CI may lower to 4 for
# speed (conftest does this automatically). In production, any value < 12
# with ENVIRONMENT=production aborts startup to prevent silent security downgrade.
# BCRYPT_ROUNDS=12

# ENVIRONMENT: set to "production" on all production hosts. Enables fail-fast
# guards: WEBUI_SESSION_SECRET required, FERNET_KEY required,
# BCRYPT_ROUNDS >= 12 required. Never set to "production" in test/CI.
# ENVIRONMENT=production

# SIGNUP_ENABLED: allow public self-registration (POST /api/auth/register) and
# OAuth new-user auto-provisioning. Default OFF (invite-only model, ADR-0034 /
# Wave 0 hardening) — existing linked accounts always log in regardless.
# Set to 1 only to open public signup (e.g. a limited beta). Read once at
# startup — changing it requires a service restart.
# SIGNUP_ENABLED=0

# TRUSTED_PROXY_CIDRS: comma-separated CIDR list of trusted reverse proxies.
# Leave empty (default) to never trust X-Forwarded-For headers.
# Example (nginx on same host + office LAN):
# TRUSTED_PROXY_CIDRS=127.0.0.0/8,10.0.0.0/8
TRUSTED_PROXY_CIDRS=

# ── OAUTH (M9 W-OA) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
PUBLIC_BASE_URL=http://localhost:4321
API_BASE_URL=http://localhost:8003

# ── SMTP — email verification + password reset (M9 W-SG/W-UM) ────────
# Leave SMTP_HOST blank in local dev — emails are logged to stdout instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@odoo-semantic.viindoo.com

# Admin email recipient for /api/waitlist submissions (default: admin@viindoo.com).
# Set to your internal inbox so you are notified when someone joins the waitlist.
# Leave unset in local dev — admin notify is logged to stdout instead (no SMTP needed).
# WAITLIST_NOTIFY_EMAIL=admin@yourdomain.com

# ── hCaptcha — signup spam protection (M9 W-SG) ──────────────────────
# Leave blank in local dev — captcha verification is skipped (logged warning).
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=

# ── BILLING / POLAR.SH (M10B P1) ─────────────────────────────────────
# POLAR_WEBHOOK_SECRET: Standard-Webhooks HMAC signing secret from Polar.sh.
# Obtain from Polar Dashboard → Webhooks → your endpoint → "Signing secret".
# In production set in webui.env (mode 600) or via systemd LoadCredential=.
# If unset the webhook route returns HTTP 503 (fail-closed — never processes
# unsigned payloads). Leave blank in local dev unless running webhook tests.
POLAR_WEBHOOK_SECRET=
# POLAR_API_KEY: Polar Organization Access Token (Bearer token for the REST API).
# Obtain from Polar Dashboard → Settings → Organization Access Tokens (scope:
# subscriptions:write). Required for the outbound in-app subscription cancel in
# src/billing/polar_api.py. In production set in webui.env (mode 600) or via
# systemd LoadCredential=. If unset the cancel endpoint fails closed (HTTP 503).
# Leave blank in local dev unless exercising the outbound cancel path.
POLAR_API_KEY=

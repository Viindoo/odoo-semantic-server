POSTGRES_DB=osm
POSTGRES_USER=osm
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://osm:changeme@db:5432/osm

# Tailscale auth key for sidecar. Generate a reusable one-shot key in your
# personal tailnet admin panel (tailscale.com) and paste it here. Leave
# empty until you are ready to enable the sidecar in docker-compose.yml.
TS_AUTHKEY=

# Active tenant schema for local dev. `public` holds the shared Odoo CE
# index; create additional schemas via scripts/create_tenant.py.
OSM_TENANT=public

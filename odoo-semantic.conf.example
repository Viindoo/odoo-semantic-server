# odoo-semantic.conf.example
# Copy → odoo-semantic.conf rồi điền giá trị thật.
# File `odoo-semantic.conf` thật KHÔNG commit (đã trong .gitignore).
#
# Các path tìm config FILE khi runtime (theo thứ tự):
#   1. $ODOO_SEMANTIC_CONF (override — trả về ngay, không tìm tiếp)
#   2. ~/.odoo-semantic/odoo-semantic.conf
#   3. ./odoo-semantic.conf  (repo-local, dev convenience)
#
# Mỗi GIÁ TRỊ có thể override bằng env var (precedence cao hơn INI):
#   neo4j_uri      ← NEO4J_URI
#   neo4j_user     ← NEO4J_USER
#   neo4j_password ← NEO4J_PASSWORD
#   pg_dsn         ← PG_DSN
#   embedder.url   ← EMBEDDER_URL
#   embedder.model ← EMBEDDER_MODEL
#   embedder.dim   ← EMBEDDER_DIM
# → docker-compose.yml và .env dùng env var để cấu hình runtime,
#   INI là default cho local dev.

[database]
neo4j_uri = bolt://localhost:7687
neo4j_user = neo4j
neo4j_password =                                ; bắt buộc điền (hoặc set NEO4J_PASSWORD env)

# Thay <PASSWORD> bằng password thật. KHÔNG để mặc định "password" trên prod.
pg_dsn = postgresql://odoo_semantic:<PASSWORD>@localhost:5432/odoo_semantic

[server]
# Bind localhost — reverse proxy phía trước handle external + auth (M5).
host = 127.0.0.1
port = 8002

[indexer]
# Fallback khi `repos.local_path` chưa được set trong PostgreSQL.
repos_base_dir = /home/user/git

[embedder]
# Ollama endpoint cho Qwen3-Embedding-4B Q5_K_M
# Xem docs/deploy.md §Embedder Setup để biết cách tải model GGUF + tạo Modelfile.
url = http://localhost:11434
model = qwen3-embedding-q5km
dim = 1024
# auth_token = <bearer-token>
# Optional — set if your Ollama is behind an authenticated reverse proxy
# (e.g. Caddy/nginx with Authorization: Bearer check). Leave unset for
# loopback / VPC-firewall-only setups. Env override: EMBEDDER_AUTH_TOKEN

[auth]
# Per-key rate limit (requests per minute, sliding window).
# 0 = unlimited (không nên dùng trên production).
# Xem docs/deploy.md §10 + src/auth.py rate_limit_rpm usage.
rate_limit_rpm = 120

# --- Chú thích auth/secrets ---
# Secrets được lưu trong webui.env + /etc/odoo-semantic/, KHÔNG commit vào repo.
#
# API key: tạo bằng `python -m src.manager create-api-key <name>`
#   → raw key chỉ show một lần, được hash SHA-256 trong DB api_keys table
#   → client gửi header: X-API-Key: osm_xxxx...
#
# SSH key (private): được encrypt bằng Fernet symmetric encryption.
#   Cần set FERNET_KEY trong /etc/odoo-semantic/webui.env:
#   $ python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   → Thêm vào webui.env: FERNET_KEY=<output>
#   → Private key được lưu encrypted trong DB ssh_key_pairs table
#
# Xem docs/deploy.md §10–§13 để biết cách setup + quản lý.

<kanban class="o_kanban_dashboard o_hr_department_kanban o_kanban_small_column" sample="1"><field name="name"></field><field name="company_id"></field><field name="manager_id"></field><field name="color"></field><field name="total_employee"></field><templates><t t-if="!selection_mode" t-name="kanban-menu"><div class="o_kanban_card_manage_section"><div class="o_kanban_manage_reports" role="menuitem"><div class="o_kanban_card_manage_title ps-4 pb-1"><span class="fw-bolder">Reporting</span></div><a class="dropdown-item" name="268" role="menuitem" type="action">Skills History</a></div></div><a class="dropdown-item" role="menuitem" t-if="widget.editable" type="edit">Configuration</a><ul class="oe_kanban_colorpicker" data-field="color" role="menu" t-if="widget.editable"></ul></t><t t-name="kanban-box"><div t-attf-class="#{!selection_mode ? kanban_color(record.color.raw_value) : ''}"><div t-attf-class="o_kanban_card_header oe_kanban_details"><div class="o_kanban_card_header_title"><div class="o_primary"><a type="edit"><field name="name"></field></a></div><div class="o_secondary" groups="base.group_multi_company"><small><i aria-label="Company" class="fa fa-building-o" role="img" title="Company"></i><field name="company_id"></field></small></div></div></div><div class="container o_kanban_card_content" t-if="!selection_mode"><div class="row o_kanban_card_upper_content"><div class="col-6 o_kanban_primary_left"><button class="btn btn-primary" name="214" type="action"><t t-out="record.total_employee.raw_value"></t>Employees</button></div><div class="col-6 o_kanban_primary_right"></div></div><div class="o_kanban_card_lower_content" style="justify-content: end"></div></div></div></t></templates></kanban>
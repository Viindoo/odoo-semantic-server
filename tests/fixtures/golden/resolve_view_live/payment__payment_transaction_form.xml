<form create="false" edit="false" string="Payment Transactions"><header><button class="oe_highlight" invisible="state != 'authorized'" name="action_capture" string="Capture Transaction" type="object"></button><button confirm="Are you sure you want to void the authorized transaction? This action can't be undone." invisible="state != 'authorized'" name="action_void" string="Void Transaction" type="object"></button><field name="state" widget="statusbar"></field></header><sheet><div class="oe_button_box" name="button_box"><button class="oe_stat_button" icon="fa-money" invisible="invoices_count == 0" name="action_view_invoices" type="object"><field name="invoices_count" string="Invoice(s)" widget="statinfo"></field></button><field invisible="1" name="pos_order_id"></field><button class="oe_stat_button" icon="fa-shopping-cart" invisible="not pos_order_id" name="action_view_pos_order" type="object"><field name="pos_order_id" string="POS Order" widget="statinfo"></field></button><button class="oe_stat_button" icon="fa-money" invisible="refunds_count == 0" name="action_view_refunds" type="object"><field name="refunds_count" string="Refunds" widget="statinfo"></field></button><button class="oe_stat_button" icon="fa-money" invisible="sale_order_ids_nbr == 0" name="action_view_sales_orders" type="object"><field name="sale_order_ids_nbr" string="Sales Order(s)" widget="statinfo"></field></button></div><group><group name="transaction_details"><field name="reference"></field><field name="payment_id"></field><field invisible="not source_transaction_id" name="source_transaction_id"></field><field name="amount"></field><field invisible="1" name="currency_id"></field><field name="payment_method_id"></field><field name="provider_id"></field><field groups="base.group_multi_company" name="company_id"></field><field invisible="1" name="provider_code"></field><field name="provider_reference"></field><field invisible="not token_id" name="token_id"></field><field name="create_date"></field><field name="last_state_change"></field><field groups="base.group_no_one" name="is_post_processed"></field></group><group name="transaction_partner"><field name="partner_id" widget="res_partner_many2one"></field><label for="partner_address" string="Address"></label><div class="o_address_format"><field class="o_address_street" name="partner_address" placeholder="Address"></field><field class="o_address_city" name="partner_city" placeholder="City"></field><field class="o_address_state" name="partner_state_id" options="{'no_open': True}" placeholder="State"></field><field class="o_address_zip" name="partner_zip" placeholder="ZIP"></field><field class="o_address_country" name="partner_country_id" options="{'no_open': True}" placeholder="Country"></field></div><field name="partner_email" widget="email"></field><field name="partner_phone" widget="phone"></field><field name="partner_lang"></field></group></group><separator invisible="not child_transaction_ids" string="Child transactions"></separator><field invisible="not child_transaction_ids" name="child_transaction_ids"></field><group invisible="not state_message" string="Message"><field colspan="2" name="state_message" nolabel="1"></field></group></sheet></form>
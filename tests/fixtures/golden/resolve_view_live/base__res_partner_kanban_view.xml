<kanban sample="1"><field name="id"></field><field name="color"></field><field name="display_name"></field><field name="title"></field><field name="email"></field><field name="parent_id"></field><field name="is_company"></field><field name="function"></field><field name="phone"></field><field name="street"></field><field name="street2"></field><field name="zip"></field><field name="city"></field><field name="country_id"></field><field name="mobile"></field><field groups="sales_team.group_sale_salesman" name="sale_order_count"></field><field groups="purchase.group_purchase_user" name="purchase_order_count"></field><field groups="sales_team.group_sale_salesman" name="opportunity_count"></field><field name="meeting_count"></field><field groups="point_of_sale.group_pos_user" name="pos_order_count"></field><field name="state_id"></field><field name="category_id"></field><field name="avatar_128"></field><field name="type"></field><field name="activity_state"></field><field name="active"></field><templates><t t-name="kanban-box"><div class="oe_kanban_global_click o_kanban_record_has_image_fill o_res_partner_kanban"><t t-if="!record.is_company.raw_value"><t t-set="avatar_image" t-value="kanban_image('res.partner', 'avatar_128', record.id.raw_value)"></t><div class="o_kanban_image_fill_left d-none d-md-block"><img t-att-alt="record.id.value" t-attf-src="#{avatar_image}"></img><img class="o_kanban_image_inner_pic" t-att-alt="record.parent_id.value" t-att-src="kanban_image('res.partner', 'avatar_128', record.parent_id.raw_value)" t-if="record.parent_id.raw_value"></img></div><div class="o_kanban_image d-md-none d-block"><img t-att-alt="record.id.value" t-attf-src="#{avatar_image}"></img><img class="o_kanban_image_inner_pic" t-att-alt="record.parent_id.value" t-att-src="kanban_image('res.partner', 'avatar_128', record.parent_id.raw_value)" t-if="record.parent_id.raw_value"></img></div></t><t t-else=""><div class="o_kanban_image_fill_left d-none d-md-block o_kanban_image_full"><img role="img" t-att-alt="record.id.value" t-attf-src="#{kanban_image('res.partner', 'avatar_128', record.id.raw_value)}"></img></div><div class="o_kanban_image d-md-none d-block o_kanban_image_full"><img role="img" t-att-alt="record.id.value" t-attf-src="#{kanban_image('res.partner', 'avatar_128', record.id.raw_value)}"></img></div></t><div class="ribbon ribbon-top-right" invisible="active"><span class="text-bg-danger">Archived</span></div><div class="oe_kanban_details d-flex flex-column justify-content-between"><div><strong class="o_kanban_record_title oe_partner_heading"><field name="display_name"></field></strong><div class="o_kanban_tags_section oe_kanban_partner_categories"><span class="oe_kanban_list_many2many"><field name="category_id" options="{'color_field': 'color'}" widget="many2many_tags"></field></span></div><ul><li t-if="record.parent_id.raw_value and !record.function.raw_value"><field name="parent_id"></field></li><li t-elif="!record.parent_id.raw_value and record.function.raw_value"><field name="function"></field></li><li t-elif="record.parent_id.raw_value and record.function.raw_value"><field name="function"></field>at<field name="parent_id"></field></li><li t-if="record.city.raw_value or record.country_id.raw_value"><t t-if="record.city.raw_value"><field name="city"></field><t t-if="record.country_id.raw_value">,</t></t><t t-if="record.country_id.raw_value"><field name="country_id"></field></t></li><li class="o_text_overflow" t-if="record.email.raw_value"><field name="email"></field></li></ul></div><div class="o_kanban_record_bottom"><div class="oe_kanban_bottom_left"><a class="oe_kanban_action oe_kanban_action_a me-1" data-name="schedule_meeting" data-type="object" href="#" t-if="record.meeting_count.value>0"><span class="badge rounded-pill"><i aria-label="Meetings" class="fa fa-fw fa-calendar" role="img" title="Meetings"></i><t t-out="record.meeting_count.value"></t></span></a><a class="oe_kanban_action oe_kanban_action_a me-1" data-name="action_view_opportunity" data-type="object" groups="sales_team.group_sale_salesman" href="#" t-if="record.opportunity_count.value>0"><span class="badge rounded-pill"><i aria-label="Opportunities" class="fa fa-fw fa-star" role="img" title="Opportunities"></i><t t-out="record.opportunity_count.value"></t></span></a><a class="oe_kanban_action oe_kanban_action_a me-1" data-name="518" data-type="action" groups="purchase.group_purchase_user" href="#" t-if="record.purchase_order_count.value>0"><span class="badge rounded-pill"><i aria-label="Purchases" class="fa fa-fw fa-credit-card" role="img" title="Purchases"></i><t t-out="record.purchase_order_count.value"></t></span></a><a class="oe_kanban_action oe_kanban_action_a me-1" data-name="action_view_pos_order" data-type="object" groups="point_of_sale.group_pos_user" href="#" t-if="record.pos_order_count.value>0"><span class="badge rounded-pill"><i aria-label="Shopping cart" class="fa fa-fw fa-shopping-bag" role="img" title="Shopping cart"></i><t t-out="record.pos_order_count.value"></t></span></a><a class="oe_kanban_action oe_kanban_action_a me-1" data-name="action_view_sale_order" data-type="object" groups="sales_team.group_sale_salesman" href="#" t-if="record.sale_order_count.value>0"><span class="badge rounded-pill"><i aria-label="Sale orders" class="fa fa-fw fa-usd" role="img" title="Sales orders"></i><t t-out="record.sale_order_count.value"></t></span></a></div><div class="oe_kanban_bottom_right"><field name="activity_ids" widget="kanban_activity"></field></div></div></div></div></t></templates></kanban>
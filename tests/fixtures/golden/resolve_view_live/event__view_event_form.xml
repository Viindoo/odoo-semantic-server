<form class="o_event_form_view" string="Events"><header><button context="{'default_event_id': id}" name="250" type="action">Registration Desk</button><field name="stage_id" options="{'clickable': '1'}" widget="statusbar"></field></header><sheet><div class="oe_button_box" groups="base.group_user" name="button_box"><button class="oe_stat_button" icon="fa-line-chart" name="248" type="action"><div class="o_stat_info"><span class="o_stat_text">Registration</span></div></button><button class="oe_stat_button" context="{'search_default_expected': True}" help="Total Registrations for this Event" icon="fa-users" name="243" type="action"><field name="seats_taken" string="Attendees" widget="statinfo"></field></button><button class="oe_stat_button" groups="sales_team.group_sale_salesman" icon="fa-star" invisible="lead_count == 0" name="502" type="action"><div class="o_stat_info"><field name="lead_count"></field><span class="o_stat_text">Leads</span></div></button><field invisible="1" name="currency_id"></field><button class="oe_stat_button" groups="sales_team.group_sale_salesman" help="Total sales for this event" icon="fa-dollar" invisible="sale_price_subtotal == 0 or not sale_price_subtotal" name="action_view_linked_orders" type="object"><div class="o_field_widget o_stat_info"><span class="o_stat_value"><field name="sale_price_subtotal" options="{'currency_field': 'currency_id'}" string="Sales" widget="monetary"></field></span><span class="o_stat_text">Sales</span></div></button><button class="oe_stat_button" context="{'default_event_id': id}" icon="fa-mobile" name="250" type="action"><div class="o_stat_info"><span class="o_stat_text">Registration Desk</span></div></button></div><field invisible="1" name="active"></field><field invisible="1" name="company_id"></field><field invisible="1" name="legend_blocked"></field><field invisible="1" name="legend_normal"></field><field invisible="1" name="legend_done"></field><widget bg_color="text-bg-danger" invisible="active" name="web_ribbon" text="Archived"></widget><field class="ms-auto float-end" name="kanban_state" widget="state_selection"></field><div class="oe_title"><label for="name" string="Event Name"></label><h1><field class="text-break" name="name" options="{'line_breaks': False}" placeholder="e.g. Conference for Architects" widget="text"></field></h1></div><group><group><field invisible="1" name="active"></field><field name="date_begin" options="{'end_date_field': 'date_end'}" string="Date" widget="daterange"></field><field invisible="1" name="date_end"></field><field name="date_tz"></field><field name="lang"></field><field name="event_type_id" string="Template"></field><field name="tag_ids" options="{'color_field': 'color', 'no_quick_create': True}" widget="many2many_tags"></field></group><group name="right_event_details"><field name="organizer_id"></field><field domain="[('share', '=', False)]" name="user_id" widget="many2one_avatar_user"></field><field groups="base.group_multi_company" name="company_id"></field><field context="{'show_address': 1}" name="address_id"></field><label for="seats_limited" string="Limit Registrations"></label><div><field name="seats_limited"></field><span invisible="not seats_limited" required="not seats_limited">to<field class="oe_inline o_input_9ch" name="seats_max"></field>Attendees</span></div><field name="badge_format"></field><field name="badge_image"></field></group></group><notebook><page name="tickets" string="Tickets"><field context="{                                 'default_event_name': name,                                 'tree_view_ref': 'event.event_event_ticket_view_tree_from_event',                                 'form_view_ref': 'event.event_event_ticket_view_form_from_event',                                 'kanban_view_ref': 'event.event_event_ticket_view_kanban_from_event'}" mode="tree,kanban" name="event_ticket_ids"></field></page><page name="event_communication" string="Communication"><field name="event_mail_ids"><tree editable="bottom" string="Communication"><field name="sequence" widget="handle"></field><field name="notification_type"></field><field column_invisible="True" name="template_model_id"></field><field context="{'filter_template_on_event': True, 'default_model': 'event.registration'}" name="template_ref" options="{'hide_model': True, 'no_quick_create': True}"></field><field name="interval_nbr" readonly="interval_unit == 'now'"></field><field name="interval_unit"></field><field name="interval_type"></field><field groups="base.group_no_one" name="scheduled_date"></field><field name="mail_count_done"></field><field name="mail_state" nolabel="1" options="{'sent': 'fa fa-check', 'scheduled': 'fa fa-hourglass-half', 'running': 'fa fa-cogs'}" string=" " widget="event_icon_selection"></field></tree></field></page><page name="event_notes" string="Notes"><group><label for="note" string="Note"></label><br></br><field colspan="2" name="note" nolabel="1" placeholder="Add some internal notes (to do lists, contact info, ...)"></field><label for="ticket_instructions" string="Ticket Instructions"></label><br></br><field colspan="2" name="ticket_instructions" nolabel="1" placeholder="e.g. How to get to your event, door closing time, ..."></field></group></page></notebook></sheet><div class="oe_chatter"><field groups="base.group_user" name="message_follower_ids"></field><field name="activity_ids"></field><field name="message_ids"></field></div></form>
<kanban class="o_utm_kanban" default_group_by="stage_id" examples="utm_campaign" on_create="quick_create" quick_create_view="utm.utm_campaign_view_form_quick_create" sample="1"><field name="color"></field><field name="user_id"></field><field name="use_leads"></field><field name="stage_id"></field><field name="active"></field><templates><t t-name="kanban-menu"><t t-if="widget.editable"><a class="dropdown-item" role="menuitem" type="edit">Edit</a></t><t t-if="widget.deletable"><a class="dropdown-item" role="menuitem" type="delete">Delete</a></t><a class="dropdown-item o_kanban_mailing_active" name="toggle_active" role="menuitem" type="object"><t t-if="record.active.raw_value">Archive</t><t t-else="">Restore</t></a><div class="dropdown-divider" role="separator"></div><ul class="oe_kanban_colorpicker" data-field="color"></ul></t><t t-name="kanban-box"><div t-attf-class="oe_kanban_color_#{kanban_getcolor(record.color.raw_value)} oe_kanban_card oe_kanban_global_click"><div class="oe_kanban_content"><div class="o_kanban_record_top"><div class="o_kanban_record_headings"><h3 class="oe_margin_bottom_8 o_kanban_record_title"><field name="title"></field></h3></div></div><div class="o_kanban_record_body"><field name="tag_ids" options="{'color_field': 'color'}" widget="many2many_tags"></field><ul class="list-group list-group-horizontal my-0" id="o_utm_actions"></ul></div><div class="o_kanban_record_bottom h5 mt-2 mb-0"><div class="oe_kanban_bottom_left py-auto"><t t-if="record.use_leads.raw_value"><t t-set="crm_lead_count_label">Leads</t></t><t t-else=""><t t-set="crm_lead_count_label">Opportunities</t></t><a class="oe_kanban_action oe_kanban_action_a btn-outline-primary rounded-pill me-1 order-3" data-name="action_redirect_to_leads_opportunities" data-type="object" groups="sales_team.group_sale_salesman" href="#" role="button" t-att-title="crm_lead_count_label" t-if="record.crm_lead_count"><span class="badge"><i class="fa fa-fw fa-star" role="img" t-att-aria-label="crm_lead_count_label"></i><field name="crm_lead_count"></field></span></a><a class="oe_kanban_action oe_kanban_action_a btn-outline-primary rounded-pill me-1 order-1" data-name="action_redirect_to_invoiced" data-type="object" groups="sales_team.group_sale_salesman" href="#" role="button" t-if="record.invoiced_amount" title="Revenues"><span class="badge"><field invisible="True" name="currency_id"></field><field name="invoiced_amount" options="{'currency_field': 'currency_id'}" widget="monetary"></field></span></a><a class="oe_kanban_action oe_kanban_action_a btn-outline-primary rounded-pill me-1 order-2" data-name="action_redirect_to_quotations" data-type="object" groups="sales_team.group_sale_salesman" href="#" role="button" t-if="record.quotation_count" title="Quotations"><span class="badge"><i aria-label="Quotations" class="fa fa-fw fa-money me-1" role="img"></i><field name="quotation_count"></field></span></a></div><div class="oe_kanban_bottom_right"><field name="user_id" widget="many2one_avatar_user"></field></div></div></div><div class="clearfix"></div></div></t></templates></kanban>
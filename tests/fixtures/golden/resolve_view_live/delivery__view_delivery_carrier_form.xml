<form string="Carrier"><sheet><div class="oe_button_box" name="button_box"><button class="oe_stat_button" icon="fa-play" invisible="not prod_environment or delivery_type == 'fixed' or delivery_type == 'base_on_rule'" name="toggle_prod_environment" type="object"><div class="o_stat_info o_field_widget"><span class="text-success">Production</span><span class="o_stat_text">Environment</span></div></button><button class="oe_stat_button" icon="fa-stop" invisible="prod_environment or delivery_type == 'fixed' or delivery_type == 'base_on_rule'" name="toggle_prod_environment" type="object"><div class="o_stat_info o_field_widget"><span class="o_stat_text o_warning_text fw-bold">Test</span><span class="o_stat_text">Environment</span></div></button><button class="oe_stat_button" icon="fa-code" invisible="delivery_type == 'fixed' or delivery_type == 'base_on_rule' or debug_logging" name="toggle_debug" type="object"><div class="o_stat_info o_field_widget"><span class="o_stat_text text-danger">No debug</span></div></button><button class="oe_stat_button" icon="fa-code" invisible="delivery_type == 'fixed' or delivery_type == 'base_on_rule' or not debug_logging" name="toggle_debug" type="object"><div class="o_stat_info o_field_widget"><span class="text-success">Debug requests</span></div></button></div><widget bg_color="text-bg-danger" invisible="active" name="web_ribbon" title="Archived"></widget><div class="oe_title" name="title"><label for="name" string="Shipping Method"></label><h1><field name="name" placeholder="e.g. UPS Express"></field></h1></div><group><group name="provider_details"><field invisible="1" name="active"></field><field invisible="1" name="company_id"></field><field invisible="1" name="prod_environment"></field><field invisible="1" name="debug_logging"></field><label for="delivery_type"></label><div><field name="delivery_type"></field><button class="oe_link oe_edit_only" name="install_more_provider" string="Install more Providers" type="object"></button></div><field invisible="delivery_type == 'fixed' or delivery_type == 'base_on_rule'" name="integration_level" widget="radio"></field><field groups="base.group_multi_company" name="company_id"></field><field groups="stock.group_adv_location" name="route_ids" options="{'no_create': True}" string="Routes" widget="many2many_tags"></field></group><group name="delivery_details"><field invisible="1" name="currency_id"></field><field class="oe_inline" invisible="delivery_type != 'fixed'" name="fixed_price" widget="monetary"></field><field class="oe_inline" invisible="delivery_type == 'fixed'" name="margin" string="Margin on Rate" widget="percentage"></field><field invisible="delivery_type == 'fixed'" name="fixed_margin" string="Additional margin" widget="monetary"></field><label for="free_over" invisible="delivery_type == 'base_on_rule'"></label><div invisible="delivery_type == 'base_on_rule'" name="free_over_amount"><field name="free_over"></field><field class="oe_inline" invisible="not free_over" name="amount" required="free_over" widget="monetary"></field></div><field context="{'default_detailed_type': 'service', 'default_sale_ok': False, 'default_purchase_ok': False, 'default_invoice_policy': 'order'}" name="product_id"></field><field invisible="delivery_type in ('fixed', 'base_on_rule') or integration_level == 'rate'" name="invoice_policy" widget="radio"></field><field invisible="1" name="supports_shipping_insurance"></field><label String="Shipping Insurance" for="shipping_insurance" invisible="not supports_shipping_insurance"></label><div invisible="not supports_shipping_insurance"><field class="oe_inline" name="shipping_insurance"></field>%</div></group></group><notebook><page invisible="delivery_type != 'base_on_rule'" name="pricing" string="Pricing"><group name="general"><field colspan="2" name="price_rule_ids" nolabel="1"></field></group></page><page name="destination" string="Destination Availability"><group col="1"><p>Filling this form allows you to filter delivery carriers according to the delivery address of your customer.</p><group class="oe_inline" name="country_details"><field name="country_ids" options="{'no_open': True, 'no_create': True}" widget="many2many_tags"></field><field domain="[('country_id', 'in', country_ids)]" force_save="1" name="state_ids" options="{'no_create': True}" readonly="not country_ids" widget="many2many_tags"></field><field force_save="1" name="zip_prefix_ids" options="{'no_create_edit': True}" readonly="not country_ids" widget="many2many_tags"></field></group><p class="fst-italic" invisible="country_ids">Please select a country before choosing a state or a zip prefix.</p></group></page><page name="description" string="Description"><field name="carrier_description" placeholder="Shipping method details to be included at bottom sales orders and their confirmation emails. E.g. Instructions for customers to follow."></field></page></notebook></sheet></form>
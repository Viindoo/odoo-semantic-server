journal_line', 'search_default_to_check': True}" name="open_action" type="object"><t t-out="dashboard.number_to_check"></t>to check</a></div><div class="col-auto text-end"><span class="o_kanban_monetary"><t t-out="dashboard.to_check_balance"></t></span></div></div></t></div></t><t t-name="JournalBodyBankCash"><div class="col-12 col-sm-5 mb-3 mb-sm-0 o_kanban_primary_left" id="dashboard_bank_cash_left"><t t-if="journal_type == 'bank'"><t t-if="['undefined', 'online_sync'].includes(dashboard.bank_statements_source)"><button class="btn btn-primary" groups="account.group_account_invoice" name="action_configure_bank_journal" type="object">Connect</button></t><div class="d-flex mt-3 mt-sm-0" id="transactions" style="gap: 5px;"><div class="w-100" name="bank_journal_cta"><div class="w-100 d-flex" name="bank_journal_transactions" style="gap: 5px;" t-if="['undefined', 'file_import'].includes(dashboard.bank_statements_source)"><a groups="account.group_account_invoice" id="create_transaction" name="action_new_transaction" type="object">New Transaction</a></div></div></div></t><t t-if="journal_type == 'cash'"><button class="btn btn-primary" groups="account.group_account_invoice" name="action_new_transaction" t-if="dashboard.number_to_reconcile == 0" type="object">New Transaction</button><a class="oe_inline" groups="account.group_account_invoice" name="action_new_transaction" t-if="dashboard.number_to_reconcile > 0" type="object">New Transaction</a></t></div><div class="col-12 col-sm-7 o_kanban_primary_right" id="dashboard_bank_cash_right"><div class="row" t-if="dashboard.nb_lines_bank_account_balance > 0"><div class="col overflow-hidden text-start" id="dashboard_bank_cash_balance"><span>Balance</span></div><div class="col-auto text-end"><span class="o_kanban_monetary"><t t-out="dashboard.account_balance"></t></span></div></div><t t-if="dashboard.has_at_least_one_statement and dashboard.account_balance != dashboard.last_balance"><div class="row" name="latest_statement"><div class
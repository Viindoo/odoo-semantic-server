<kanban banner_route="/onboarding/account_dashboard" class="o_kanban_dashboard o_account_kanban" create="false" js_class="account_dashboard_kanban"><field name="id"></field><field name="name"></field><field name="type"></field><field name="color"></field><field name="show_on_dashboard"></field><field name="kanban_dashboard"></field><field name="activity_ids"></field><field name="activity_state"></field><field name="alias_domain_id"></field><templates><t t-name="kanban-box"><div t-attf-class="d-flex flex-column flex-fill"><t t-set="dashboard" t-value="JSON.parse(record.kanban_dashboard.raw_value)"></t><t t-set="journal_type" t-value="record.type.raw_value"></t><t t-call="JournalTop"></t><div t-att-class="'container o_kanban_card_content' + (dashboard.is_sample_data ? ' o_sample_data' : '')"><div class="row"><t t-call="JournalBodyBankCash" t-if="(journal_type == 'bank' || journal_type == 'cash')"></t><t t-call="JournalBodySalePurchase" t-if="journal_type == 'sale' || journal_type == 'purchase'"></t><t t-call="JournalMiscelaneous" t-if="journal_type == 'general'"></t><div class="col-12 col-sm-5 mb-3 mb-sm-0 o_kanban_primary_left"></div><div class="col-12 col-sm-7 o_kanban_primary_right"><t t-call="HasSequenceHoles"></t></div></div><div class="row mt-auto"><t t-call="JournalBodyGraph" t-if="['bank', 'cash', 'sale', 'purchase'].includes(journal_type)"></t></div></div></div></t><t t-name="JournalTop"><div t-attf-class="o_kanban_card_header"><div class="o_kanban_card_header_title"><div class="o_primary"><a name="open_action" type="object"><field name="name"></field></a><t t-if="dashboard.show_company"><span class="small" groups="base.group_multi_company">-<field name="company_id"></field></span></t></div><div class="o_secondary" t-att-title="dashboard.title" t-if="journal_type == 'purchase' &amp;&amp; record.alias_domain_id.raw_value"><field name="alias_id"></field></div></div></div></t><t t-name="HasSequenceHoles"><a class="text-warning" name="show_sequence_holes" t-if="dashboard.has_sequence_holes" title="Gaps due to canceled invoices, deleted entries or manual errors in open period." type="object">Gaps in the sequence</a></t><t t-name="kanban-menu"><t t-set="dashboard" t-value="JSON.parse(record.kanban_dashboard.raw_value)"></t><t t-set="journal_type" t-value="record.type.raw_value"></t><div class="container"><div class="row" id="bank_and_cash_container" t-if="journal_type == 'bank' || journal_type == 'cash'"><div class="col-4 o_kanban_card_manage_section o_kanban_manage_view"><h5 class="o_kanban_card_manage_title" id="card_action_view_menus"><span role="separator">View</span></h5><div id="action_card_statements"><a context="{'action_name': 'action_bank_statement_tree', 'search_default_journal': True}" name="open_action_with_context" role="menuitem" t-if="journal_type == 'bank'" type="object">Statements</a><a context="{'action_name': 'action_view_bank_statement_tree', 'search_default_journal': True}" name="open_action_with_context" role="menuitem" t-if="journal_type == 'cash'" type="object">Cash Registers</a></div><div><a name="open_payments_action" role="menuitem" type="object">Payments</a></div></div><div class="col-4 o_kanban_card_manage_section o_kanban_manage_new" groups="account.group_account_user"><h5 class="o_kanban_card_manage_title"><span role="separator">New</span></h5><div name="bank_new_actions" t-if="journal_type == 'bank'"><a groups="account.group_account_invoice" name="action_new_transaction" role="menuitem" type="object">New Transaction</a></div><div name="bank_customer_payment"><a name="create_customer_payment" role="menuitem" type="object">Customer Payment</a></div><div><a name="create_supplier_payment" role="menuitem" type="object">Vendor Payment</a></div></div></div><div class="row" t-if="journal_type == 'purchase' || journal_type == 'sale'"><div class="col-4 o_kanban_card_manage_section o_kanban_manage_view"><h5 class="o_kanban_card_manage_title"><span>View</span></h5><div><a context="{'action_name': 'action_move_out_invoice_type'}" name="open_action" t-if="journal_type == 'sale'" type="object">Invoices</a><a context="{'action_name': 'action_move_in_invoice_type'}" name="open_action" t-if="journal_type == 'purchase'" type="object">Bills</a></div><div id="sale_purchase_refund"><a context="{'action_name': 'action_move_out_refund_type'}" name="open_action" t-if="journal_type == 'sale'" type="object">Credit Notes</a><a context="{'action_name': 'action_move_in_refund_type'}" name="open_action" t-if="journal_type == 'purchase'" type="object">Refund</a></div><div><a context="{'action_name': 'action_account_moves_all_a'}" groups="base.group_no_one" name="open_action" type="object">Journal Items</a></div></div><div class="col-4 o_kanban_card_manage_section o_kanban_manage_new" groups="account.group_account_invoice"><h5 class="o_kanban_card_manage_title"><span>New</span></h5><div><a name="action_create_new" type="object"><span t-if="journal_type == 'sale'">Invoice</span><span t-if="journal_type == 'purchase'">Bill</span></a></div><div><a context="{'refund':True}" name="action_create_new" type="object"><span t-if="journal_type == 'sale'">Credit Note</span><span t-if="journal_type == 'purchase'">Refund</span></a></div><div t-if="journal_type == 'sale'"><widget btnClass="file_upload_kanban_action_a" name="account_file_uploader" title="Upload Invoices"></widget></div></div><div class="col-4 o_kanban_card_manage_section o_kanban_manage_reports"><h5 class="o_kanban_card_manage_title"><span>Reporting</span></h5><div><a groups="account.group_account_readonly" name="340" t-if="journal_type == 'sale'" type="action">Invoices Analysis</a><a groups="account.group_account_readonly" name="339" t-if="journal_type == 'purchase'" type="action">Bills Analysis</a></div></div></div><div class="row" t-if="journal_type == 'general' || journal_type == 'situation'"><div class="col-4 o_kanban_card_manage_section o_kanban_manage_view"><h5 class="o_kanban_card_manage_title"><span>View</span></h5><div><a con
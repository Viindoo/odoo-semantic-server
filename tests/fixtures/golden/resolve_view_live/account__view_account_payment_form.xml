t_user,account.group_account_readonly" icon="fa-bars" name="button_open_journal_entry" type="object"><div class="o_stat_info"><span class="o_stat_text">Journal Entry</span></div></button><button class="oe_stat_button" icon="fa-money" invisible="refunds_count == 0" name="action_view_refunds" type="object"><field name="refunds_count" string="Refunds" widget="statinfo"></field></button><field invisible="1" name="pos_order_id"></field><button class="oe_stat_button" icon="fa-shopping-cart" invisible="not pos_order_id" name="action_view_pos_order" type="object"><field name="pos_order_id" string="POS Order" widget="statinfo"></field></button></div><widget bg_color="text-bg-info" invisible="state != 'invoicing_legacy'" name="web_ribbon" text="Invoicing App Legacy" tooltip="This payment has been generated through the Invoicing app, before installing Accounting. It has been disabled by the 'Invoicing Switch Threshold Date' setting so that it does not impact your accounting."></widget><div class="oe_title"><h1 invisible="state != 'draft'"><span>Draft</span></h1><h1 invisible="state == 'draft'"><field name="name" readonly="1"></field></h1></div><group name="main_group"><group name="group1"><label for="is_internal_transfer"></label><div><field name="is_internal_transfer" readonly="state != 'draft'"></field><span class="fst-italic" invisible="paired_internal_transfer_payment_id or not is_internal_transfer or state != 'draft'">A second payment will be created in the destination journal.</span></div><field name="payment_type" options="{'horizontal': True}" readonly="state != 'draft'" widget="radio"></field><field context="{'default_is_company': True}" invisible="partner_type != 'customer' or is_internal_transfer" name="partner_id" options="{'no_quick_create': True}" readonly="state != 'draft'" string="Customer"></field><field context="{'default_is_company': True}" invisible="partner_type != 'supplier' or is_internal_transfer" name="partner_id" options="{'no_quick_create': True}" re
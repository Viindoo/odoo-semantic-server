<form string="Register Payment"><header><button class="oe_highlight" data-hotkey="q" invisible="state != 'draft'" name="action_post" string="Confirm" type="object"></button><button class="btn btn-secondary" data-hotkey="w" groups="account.group_account_invoice" invisible="not show_reset_to_draft_button" name="action_draft" string="Reset To Draft" type="object"></button><field invisible="1" name="amount_available_for_refund"></field><button class="btn-secondary" groups="account.group_account_invoice" invisible="amount_available_for_refund &lt;= 0" name="action_refund_wizard" string="Refund" type="object"></button><button data-hotkey="x" invisible="not id or state != 'draft'" name="action_cancel" string="Cancel" type="object"></button><button data-hotkey="w" groups="account.group_account_invoice" invisible="state != 'posted' or show_reset_to_draft_button or not need_cancel_request" name="button_request_cancel" string="Request Cancel" type="object"></button><button data-hotkey="v" invisible="state != 'posted' or is_move_sent or payment_method_code != 'manual'" name="mark_as_sent" string="Mark as Sent" type="object"></button><button data-hotkey="k" invisible="state != 'posted' or not is_move_sent or payment_method_code != 'manual'" name="unmark_as_sent" string="Unmark as Sent" type="object"></button><field name="state" statusbar_visible="draft,posted" widget="statusbar"></field></header><div class="alert alert-warning text-center" invisible="not is_internal_transfer or not require_partner_bank_account or partner_bank_id" role="alert">The selected payment method requires a bank account but none is set on<button class="oe_link alert-link" name="action_open_destination_journal" style="padding: 0; vertical-align: baseline;" type="object">the destination journal</button>.</div><sheet><field invisible="1" name="id"></field><field invisible="1" name="is_move_sent"></field><field invisible="1" name="need_cancel_request"></field><field invisible="1" name="show_reset_to_draft_but
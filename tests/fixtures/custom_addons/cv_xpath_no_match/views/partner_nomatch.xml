<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="cv_nomatch_ext" model="ir.ui.view">
        <field name="name">cv.nomatch.ext</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="cv_basic_form.cv_basic_partner_form"/>

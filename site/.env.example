# site/.env.example — Astro frontend environment variables
# Copy to site/.env and fill in values before running `pnpm dev`.

# ── hCaptcha (M9 W-SG) ───────────────────────────────────────────────
# Public site key shown in the browser widget (safe to expose).
# Leave blank in local dev — captcha widget renders in test mode.
# Get your keys from https://dashboard.hcaptcha.com
PUBLIC_HCAPTCHA_SITE_KEY=

---
// SPDX-License-Identifier: AGPL-3.0-or-later
// signup.astro — Public signup page (M9 W-SG)
// prerender=false: SSR so we can redirect already-authed users server-side.
export const prerender = false;

import AuthLayout from '../layouts/AuthLayout.astro';
import { FASTAPI_BASE } from '../lib/fastapi';
import OAuthButtons from '../components/OAuthButtons.astro';
import { resolveAuthLanding } from '../lib/auth-landing';

// Redirect already-authed users to their role-appropriate landing.
const cookieHeader = Astro.request.headers.get('cookie') ?? '';
let alreadyAuthed = false;
let alreadyAuthedIsAdmin = false;
try {
  const verify = await fetch(`${FASTAPI_BASE}/api/auth/verify`, {
    headers: { cookie: cookieHeader },
  });
  alreadyAuthed = verify.ok;
  if (verify.ok) {
    const vb = await verify.json().catch(() => ({ is_admin: false }));
    alreadyAuthedIsAdmin = vb.is_admin === true;
  }
} catch {
  // server down — allow signup page
}

if (alreadyAuthed) {
  // resolveAuthLanding avoids the prior /admin → /account/api-keys double-bounce
  // for already-authed non-admin customers landing on the signup page.
  return Astro.redirect(resolveAuthLanding(alreadyAuthedIsAdmin));
}

// XSS-safe error banner — ONLY whitelisted codes are rendered.
// User-supplied ?error= values are never rendered verbatim.
const SIGNUP_ERROR_MESSAGES: Record<string, string> = {
  oauth_failed:
    'Sign-up with that provider didn\'t work. Try again or use email.',
  signup_disabled:
    'Sign-ups are currently invite-only. Contact your admin for an invite.',
  email_conflict:
    'That email is already linked to another account. Try signing in instead.',
  no_email:
    'Your GitHub account has no verified primary email. Add one in GitHub settings and try again.',
};
const SIGNUP_ERROR_FALLBACK = 'Sign-up failed. Please try again.';

const _rawSignupError = Astro.url.searchParams.get('error') ?? '';
const signupErrorMsg: string | null = _rawSignupError
  ? (SIGNUP_ERROR_MESSAGES[_rawSignupError] ?? SIGNUP_ERROR_FALLBACK)
  : null;

const hcaptchaSiteKey = import.meta.env.PUBLIC_HCAPTCHA_SITE_KEY ?? '';
---

<AuthLayout title="Sign Up — Odoo Semantic MCP" subtitle="Create your account">
  <Fragment slot="head">
    <!-- hCaptcha script (only injected when site key is configured) -->
    {hcaptchaSiteKey && (
      <script src="https://js.hcaptcha.com/1/api.js" async defer is:inline></script>
    )}
  </Fragment>

  <!-- Flash banner -->
  <div data-testid="flash-banner" hidden
    class="fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium"></div>

  <!-- Server-rendered error banner (from ?error= URL param) -->
  {signupErrorMsg && (
    <div
      class="mb-4 px-4 py-3 rounded-lg border text-sm font-medium bg-red-50 border-red-200 text-red-600"
      role="alert"
      aria-live="assertive"
      data-testid="signup-error-banner"
    >
      {signupErrorMsg}
    </div>
  )}

  <!-- Signup form -->
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <!-- Success state (hidden until submit succeeds) -->
    <div data-testid="signup-success" hidden class="text-center py-4" role="status" aria-live="polite">
      <p class="text-lg font-semibold text-gray-900 mb-2">Check your email!</p>
      <p class="text-sm text-gray-600" data-testid="signup-success-msg">
        We sent a verification link to your email address. Click it to activate your account.
      </p>
      <p class="text-xs text-gray-400 mt-3">The link expires in 24 hours.</p>
    </div>

    <!-- The form itself -->
    <form data-testid="signup-form" class="space-y-4">
      <div>
        <label for="su-email" class="block text-sm font-medium text-gray-700 mb-1">
          Email
        </label>
        <input
          id="su-email"
          name="email"
          type="email"
          autocomplete="email"
          required
          autofocus
          data-testid="signup-email-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-white placeholder-gray-500
                 focus:outline-none focus:ring-2 focus:ring-viindoo-primary-deep focus:border-viindoo-primary-deep"
          placeholder="you@example.com"
        />
      </div>

      <div>
        <label for="su-username" class="block text-sm font-medium text-gray-700 mb-1">
          Username
        </label>
        <input
          id="su-username"
          name="username"
          type="text"
          autocomplete="username"
          required
          minlength="2"
          maxlength="64"
          data-testid="signup-username-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-white placeholder-gray-500
                 focus:outline-none focus:ring-2 focus:ring-viindoo-primary-deep focus:border-viindoo-primary-deep"
          placeholder="yourname"
        />
      </div>

      <div>
        <label for="su-password" class="block text-sm font-medium text-gray-700 mb-1">
          Password
        </label>
        <input
          id="su-password"
          name="password"
          type="password"
          autocomplete="new-password"
          required
          minlength="12"
          data-testid="signup-password-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-white placeholder-gray-500
                 focus:outline-none focus:ring-2 focus:ring-viindoo-primary-deep focus:border-viindoo-primary-deep"
          placeholder="Min 12 characters"
        />
      </div>

      <div>
        <label for="su-confirm-password" class="block text-sm font-medium text-gray-700 mb-1">
          Confirm Password
        </label>
        <input
          id="su-confirm-password"
          name="confirm_password"
          type="password"
          autocomplete="new-password"
          required
          data-testid="signup-confirm-password-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-white placeholder-gray-500
                 focus:outline-none focus:ring-2 focus:ring-viindoo-primary-deep focus:border-viindoo-primary-deep"
          placeholder="Repeat password"
        />
      </div>

      <!-- Consent checkbox (required — W6 legal gate D4) -->
      <div class="flex items-start gap-3">
        <input
          id="su-consent"
          name="consent"
          type="checkbox"
          required
          data-testid="signup-consent-checkbox"
          class="mt-0.5 h-4 w-4 rounded border-gray-300 text-viindoo-primary focus:ring-viindoo-primary-deep cursor-pointer"
        />
        <label for="su-consent" class="text-sm text-gray-600 cursor-pointer select-none">
          I agree to the
          <a href="/terms" target="_blank" rel="noopener noreferrer" class="text-viindoo-primary-text hover:underline font-medium">Terms of Service</a>
          and
          <a href="/privacy" target="_blank" rel="noopener noreferrer" class="text-viindoo-primary-text hover:underline font-medium">Privacy Policy</a>.
        </label>
      </div>

      <!--
        Informational-only withdrawal notice (WI-4). Signing up creates a FREE
        account, so no paid-service withdrawal waiver is needed here. The binding
        "begin immediately / waive withdrawal" consent is collected at checkout by
        WI-5 (see /refund §B). This note is purely to inform consumers; it is NOT a
        second required checkbox and does NOT change form logic.
      -->
      <p class="text-xs text-gray-400 leading-relaxed" data-testid="signup-withdrawal-notice">
        Creating an account is free. When you later subscribe to a paid plan, EEA/UK
        consumers keep a 14-day right of withdrawal; if you ask us to start the paid
        service immediately you may be asked to confirm that you will lose that right
        once the service is fully performed, and will pay pro-rata for any portion
        already provided if you withdraw earlier. See our
        <a href="/refund" target="_blank" rel="noopener noreferrer" class="text-viindoo-primary-text hover:underline">Refund &amp; Cancellation Policy</a>.
      </p>

      <!-- hCaptcha widget (only shown when site key is configured) -->
      {hcaptchaSiteKey ? (
        <div
          class="h-captcha"
          data-sitekey={hcaptchaSiteKey}
          data-theme="light"
          data-testid="signup-hcaptcha"
        ></div>
      ) : (
        <input type="hidden" name="hcaptcha_token" value="" data-testid="signup-hcaptcha-hidden" />
      )}

      <!-- Error message (item #13 a11y) -->
      <p
        data-testid="signup-error"
        hidden
        role="alert"
        aria-live="assertive"
        class="text-sm text-red-600 bg-red-50 px-3 py-2 rounded-lg border border-red-200"
      ></p>

      <button
        type="submit"
        data-testid="signup-submit-button"
        class="w-full bg-viindoo-primary hover:bg-viindoo-primary-bright
               text-viindoo-bg-0 font-medium py-2.5 rounded-lg transition-colors text-sm"
      >
        Create Account
      </button>
    </form>

    <OAuthButtons verb="Sign up" />
  </div>

  <!-- Login link -->
  <p class="text-center text-sm text-gray-500 mt-4">
    Already have an account?
    <a href="/login" class="text-viindoo-primary-text hover:underline font-medium">Sign in</a>
  </p>
</AuthLayout>

<script define:vars={{ hcaptchaSiteKey }}>
  // Expose site key to the module script via a data attribute on the form.
  const _form = document.querySelector('[data-testid="signup-form"]');
  if (_form && hcaptchaSiteKey) _form.dataset.hcaptchaSiteKey = hcaptchaSiteKey;
</script>

<script>
  import { submitJson } from '../lib/apiClient';

  const form = document.querySelector('[data-testid="signup-form"]') as HTMLFormElement | null;
  const successDiv = document.querySelector('[data-testid="signup-success"]') as HTMLElement | null;
  const errorEl = document.querySelector('[data-testid="signup-error"]') as HTMLElement | null;
  const submitBtn = document.querySelector('[data-testid="signup-submit-button"]') as HTMLButtonElement | null;
  const consentCb = document.querySelector('[data-testid="signup-consent-checkbox"]') as HTMLInputElement | null;

  // Disable submit until consent is checked (D4 client-side guard).
  function _syncSubmitDisabled() {
    if (submitBtn) {
      submitBtn.disabled = !consentCb?.checked;
    }
  }
  _syncSubmitDisabled(); // initial state
  consentCb?.addEventListener('change', _syncSubmitDisabled);

  function showError(msg: string) {
    if (errorEl) {
      errorEl.textContent = msg;
      errorEl.removeAttribute('hidden');
    }
  }

  function clearError() {
    if (errorEl) errorEl.setAttribute('hidden', '');
  }

  function setLoading(loading: boolean) {
    if (submitBtn) {
      submitBtn.disabled = loading;
      submitBtn.textContent = loading ? 'Creating account…' : 'Create Account';
    }
  }

  function getHcaptchaToken(): string {
    // Site key was stashed by the define:vars script above.
    const siteKey = form?.dataset.hcaptchaSiteKey ?? '';
    if (!siteKey) return '';
    if (typeof (window as unknown as Record<string, unknown>).hcaptcha === 'undefined') return '';
    return (window as unknown as { hcaptcha: { getResponse: () => string; reset: () => void } }).hcaptcha.getResponse() || '';
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearError();
    setLoading(true);

    const fd = new FormData(form!);
    const password = fd.get('password') as string;
    const confirm = fd.get('confirm_password') as string;

    if (password !== confirm) {
      showError('Passwords do not match.');
      setLoading(false);
      return;
    }

    const payload = {
      email: fd.get('email'),
      username: fd.get('username'),
      password,
      confirm_password: confirm,
      hcaptcha_token: getHcaptchaToken(),
      consent: consentCb?.checked === true,
    };

    try {
      const r = await submitJson('/api/auth/register', {
        method: 'POST',
        body: payload,
        stepUp: false,
      });

      if (r.ok) {
        // Show success state, hide form
        form!.setAttribute('hidden', '');
        successDiv?.removeAttribute('hidden');
        const msgEl = document.querySelector('[data-testid="signup-success-msg"]');
        if (msgEl) {
          msgEl.textContent =
            `We sent a verification link to ${payload.email}. Click it to activate your account.`;
        }
      } else {
        showError(r.error ?? 'Signup failed. Please try again.');
        // Reset hcaptcha on failure
        const siteKey = form?.dataset.hcaptchaSiteKey ?? '';
        if (siteKey && typeof (window as unknown as Record<string, unknown>).hcaptcha !== 'undefined') {
          (window as unknown as { hcaptcha: { reset: () => void } }).hcaptcha.reset();
        }
        setLoading(false);
      }
    } catch {
      showError('Network error. Please check your connection and try again.');
      setLoading(false);
    }
  });
</script>

---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Admin Users page — SSR (M9 W-UM)
// Middleware enforces requireAdmin before rendering this page.
import AdminLayout from '../../layouts/AdminLayout.astro';
import UserTable from '../../components/UserTable.astro';
import CreateUserIsland from './_create-user-island';
import { FASTAPI_BASE } from '../../lib/fastapi';

const cookieHeader = Astro.request.headers.get('cookie') ?? '';

type User = {
  id: number;
  username: string;
  email: string | null;
  is_admin: boolean;
  is_active: boolean;
  mfa_enabled: boolean;
  api_key_count: number;
  created_at: string | null;
};

type Plan = {
  id: number;
  slug: string;
  display_name: string;
  quota_calls_per_month: number | null;
  rate_limit_rpm: number | null;
  seat_limit: number | null;
  is_public: boolean;
};

let usersData: { users: User[]; error?: string | null } = { users: [] };
let plansData: Plan[] = [];

try {
  const [usersRes, plansRes] = await Promise.all([
    fetch(`${FASTAPI_BASE}/api/admin/users`, {
      headers: { cookie: cookieHeader },
    }),
    fetch(`${FASTAPI_BASE}/api/admin/plans`, {
      headers: { cookie: cookieHeader },
    }),
  ]);

  if (usersRes.status === 403) {
    return Astro.redirect('/admin?error=admin_required');
  }
  if (usersRes.ok) {
    usersData = await usersRes.json();
  } else {
    usersData.error = 'Could not load users.';
  }

  if (plansRes.ok) {
    const pd = await plansRes.json();
    plansData = pd.plans ?? [];
  }
} catch {
  usersData.error = 'Could not connect to API server.';
}
---

<AdminLayout title="Users — Admin">
  <!-- Flash banner -->
  <div data-testid="flash-banner" hidden class="fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border"></div>

  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Users</h1>
      <p class="text-sm text-gray-500 mt-1">Manage web UI user accounts</p>
    </div>
    <div class="flex items-center gap-3">
      <span class="text-xs bg-violet-100 text-violet-800 px-3 py-1 rounded-full font-medium">
        {usersData.users.length} user{usersData.users.length !== 1 ? 's' : ''}
      </span>
      <!-- W3 B: Create User island trigger -->
      <button
        id="btn-open-create-user"
        class="text-xs px-3 py-1.5 rounded-lg bg-viindoo-primary text-viindoo-bg-0 font-medium hover:opacity-90"
      >
        + Create User
      </button>
    </div>
  </div>

  <!-- W3 B: Create User island (modal) -->
  <CreateUserIsland client:load />

  {usersData.error && (
    <div data-testid="users-error" class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm">
      {usersData.error}
    </div>
  )}

  <UserTable users={usersData.users} plans={plansData} />
</AdminLayout>

<script>
  import { submitJson } from '../../lib/apiClient';
  import { flash } from '../../lib/flash';

  // Deactivate / Reactivate
  document.querySelectorAll('[data-action]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLElement;
      const action = el.dataset.action as string;
      const userId = el.dataset.userId as string;
      const username = el.dataset.username ?? userId;

      const confirmMsg =
        action === 'deactivate'
          ? `Deactivate user "${username}"? They will be logged out immediately.`
          : `Reactivate user "${username}"?`;
      if (!confirm(confirmMsg)) return;

      const r = await submitJson(`/api/admin/users/${userId}/${action}`, { method: 'POST', body: {} });
      if (r.ok) {
        flash(`User "${username}" ${action === 'deactivate' ? 'deactivated' : 'reactivated'}.`);
        setTimeout(() => location.reload(), 800);
      } else {
        flash(r.error!, { error: true });
      }
    });
  });

  // Promote / Demote admin toggle
  document.querySelectorAll('[data-action-admin]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLElement;
      const action = el.dataset.actionAdmin as string; // 'promote' | 'demote'
      const userId = el.dataset.userId as string;
      const username = el.dataset.username ?? userId;
      const newIsAdmin = action === 'promote';

      const confirmMsg = newIsAdmin
        ? `Promote "${username}" to Admin? They will gain full admin access.`
        : `Demote "${username}" to regular User? They will lose admin access.`;
      if (!confirm(confirmMsg)) return;

      const r = await submitJson(`/api/admin/users/${userId}/admin`, {
        method: 'PATCH',
        body: { is_admin: newIsAdmin },
      });
      if (r.ok) {
        flash(`User "${username}" ${newIsAdmin ? 'promoted to Admin' : 'demoted to User'}.`);
        setTimeout(() => location.reload(), 800);
      } else if (r.status === 422) {
        flash('Cannot demote last admin.', { error: true });
      } else {
        flash(r.error!, { error: true });
      }
    });
  });

  // Reset password link
  document.querySelectorAll('[data-action-reset]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLElement;
      const userId = el.dataset.userId as string;
      const username = el.dataset.username ?? userId;

      if (!confirm(`Send password reset link to "${username}"?`)) return;

      const r = await submitJson(`/api/admin/users/${userId}/reset-password-link`, { method: 'POST', body: {} });
      if (r.ok) {
        const d = r.data as { email_sent?: boolean };
        const msg = d.email_sent
          ? `Reset email sent to "${username}".`
          : `Reset link generated for "${username}" (check server logs — SMTP not configured).`;
        flash(msg);
      } else {
        flash(r.error!, { error: true });
      }
    });
  });

  // Cascade plan to all keys for a user
  document.querySelectorAll('.cascade-plan-save').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLElement;
      const userId = el.dataset.userId as string;
      const username = el.dataset.username ?? userId;
      const row = el.closest('tr');
      const select = row?.querySelector('.cascade-plan-select') as HTMLSelectElement | null;
      if (!select) return;

      const planId = select.value;
      const planLabel = select.options[select.selectedIndex]?.text ?? planId;

      if (!planId) {
        alert('Please select a plan first.');
        return;
      }

      if (!confirm(`Apply plan "${planLabel}" to ALL API keys (active + inactive) of user "${username}"?\n\nThis will overwrite the current plan on every key.`)) return;

      const r = await submitJson(`/api/admin/users/${userId}/plan`, {
        method: 'PATCH',
        body: { plan_id: parseInt(planId, 10) },
      });
      if (r.ok) {
        const d = r.data as { keys_updated?: number };
        const n = d.keys_updated ?? 0;
        flash(`Plan "${planLabel}" applied to ${n} key${n !== 1 ? 's' : ''} of user "${username}".`);
        setTimeout(() => location.reload(), 800);
      } else {
        flash(r.error!, { error: true });
      }
    });
  });
</script>

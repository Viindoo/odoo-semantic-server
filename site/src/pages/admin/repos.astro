---
// Repos & Profiles management page — SSR fetch from FastAPI W1
import AdminLayout from '../../layouts/AdminLayout.astro';
import RepoTable from '../../components/RepoTable.astro';
import JobStatus from '../../components/JobStatus.astro';
import ProfileTree from '../../components/ProfileTree.astro';
import { FASTAPI_BASE } from '../../lib/fastapi';

const cookieHeader = Astro.request.headers.get('cookie') ?? '';

const [profilesRes, reposRes, sshKeysRes] = await Promise.allSettled([
  fetch(`${FASTAPI_BASE}/api/repos/profiles`, { headers: { cookie: cookieHeader } }),
  fetch(`${FASTAPI_BASE}/api/repos/repos`, { headers: { cookie: cookieHeader } }),
  fetch(`${FASTAPI_BASE}/api/repos/ssh-keys-list`, { headers: { cookie: cookieHeader } }),
]);

let profilesData: { profiles: unknown[]; all_job_id?: number | null; all_job_status?: string | null; error?: string | null } = { profiles: [] };
let repos: unknown[] = [];
let sshKeys: { id: number; name: string }[] = [];

if (profilesRes.status === 'fulfilled' && profilesRes.value.ok) {
  profilesData = await profilesRes.value.json();
}
if (reposRes.status === 'fulfilled' && reposRes.value.ok) {
  const d = await reposRes.value.json();
  repos = d.repos ?? d ?? [];
}
if (sshKeysRes.status === 'fulfilled' && sshKeysRes.value.ok) {
  sshKeys = await sshKeysRes.value.json();
}

// Flatten repos from profiles if direct endpoint returns empty
if (repos.length === 0 && profilesData.profiles.length > 0) {
  for (const p of profilesData.profiles as { repos?: unknown[] }[]) {
    if (p.repos) repos = [...repos, ...p.repos];
  }
}
---

<AdminLayout title="Repositories — Admin">
  <!-- Flash banner -->
  <div data-testid="flash-banner" hidden class="fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border"></div>

  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Repositories</h1>
      <p class="text-sm text-gray-500 mt-1">Manage profiles and their repositories</p>
    </div>
  </div>

  <!-- Add Profile Form -->
  <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6 shadow-sm">
    <h2 class="text-base font-semibold text-gray-800 mb-4">Add Profile</h2>
    <form data-testid="add-profile-form" class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Name</label>
        <input
          name="name"
          type="text"
          placeholder="viindoo17"
          data-testid="profile-name-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
          required
        />
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Odoo Version</label>
        <input
          name="version"
          type="text"
          placeholder="17.0"
          data-testid="profile-version-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
          required
        />
      </div>
      <div class="flex items-end">
        <button
          type="submit"
          data-testid="add-profile-button"
          class="w-full bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0 text-sm font-medium px-4 py-2 rounded-lg transition-colors"
        >
          Add Profile
        </button>
      </div>
    </form>
  </div>

  <!-- Profiles list -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-6">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-base font-semibold text-gray-800">
        Profiles ({profilesData.profiles.length})
      </h2>
      {profilesData.profiles.length > 0 && (
        <button
          id="profile-view-toggle"
          data-testid="profile-view-toggle"
          class="text-xs border border-gray-300 rounded-lg px-3 py-1.5 text-gray-600 hover:bg-gray-50 transition-colors"
          aria-label="Switch profile view mode"
        >
          Switch to tree view
        </button>
      )}
    </div>

    {profilesData.profiles.length === 0 ? (
      <div data-testid="profiles-empty-state" class="py-12 text-center text-gray-500">
        <p class="text-3xl mb-2">🗂️</p>
        <p class="font-medium">No profiles configured.</p>
        <p class="text-sm mt-1">Add a profile above to get started.</p>
      </div>
    ) : (
      <>
        <!-- Flat list view (default) -->
        <div id="profile-flat-list" class="divide-y divide-gray-100">
          {(profilesData.profiles as { id: number; name: string; odoo_version: string; description?: string; repos?: unknown[]; parent_profile_id?: number | null }[]).map((p) => (
            <div data-testid="profile-row" data-testid-id={`profile-row-${p.id}`} class="px-5 py-4 hover:bg-gray-50">
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-medium text-gray-800">{p.name}</p>
                  <p class="text-xs text-gray-500 mt-0.5">Odoo {p.odoo_version}{p.description ? ` — ${p.description}` : ''}</p>
                </div>
                <div class="flex items-center gap-3 flex-wrap">
                  <span class="text-sm text-gray-500">{p.repos?.length ?? 0} repos</span>

                  <!-- Parent profile dropdown -->
                  <select
                    data-testid="profile-parent-select"
                    data-profile-id={String(p.id)}
                    class="text-xs border border-gray-300 rounded-lg px-2 py-1.5 text-gray-600 focus:outline-none focus:ring-2 focus:ring-viindoo-primary profile-parent-select"
                    title="Set parent profile"
                  >
                    <option value="">— no parent —</option>
                    {(profilesData.profiles as { id: number; name: string; odoo_version: string; parent_profile_id?: number | null }[])
                      .filter((other) => other.id !== p.id && other.odoo_version === p.odoo_version)
                      .map((other) => (
                        <option value={String(other.id)} selected={p.parent_profile_id === other.id}>{other.name}</option>
                      ))
                    }
                  </select>

                  <!-- Clone all pending button -->
                  <button
                    data-testid="clone-all-button"
                    data-profile-id={String(p.id)}
                    class="text-xs bg-blue-50 hover:bg-blue-100 text-blue-700 px-3 py-1.5 rounded-lg transition-colors clone-all-btn"
                  >
                    Clone all pending
                  </button>

                  <button
                    data-testid={`delete-profile-button-${p.id}`}
                    data-profile-id={String(p.id)}
                    class="text-xs bg-red-50 hover:bg-red-100 text-red-700 px-3 py-1.5 rounded-lg transition-colors delete-profile-btn"
                  >
                    Delete
                  </button>
                </div>
              </div>

              <!-- JobStatus widget for clone-all (hidden until a job is triggered) -->
              <div
                data-testid={`clone-all-status-${p.id}`}
                data-profile-id={String(p.id)}
                class="mt-2"
                hidden
              >
                <JobStatus jobId={null} autoPoll={false} testid={`clone-all-job-${p.id}`} />
              </div>
            </div>
          ))}
        </div>

        <!-- Tree view (hidden by default; toggled by JS) -->
        <div id="profile-tree-view" hidden>
          <ProfileTree profiles={profilesData.profiles as Parameters<typeof ProfileTree>[0]['profiles']} />
        </div>
      </>
    )}
  </div>

  <!-- Repo table component -->
  <RepoTable
    repos={repos as Parameters<typeof RepoTable>[0]['repos']}
    profiles={profilesData.profiles as Parameters<typeof RepoTable>[0]['profiles']}
    sshKeys={sshKeys}
  />
</AdminLayout>

<script>
  function showFlash(msg: string, type: 'success' | 'error' = 'success') {
    const banner = document.querySelector('[data-testid="flash-banner"]') as HTMLElement | null;
    if (!banner) return;
    banner.textContent = msg;
    banner.className = `fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border ${
      type === 'error' ? 'bg-red-100 text-red-800 border-red-300' : 'bg-green-100 text-green-800 border-green-300'
    }`;
    banner.removeAttribute('hidden');
    setTimeout(() => banner.setAttribute('hidden', ''), 4000);
  }

  // Add profile
  document.querySelector('[data-testid="add-profile-form"]')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const fd = new FormData(form);
    const res = await fetch('/api/repos/profiles', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: fd.get('name'), version: fd.get('version') }),
    });
    if (res.ok) {
      showFlash('Profile created.', 'success');
      setTimeout(() => location.reload(), 800);
    } else {
      const data = await res.json().catch(() => ({}));
      showFlash(data.error ?? 'Failed to create profile.', 'error');
    }
  });

  // Parent profile dropdown — PATCH /api/repos/profiles/{id}/parent
  document.querySelectorAll('.profile-parent-select').forEach((sel) => {
    sel.addEventListener('change', async () => {
      const select = sel as HTMLSelectElement;
      const profileId = (select as HTMLElement).dataset.profileId;
      const parentId = select.value ? Number(select.value) : null;
      const res = await fetch(`/api/repos/profiles/${profileId}/parent`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ parent_id: parentId }),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        showFlash('Parent updated.', 'success');
      } else if (res.status === 404) {
        showFlash(data.error ?? 'Profile not found.', 'error');
      } else if (res.status === 422) {
        showFlash(data.detail ?? data.error ?? 'Validation error.', 'error');
      } else if (res.status === 400) {
        showFlash(data.error ?? 'Invalid parent selection.', 'error');
      } else {
        showFlash(data.error ?? 'Failed to update parent.', 'error');
      }
    });
  });

  // Clone all pending — POST /api/repos/profiles/{id}/clone-all
  document.querySelectorAll('.clone-all-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const profileId = (btn as HTMLElement).dataset.profileId;
      (btn as HTMLButtonElement).disabled = true;

      const res = await fetch(`/api/repos/profiles/${profileId}/clone-all`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await res.json().catch(() => ({}));

      if (res.ok) {
        const total: number = data.total ?? 0;
        if (total === 0) {
          showFlash('No pending repos to clone.', 'success');
          (btn as HTMLButtonElement).disabled = false;
          return;
        }
        showFlash(`Clone-all started: ${total} repo(s) processing.`, 'success');

        // Show the JobStatus widget for this profile
        const statusDiv = document.querySelector(
          `[data-testid="clone-all-status-${profileId}"]`
        ) as HTMLElement | null;
        if (statusDiv) {
          statusDiv.removeAttribute('hidden');
          // Update the inner JobStatus badge text with summary
          const badge = statusDiv.querySelector('[data-testid^="clone-all-job-"]') as HTMLElement | null;
          if (badge) {
            badge.textContent = `Spawned: ${data.spawned ?? 0}, Short-circuited: ${data.short_circuited ?? 0}`;
            badge.removeAttribute('hidden');
          }
        }
      } else if (res.status === 404) {
        showFlash('Profile not found.', 'error');
      } else {
        showFlash(data.error ?? 'Clone-all failed.', 'error');
      }
      (btn as HTMLButtonElement).disabled = false;
    });
  });

  // Delete profile
  document.querySelectorAll('.delete-profile-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const profileId = (btn as HTMLElement).dataset.profileId;
      if (!confirm('Delete this profile and ALL its repos? This cannot be undone.')) return;
      // Content-Type: application/json is required to bypass Astro's default
      // `security.checkOrigin` CSRF guard, which rejects POST/DELETE with
      // form-like content types (none, urlencoded, multipart, text/plain) as
      // "Cross-site form submission". JSON requests are exempt from that check.
      const res = await fetch(`/api/repos/profiles/${profileId}`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        showFlash('Profile deleted.', 'success');
        setTimeout(() => location.reload(), 800);
      } else {
        showFlash(data.error ?? 'Delete failed.', 'error');
      }
    });
  });

  // ── Profile view toggle (flat list ↔ tree view) ────────────────────────────
  // localStorage key: 'osm-profile-view' — values: 'flat' | 'tree'
  const STORAGE_KEY = 'osm-profile-view';

  const toggleBtn = document.getElementById('profile-view-toggle') as HTMLButtonElement | null;
  const flatList = document.getElementById('profile-flat-list') as HTMLElement | null;
  const treeView = document.getElementById('profile-tree-view') as HTMLElement | null;

  function applyViewMode(mode: 'flat' | 'tree') {
    if (!flatList || !treeView || !toggleBtn) return;
    if (mode === 'tree') {
      flatList.setAttribute('hidden', '');
      treeView.removeAttribute('hidden');
      toggleBtn.textContent = 'Switch to flat list';
    } else {
      treeView.setAttribute('hidden', '');
      flatList.removeAttribute('hidden');
      toggleBtn.textContent = 'Switch to tree view';
    }
  }

  // Restore saved preference on page load
  const savedMode = localStorage.getItem(STORAGE_KEY) as 'flat' | 'tree' | null;
  if (savedMode === 'tree') {
    applyViewMode('tree');
  }

  // Toggle on click
  toggleBtn?.addEventListener('click', () => {
    const isTree = !treeView?.hasAttribute('hidden');
    const nextMode: 'flat' | 'tree' = isTree ? 'flat' : 'tree';
    localStorage.setItem(STORAGE_KEY, nextMode);
    applyViewMode(nextMode);
  });
</script>

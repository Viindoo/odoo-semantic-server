---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Admin Settings — Plans page: 4 plan tier table with edit modal (WI-10, ADR-0039)
import AdminLayout from '../../../layouts/AdminLayout.astro';
import PlanTierEditorIsland from './_plan-tier-editor-island';
import { FASTAPI_BASE } from '../../../lib/fastapi';

const cookieHeader = Astro.request.headers.get('cookie') ?? '';

type Plan = {
  id: number;
  slug: string;
  display_name: string;
  quota_calls_per_month: number;
  rate_limit_rpm: number;
  seat_limit: number | null;
  is_public: boolean;
  metadata: Record<string, unknown> | null;
  created_at: string | null;
};

let plans: Plan[] = [];
let fetchError: string | null = null;

try {
  const res = await fetch(`${FASTAPI_BASE}/api/admin/plans`, {
    headers: { cookie: cookieHeader },
  });
  if (res.ok) {
    const data = await res.json();
    plans = data.plans ?? [];
  } else if (res.status === 403) {
    return Astro.redirect('/admin?error=admin_required');
  } else {
    fetchError = `API error ${res.status}`;
  }
} catch {
  fetchError = 'Could not connect to API server.';
}
---

<AdminLayout title="Plans — Admin Settings">
  <!-- Flash banner -->
  <div data-testid="flash-banner" hidden class="fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border"></div>

  <!-- Breadcrumb -->
  <nav class="mb-4 text-xs text-gray-500 flex items-center gap-1">
    <a href="/admin/settings" class="hover:text-viindoo-primary transition-colors">Settings</a>
    <span class="text-gray-300">/</span>
    <span class="text-gray-700 font-medium">Plans</span>
  </nav>

  <!-- Page header -->
  <div class="flex items-start justify-between mb-6">
    <div class="flex items-start gap-3">
      <span class="text-2xl">📊</span>
      <div>
        <h1 class="text-2xl font-bold text-gray-900 font-display">Plan Tiers</h1>
        <p class="text-sm text-gray-500 mt-1">
          Configure quota, rate limits, and seat limits for each billing plan tier.
          Changes propagate within ≤60 seconds.
        </p>
      </div>
    </div>
    <span class="text-xs bg-violet-100 text-violet-700 px-3 py-1 rounded-full font-medium shrink-0">
      {plans.length} tier{plans.length !== 1 ? 's' : ''}
    </span>
  </div>

  {fetchError && (
    <div class="mb-5 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm">
      {fetchError}
    </div>
  )}

  <!-- Info callout -->
  <div class="mb-5 bg-blue-50 border border-blue-200 text-blue-800 px-4 py-3 rounded-xl text-sm">
    <strong>Note:</strong> Plan updates are logged in the audit trail and require MFA re-confirmation (5-min fresh window).
    A &gt;50% reduction in quota or RPM will trigger a confirmation dialog before submission.
    Plan tier <em>creation</em> is deferred to Phase 2.
  </div>

  <PlanTierEditorIsland client:load initialPlans={plans} />

  <!-- Back link -->
  <div class="mt-6">
    <a href="/admin/settings" class="text-sm text-viindoo-primary hover:underline">
      ← Back to Settings
    </a>
  </div>
</AdminLayout>

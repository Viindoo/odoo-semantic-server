---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Operations page — index-core, seed-patterns, apply-preset, jobs, migrations
import AdminLayout from '../../layouts/AdminLayout.astro';
import { FASTAPI_BASE } from '../../lib/fastapi';

const cookieHeader = Astro.request.headers.get('cookie') ?? '';

let presets: string[] = [];
try {
  const res = await fetch(`${FASTAPI_BASE}/api/operations/presets`, {
    headers: { cookie: cookieHeader },
  });
  if (res.ok) {
    const d = await res.json();
    presets = Object.keys(d.presets ?? {});
  }
} catch {
  // non-blocking — presets dropdown just stays empty
}

// M9 W-UO: fetch applied migrations for SSR display
const migrationsRes = await fetch(`${FASTAPI_BASE}/api/admin/migrations`, {
  headers: { cookie: cookieHeader },
}).catch(() => null);
const migrationsData: { migrations: { id: string; applied_at: string | null }[]; count: number } =
  migrationsRes?.ok ? await migrationsRes.json() : { migrations: [], count: 0 };
---

<AdminLayout title="Operations — Admin">
  <!-- Flash banner -->
  <div data-testid="flash-banner" hidden class="fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border"></div>

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Operations</h1>
    <p class="text-sm text-gray-500 mt-1">Long-running indexer commands — results tracked as jobs</p>
  </div>

  <!-- Active job status (shown after spawn).
       Tailwind `flex` overrides `[hidden] { display: none }` because utility
       classes win on specificity, so we use the `hidden` utility class instead
       of the HTML attribute — and the JS toggle below now adds/removes the
       class rather than the attribute. -->
  <div data-testid="active-job-container" class="hidden mb-6 bg-viindoo-info/5 border border-viindoo-info/20 rounded-xl px-5 py-4 items-center gap-4">
    <div>
      <p class="text-sm font-semibold text-viindoo-info">Job started</p>
      <p data-testid="active-job-id" class="text-xs text-viindoo-info mt-0.5"></p>
    </div>
  </div>

  <!-- Index Core -->
  <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6 shadow-sm">
    <div class="flex items-start gap-3 mb-4">
      <span class="text-2xl">📚</span>
      <div>
        <h2 class="text-base font-semibold text-gray-800">Index Core API</h2>
        <p class="text-xs text-gray-500 mt-0.5">Index Odoo core symbols (models, fields, methods) into the graph DB</p>
      </div>
    </div>
    <form data-testid="index-core-form" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Source path</label>
        <input
          name="source"
          type="text"
          placeholder="/home/.../odoo17"
          data-testid="ops-index-core-source-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
          required
        />
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Version</label>
        <input
          name="version"
          type="text"
          placeholder="17.0"
          data-testid="ops-index-core-version-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
          required
        />
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Static data dir (optional)</label>
        <input
          name="static_data_dir"
          type="text"
          placeholder="/path/to/static-data"
          data-testid="ops-index-core-static-dir-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
        />
      </div>
      <div class="sm:col-span-2 lg:col-span-3 flex justify-start">
        <button
          type="submit"
          data-testid="index-core-button"
          class="bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0 text-sm font-medium px-5 py-2 rounded-lg transition-colors"
        >
          Start Index Core
        </button>
      </div>
    </form>
  </div>

  <!-- Seed Patterns -->
  <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6 shadow-sm">
    <div class="flex items-start gap-3 mb-4">
      <span class="text-2xl">🌱</span>
      <div>
        <h2 class="text-base font-semibold text-gray-800">Seed Patterns</h2>
        <p class="text-xs text-gray-500 mt-0.5">Load curated pattern catalogue into the graph + vector store</p>
      </div>
    </div>
    <form data-testid="seed-patterns-form" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Version (optional)</label>
        <input
          name="version"
          type="text"
          placeholder="17.0 (leave blank for all)"
          data-testid="ops-seed-patterns-version-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
        />
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Patterns file (optional)</label>
        <input
          name="patterns_file"
          type="text"
          placeholder="/path/to/patterns.json"
          data-testid="ops-seed-patterns-file-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
        />
      </div>
      <div class="flex items-end gap-3">
        <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
          <input name="no_embed" type="checkbox" value="1" data-testid="ops-seed-no-embed-input" class="rounded" />
          No embed
        </label>
        <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
          <input name="force" type="checkbox" value="1" data-testid="ops-seed-force-input" class="rounded" />
          Force
        </label>
      </div>
      <div class="sm:col-span-2 lg:col-span-3 flex justify-start">
        <button
          type="submit"
          data-testid="seed-patterns-button"
          class="bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors"
        >
          Seed Patterns
        </button>
      </div>
    </form>
  </div>

  <!-- Apply Preset -->
  <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6 shadow-sm">
    <div class="flex items-start gap-3 mb-4">
      <span class="text-2xl">⚡</span>
      <div>
        <h2 class="text-base font-semibold text-gray-800">Apply Preset</h2>
        <p class="text-xs text-gray-500 mt-0.5">Register a predefined set of repos + profiles in one click</p>
      </div>
    </div>
    <form data-testid="apply-preset-form" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Preset</label>
        <select
          name="name"
          data-testid="ops-preset-name-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
          required
        >
          <option value="">— select preset —</option>
          {presets.map((p) => <option value={p}>{p}</option>)}
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Repo base dir (optional)</label>
        <input
          name="repo_base_dir"
          type="text"
          placeholder="/home/.../git"
          data-testid="ops-preset-repo-base-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
        />
      </div>
      <div class="sm:col-span-2 flex items-center gap-3">
        <label class="flex items-center gap-2 text-sm text-gray-600 cursor-pointer">
          <input name="dry_run" type="checkbox" value="1" data-testid="ops-preset-dry-run-input" class="rounded" />
          Dry run (preview only)
        </label>
        <button
          type="submit"
          data-testid="apply-preset-button"
          class="bg-amber-500 hover:bg-amber-600 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors"
        >
          Apply Preset
        </button>
      </div>
    </form>

    <!-- Preset result (shown after apply) -->
    <div data-testid="preset-result" hidden class="mt-4 bg-gray-50 rounded-lg border border-gray-200 px-4 py-3">
      <pre data-testid="preset-result-content" class="text-xs font-mono text-gray-700 whitespace-pre-wrap overflow-x-auto max-h-64"></pre>
    </div>
  </div>

  <!-- DB Migrations (read-only display) — M9 W-UO -->
  <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6 shadow-sm">
    <div class="flex items-start gap-3 mb-4">
      <span class="text-2xl">📋</span>
      <div>
        <h2 class="text-base font-semibold text-gray-800">Database Migrations</h2>
        <p class="text-xs text-gray-500 mt-0.5">Applied yoyo migrations (read-only — trigger via deploy script per ADR-0001)</p>
      </div>
    </div>
    <div data-testid="migrations-list" class="overflow-x-auto">
      {migrationsData.migrations.length === 0 ? (
        <p class="text-xs text-gray-400">No migrations recorded yet.</p>
      ) : (
        <table class="w-full text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-left px-3 py-2 text-xs text-gray-600">Migration ID</th>
              <th class="text-left px-3 py-2 text-xs text-gray-600">Applied At (UTC)</th>
            </tr>
          </thead>
          <tbody>
            {migrationsData.migrations.map((m) => (
              <tr class="border-t border-gray-100">
                <td class="px-3 py-2 font-mono text-xs">{m.id}</td>
                <td class="px-3 py-2 text-xs text-gray-500">{m.applied_at ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
      <p class="text-xs text-gray-400 mt-2">{migrationsData.count} migration(s) applied</p>
    </div>
  </div>

  <!-- Backup (M9 W-BK) -->
  <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6 shadow-sm">
    <div class="flex items-start gap-3 mb-4">
      <span class="text-2xl">💾</span>
      <div>
        <h2 class="text-base font-semibold text-gray-800">Create Backup</h2>
        <p class="text-xs text-gray-500 mt-0.5">Bundle PG dump + Neo4j dump + encrypted FERNET key into a tar.gz archive</p>
      </div>
    </div>
    <form data-testid="backup-form" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Output path (optional)</label>
        <input
          name="output"
          type="text"
          placeholder="Leave blank for auto-timestamped path"
          data-testid="ops-backup-output-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
        />
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Bundle passphrase env var (optional)</label>
        <input
          name="bundle_passphrase_env"
          type="text"
          placeholder="e.g. BUNDLE_PASSPHRASE"
          data-testid="ops-backup-passphrase-env-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
        />
      </div>
      <div class="sm:col-span-2 flex justify-start">
        <button
          type="submit"
          data-testid="backup-button"
          class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors"
        >
          Create Backup
        </button>
      </div>
    </form>

    <!-- Backup log stream (shown after job starts) -->
    <div data-testid="backup-log-container" hidden class="mt-4">
      <div class="flex items-center justify-between mb-2">
        <p class="text-xs font-semibold text-gray-700">Backup log</p>
        <span data-testid="backup-status-badge" class="text-xs px-2 py-0.5 bg-yellow-100 text-yellow-700 rounded-full">pending</span>
      </div>
      <pre
        data-testid="backup-log"
        class="bg-gray-900 text-green-400 rounded-lg p-3 text-xs font-mono overflow-x-auto max-h-64 overflow-y-auto whitespace-pre-wrap"
      ></pre>
      <p data-testid="backup-download-link" hidden class="mt-2 text-sm text-viindoo-primary font-medium"></p>
    </div>
  </div>

  <!-- Restore Upload (M9 W-RS) -->
  <div class="bg-white rounded-xl border border-red-200 p-5 mb-6 shadow-sm">
    <div class="flex items-start gap-3 mb-4">
      <span class="text-2xl">&#9888;</span>
      <div>
        <h2 class="text-base font-semibold text-red-700">Restore from Backup Bundle</h2>
        <p class="text-xs text-gray-500 mt-0.5">
          Upload a <code>.tar.gz</code> backup bundle. Service enters maintenance mode during restore.
          Requires admin session with MFA verified within last 5 minutes.
          A pre-restore safety backup is created automatically.
        </p>
      </div>
    </div>
    <form data-testid="restore-form" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">
          Backup bundle (.tar.gz, max 500MB)
        </label>
        <input
          name="file"
          type="file"
          accept=".tar.gz,.tgz"
          data-testid="restore-file-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-400"
          required
        />
        <p class="text-xs text-gray-400 mt-1">Max 500MB. Bundle must contain manifest.json + postgres.sql.</p>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">
          Fernet passphrase env var (optional)
        </label>
        <input
          name="passphrase_env"
          type="text"
          placeholder="RESTORE_PASSPHRASE"
          data-testid="restore-passphrase-env-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-400"
        />
        <p class="text-xs text-gray-400 mt-1">Leave blank if bundle has no fernet.enc.</p>
      </div>
      <div class="sm:col-span-2 flex justify-start">
        <button
          type="submit"
          data-testid="restore-button"
          class="bg-red-600 hover:bg-red-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors"
        >
          Upload &amp; Restore
        </button>
      </div>
    </form>
    <!-- Restore result -->
    <div data-testid="restore-result" hidden class="mt-4 bg-gray-50 rounded-lg border border-gray-200 px-4 py-3">
      <p class="text-xs font-semibold text-gray-600 mb-1">Restore result</p>
      <pre data-testid="restore-result-content" class="text-xs font-mono text-gray-700 whitespace-pre-wrap overflow-x-auto max-h-64"></pre>
    </div>
  </div>

  <!-- FERNET Key Rotation (placeholder — MFA + audit required) — M9 W-UO -->
  <div class="bg-white rounded-xl border border-amber-200 p-5 mb-6 shadow-sm">
    <div class="flex items-start gap-3 mb-4">
      <span class="text-2xl">🔑</span>
      <div>
        <h2 class="text-base font-semibold text-amber-700">FERNET Key Rotation</h2>
        <p class="text-xs text-gray-500 mt-0.5">
          High-risk operation. Requires fresh MFA verification (within 5 min)
          and is currently CLI-only. UI trigger deferred to M10.
        </p>
      </div>
    </div>
    <div data-testid="fernet-rotation-cli-hint" class="bg-amber-50 border border-amber-200 rounded-lg px-3 py-2">
      <p class="text-xs text-amber-800 font-mono">
        $ python -m src.cli rotate-fernet --old-key-env OLD_FERNET_KEY --new-key-env NEW_FERNET_KEY
      </p>
      <p class="text-xs text-gray-500 mt-1">
        See <code>docs/adr/0020-fernet-key-delivery.md</code> for full rotation procedure.
      </p>
    </div>
  </div>

  <!-- Recent jobs placeholder - populated via JS -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100">
      <h2 class="text-base font-semibold text-gray-800">Recent Jobs</h2>
    </div>
    <div data-testid="operations-empty-state" class="py-12 text-center text-gray-500">
      <p class="text-3xl mb-2">⚙️</p>
      <p class="font-medium">Start an operation above to see job status here.</p>
    </div>
    <div data-testid="recent-jobs-list" hidden class="divide-y divide-gray-100"></div>
  </div>
</AdminLayout>

<script>
  function showFlash(msg: string, type: 'success' | 'error' = 'success') {
    const banner = document.querySelector('[data-testid="flash-banner"]') as HTMLElement | null;
    if (!banner) return;
    banner.textContent = msg;
    banner.className = `fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border ${
      type === 'error' ? 'bg-red-100 text-red-800 border-red-300' : 'bg-green-100 text-green-800 border-green-300'
    }`;
    banner.removeAttribute('hidden');
    setTimeout(() => banner.setAttribute('hidden', ''), 5000);
  }

  function showJobStarted(jobId: number | null, label: string) {
    const container = document.querySelector('[data-testid="active-job-container"]') as HTMLElement | null;
    const idEl = document.querySelector('[data-testid="active-job-id"]') as HTMLElement | null;
    if (container && idEl) {
      idEl.textContent = jobId !== null ? `Job #${jobId} — ${label}` : label;
      // Swap Tailwind's `hidden` (display:none) for `flex` (display:flex) so
      // the previously-hidden container becomes visible with its intended
      // layout. Reversing the action_-job_container fix above also requires
      // this JS update (removeAttribute on the legacy `hidden` attribute is a
      // no-op now that we use the class instead).
      container.classList.remove('hidden');
      container.classList.add('flex');
    }
    // Add to recent jobs list
    const list = document.querySelector('[data-testid="recent-jobs-list"]') as HTMLElement | null;
    const emptyState = document.querySelector('[data-testid="operations-empty-state"]') as HTMLElement | null;
    if (list && jobId !== null) {
      emptyState?.setAttribute('hidden', '');
      list.removeAttribute('hidden');
      const item = document.createElement('div');
      item.className = 'px-5 py-3 flex items-center justify-between';
      item.innerHTML = `
        <span class="text-sm text-gray-700">Job #${jobId} — ${label}</span>
        <span class="text-xs px-2 py-0.5 bg-viindoo-info/10 text-viindoo-info rounded-full" data-job-badge="${jobId}">running</span>
      `;
      list.prepend(item);
      pollJob(jobId, item.querySelector(`[data-job-badge="${jobId}"]`) as HTMLElement);
    }
  }

  function pollJob(jobId: number, badgeEl: HTMLElement | null) {
    function poll() {
      fetch(`/api/jobs/${jobId}/status`)
        .then((r) => r.json())
        .then((data) => {
          if (badgeEl) {
            badgeEl.textContent = data.status ?? 'unknown';
            const colorMap: Record<string, string> = {
              running: 'bg-viindoo-info/10 text-viindoo-info',
              done: 'bg-green-100 text-green-700',
              error: 'bg-red-100 text-red-700',
              pending: 'bg-yellow-100 text-yellow-700',
            };
            badgeEl.className = `text-xs px-2 py-0.5 rounded-full ${colorMap[data.status] ?? 'bg-gray-100 text-gray-600'}`;
          }
          if (data.status === 'running' || data.status === 'pending') {
            setTimeout(poll, 3000);
          }
        })
        .catch(() => setTimeout(poll, 5000));
    }
    setTimeout(poll, 3000);
  }

  // Index Core
  document.querySelector('[data-testid="index-core-form"]')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const fd = new FormData(form);
    const res = await fetch('/api/operations/index-core', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        source: fd.get('source'),
        version: fd.get('version'),
        static_data_dir: fd.get('static_data_dir') ?? '',
      }),
    });
    const data = await res.json().catch(() => ({}));
    if (res.ok) {
      showFlash(data.message ?? 'Index core started.', 'success');
      showJobStarted(data.job_id, `core:${fd.get('version')}`);
    } else {
      showFlash(data.error ?? 'Index core failed.', 'error');
    }
  });

  // Seed Patterns
  document.querySelector('[data-testid="seed-patterns-form"]')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const fd = new FormData(form);
    const body: Record<string, string> = {
      version: String(fd.get('version') ?? ''),
      patterns_file: String(fd.get('patterns_file') ?? ''),
      no_embed: fd.get('no_embed') ? '1' : '',
      force: fd.get('force') ? '1' : '',
    };
    const res = await fetch('/api/operations/seed-patterns', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json().catch(() => ({}));
    if (res.ok) {
      showFlash(data.message ?? 'Seed patterns started.', 'success');
      showJobStarted(data.job_id, 'patterns');
    } else {
      showFlash(data.error ?? 'Seed patterns failed.', 'error');
    }
  });

  // Backup (M9 W-BK)
  document.querySelector('[data-testid="backup-form"]')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const fd = new FormData(form);
    const body: Record<string, string> = {
      output: String(fd.get('output') ?? ''),
      bundle_passphrase_env: String(fd.get('bundle_passphrase_env') ?? ''),
    };
    const res = await fetch('/api/operations/backup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json().catch(() => ({}));
    if (!res.ok) {
      showFlash(data.error ?? 'Backup failed.', 'error');
      return;
    }

    showFlash(data.message ?? 'Backup started.', 'success');
    const jobId: string = data.job_id;
    const outputPath: string = data.output ?? '';

    const logContainer = document.querySelector('[data-testid="backup-log-container"]') as HTMLElement | null;
    const logEl = document.querySelector('[data-testid="backup-log"]') as HTMLElement | null;
    const badgeEl = document.querySelector('[data-testid="backup-status-badge"]') as HTMLElement | null;
    const downloadEl = document.querySelector('[data-testid="backup-download-link"]') as HTMLElement | null;
    if (logContainer) logContainer.removeAttribute('hidden');
    if (badgeEl) { badgeEl.textContent = 'running'; badgeEl.className = 'text-xs px-2 py-0.5 bg-viindoo-info/10 text-viindoo-info rounded-full'; }

    const es = new EventSource(`/api/operations/backup/${jobId}/stream`);
    es.onmessage = (evt) => {
      let parsed: Record<string, unknown>;
      try { parsed = JSON.parse(evt.data); } catch { return; }
      if (parsed.line && logEl) {
        logEl.textContent += parsed.line + '\n';
        logEl.scrollTop = logEl.scrollHeight;
      }
      if (parsed.done) {
        es.close();
        const ok = parsed.exit_code === 0;
        if (badgeEl) {
          badgeEl.textContent = ok ? 'done' : 'error';
          badgeEl.className = `text-xs px-2 py-0.5 rounded-full ${ok ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`;
        }
        if (ok && downloadEl && outputPath) {
          downloadEl.textContent = `Backup saved: ${outputPath}`;
          downloadEl.removeAttribute('hidden');
        }
        showFlash(ok ? `Backup complete: ${outputPath}` : 'Backup failed — check log.', ok ? 'success' : 'error');
      }
      if (parsed.error) {
        es.close();
        showFlash(String(parsed.error), 'error');
      }
    };
    es.onerror = () => {
      es.close();
      if (badgeEl) { badgeEl.textContent = 'error'; badgeEl.className = 'text-xs px-2 py-0.5 bg-red-100 text-red-700 rounded-full'; }
    };
  });

  // Restore Upload (M9 W-RS)
  document.querySelector('[data-testid="restore-form"]')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const fileInput = form.querySelector('[data-testid="restore-file-input"]') as HTMLInputElement;
    const fileObj = fileInput?.files?.[0];
    if (!fileObj) {
      showFlash('Please select a file.', 'error');
      return;
    }
    const MAX_BYTES = 500 * 1024 * 1024;
    if (fileObj.size > MAX_BYTES) {
      showFlash('File exceeds 500MB limit.', 'error');
      return;
    }
    const uploadFd = new FormData();
    uploadFd.append('file', fileObj);
    showFlash('Uploading backup bundle...', 'success');
    const btn = form.querySelector('[data-testid="restore-button"]') as HTMLButtonElement;
    if (btn) btn.disabled = true;
    try {
      const res = await fetch('/api/operations/restore', {
        method: 'POST',
        body: uploadFd,
      });
      const data = await res.json().catch(() => ({}));
      const resultEl = document.querySelector('[data-testid="restore-result"]') as HTMLElement | null;
      const resultContent = document.querySelector('[data-testid="restore-result-content"]') as HTMLElement | null;
      if (res.ok) {
        if (resultEl && resultContent) {
          resultContent.textContent = JSON.stringify(data, null, 2);
          resultEl.removeAttribute('hidden');
        }
        showFlash(
          `Restore started (job ${data.job_id}). Safety backup: ${data.safety_backup ?? 'n/a'}`,
          'success'
        );
      } else {
        if (resultEl && resultContent) {
          resultContent.textContent = data.detail ?? data.error ?? 'Unknown error';
          resultEl.removeAttribute('hidden');
        }
        showFlash(data.detail ?? data.error ?? 'Restore upload failed.', 'error');
      }
    } catch (err) {
      showFlash('Restore upload failed: ' + String(err), 'error');
    } finally {
      if (btn) btn.disabled = false;
    }
  });

  // Apply Preset
  document.querySelector('[data-testid="apply-preset-form"]')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const fd = new FormData(form);
    const body: Record<string, unknown> = {
      name: fd.get('name'),
      repo_base_dir: fd.get('repo_base_dir') ?? '',
      dry_run: fd.get('dry_run') ? '1' : '',
      repo_map_urls: [],
      repo_map_paths: [],
    };
    const res = await fetch('/api/operations/apply-preset', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json().catch(() => ({}));
    const resultEl = document.querySelector('[data-testid="preset-result"]') as HTMLElement | null;
    const resultContent = document.querySelector('[data-testid="preset-result-content"]') as HTMLElement | null;
    if (res.ok) {
      if (data.dry_run && resultEl && resultContent) {
        resultContent.textContent = data.preview ?? '(no output)';
        resultEl.removeAttribute('hidden');
      }
      showFlash(data.message ?? `Preset '${fd.get('name')}' applied.`, 'success');
    } else {
      if (resultEl && resultContent) {
        resultContent.textContent = data.error ?? 'Unknown error';
        resultEl.removeAttribute('hidden');
      }
      showFlash(data.error ?? 'Apply preset failed.', 'error');
    }
  });
</script>

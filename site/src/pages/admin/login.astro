// /admin/login — 301 permanent redirect → /login.
// Preserves ?return= / ?error= / ?info= / ?next= so bookmarks and error
// redirects from OAuth callbacks continue to work after the URL rename.
// 301 = permanent; search engines transfer link equity to /login.
const u = new URL(Astro.request.url);
// Forward every query parameter (return, error, info, next, etc.) verbatim.
const qs = u.searchParams.toString();
const dest = qs ? `/login?${qs}` : '/login';
return Astro.redirect(dest, 301);
---

---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Login page — no auth required (middleware skips /admin/login)
import BaseLayout from '../../layouts/BaseLayout.astro';
import { FASTAPI_BASE } from '../../lib/fastapi';

// Redirect already-authed users to dashboard
const cookieHeader = Astro.request.headers.get('cookie') ?? '';
let alreadyAuthed = false;
try {
  const verify = await fetch(`${FASTAPI_BASE}/api/auth/verify`, {
    headers: { cookie: cookieHeader },
  });
  alreadyAuthed = verify.ok;
} catch {
  // server down — allow login page
}

if (alreadyAuthed) {
  return Astro.redirect('/admin');
}
---

<BaseLayout title="Login — Odoo Semantic MCP">
  <div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
    <!-- Flash banner (shown via JS) -->
    <div data-testid="flash-banner" hidden class="fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium"></div>

    <div class="w-full max-w-sm">
      <!-- Logo -->
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-14 h-14 bg-viindoo-primary rounded-2xl mb-3">
          <img src="/favicon.svg" alt="Logo" class="w-8 h-8" />
        </div>
        <h1 class="text-xl font-bold text-gray-900">Odoo Semantic MCP</h1>
        <p class="text-sm text-gray-500 mt-1">Admin Login</p>
      </div>

      <!-- Login form -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <!-- Step 1: password login -->
        <div data-testid="login-section">
        <form data-testid="login-form" class="space-y-4">
          <div>
            <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Username</label>
            <input
              id="username"
              name="username"
              type="text"
              autocomplete="username"
              required
              data-testid="login-username-input"
              class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary focus:border-viindoo-primary"
              placeholder="admin"
            />
          </div>
          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <input
              id="password"
              name="password"
              type="password"
              autocomplete="current-password"
              required
              data-testid="login-password-input"
              class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary focus:border-viindoo-primary"
              placeholder="••••••••"
            />
          </div>

          <!-- Error message -->
          <p data-testid="login-error" hidden class="text-sm text-red-600 bg-red-50 px-3 py-2 rounded-lg border border-red-200"></p>

          <button
            type="submit"
            data-testid="login-submit-button"
            class="w-full bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0 font-medium py-2.5 rounded-lg transition-colors text-sm"
          >
            Sign In
          </button>
        </form>

        <!-- OAuth divider -->
        <div class="mt-5 flex items-center gap-3">
          <hr class="flex-1 border-gray-200" />
          <span class="text-xs text-gray-400 font-medium">or continue with</span>
          <hr class="flex-1 border-gray-200" />
        </div>

        <!-- OAuth buttons -->
        <div class="mt-4 flex flex-col gap-2">
          <a
            href="/admin/auth/google"
            data-testid="login-google-button"
            class="flex items-center justify-center gap-2 w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors"
          >
            <!-- Google icon -->
            <svg class="w-4 h-4" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Sign in with Google
          </a>
          <a
            href="/admin/auth/github"
            data-testid="login-github-button"
            class="flex items-center justify-center gap-2 w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors"
          >
            <!-- GitHub icon -->
            <svg class="w-4 h-4 fill-gray-700" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            Sign in with GitHub
          </a>
        </div>
        </div><!-- /login-section -->

        <!-- Step 2: MFA verification (hidden until mfa_required) -->
        <div data-testid="mfa-section" hidden>
          <p class="text-sm text-gray-600 mb-4">
            Enter the 6-digit code from your authenticator app.
          </p>
          <form data-testid="mfa-form" class="space-y-4">
            <div data-testid="mfa-totp-row">
              <label class="block text-sm font-medium text-gray-700 mb-1">Authenticator Code</label>
              <input
                name="totp_code"
                type="text"
                inputmode="numeric"
                pattern="[0-9]{6}"
                maxlength="6"
                data-testid="mfa-code-input"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary focus:border-viindoo-primary font-mono text-center text-lg tracking-widest"
                placeholder="000000"
                autocomplete="one-time-code"
              />
            </div>

            <div data-testid="mfa-backup-row" hidden>
              <label class="block text-sm font-medium text-gray-700 mb-1">Backup Code</label>
              <input
                name="backup_code"
                type="text"
                data-testid="mfa-backup-input"
                class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary focus:border-viindoo-primary font-mono"
                placeholder="xxxxxxxxxxxxxxxx"
              />
            </div>

            <p data-testid="mfa-error" hidden class="text-sm text-red-600 bg-red-50 px-3 py-2 rounded-lg border border-red-200"></p>

            <button
              type="submit"
              data-testid="mfa-submit-button"
              class="w-full bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0 font-medium py-2.5 rounded-lg transition-colors text-sm"
            >
              Verify
            </button>

            <p class="text-center">
              <a data-testid="use-backup-link" href="#" class="text-xs text-gray-500 hover:text-gray-700 underline">
                Use backup code instead
              </a>
            </p>
          </form>
        </div><!-- /mfa-section -->
      </div>

      <!-- Signup link -->
      <p class="text-center text-sm text-gray-500 mt-4">
        Don't have an account?
        <a href="/signup" class="text-viindoo-primary hover:underline font-medium">Sign up</a>
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelector('[data-testid="login-form"]')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const fd = new FormData(form);
    const errorEl = document.querySelector('[data-testid="login-error"]') as HTMLElement | null;
    const submitBtn = document.querySelector('[data-testid="login-submit-button"]') as HTMLButtonElement | null;
    const loginSection = document.querySelector('[data-testid="login-section"]') as HTMLElement | null;
    const mfaSection = document.querySelector('[data-testid="mfa-section"]') as HTMLElement | null;

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Signing in…';
    }
    if (errorEl) errorEl.setAttribute('hidden', '');

    const res = await fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        username: fd.get('username'),
        password: fd.get('password'),
      }),
    });

    const data = await res.json().catch(() => ({}));

    if (res.ok) {
      if (data.mfa_required) {
        // Show MFA step
        _currentMfaToken = data.mfa_token ?? '';
        loginSection?.setAttribute('hidden', '');
        mfaSection?.removeAttribute('hidden');
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Sign In'; }
      } else {
        window.location.href = '/admin';
      }
    } else {
      if (errorEl) {
        const msg =
          data.error === 'invalid_credentials'
            ? 'Invalid username or password.'
            : data.error === 'Too many failed login attempts; wait 60s'
              ? 'Too many failed attempts. Wait 60s and try again.'
              : data.error ?? 'Login failed.';
        errorEl.textContent = msg;
        errorEl.removeAttribute('hidden');
      }
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Sign In';
      }
    }
  });

  // MFA form submission
  let _currentMfaToken = '';

  document.querySelector('[data-testid="mfa-form"]')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const fd = new FormData(form);
    const mfaErrorEl = document.querySelector('[data-testid="mfa-error"]') as HTMLElement | null;
    const mfaBtn = document.querySelector('[data-testid="mfa-submit-button"]') as HTMLButtonElement | null;

    if (mfaBtn) { mfaBtn.disabled = true; mfaBtn.textContent = 'Verifying…'; }
    if (mfaErrorEl) mfaErrorEl.setAttribute('hidden', '');

    const body: Record<string, string> = { mfa_token: _currentMfaToken };
    const backupCode = (fd.get('backup_code') as string)?.trim();
    const totpCode = (fd.get('totp_code') as string)?.trim();

    if (backupCode) {
      body['backup_code'] = backupCode;
    } else {
      body['code'] = totpCode;
    }

    const res = await fetch('/api/auth/totp/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json().catch(() => ({}));

    if (res.ok) {
      window.location.href = '/admin';
    } else {
      if (mfaErrorEl) {
        const msg =
          data.error === 'invalid_code' ? 'Invalid code. Try again.' :
          data.error === 'invalid_backup_code' ? 'Invalid backup code. Try again.' :
          data.error === 'mfa_token_expired' ? 'Session expired. Please log in again.' :
          data.error ?? 'Verification failed.';
        mfaErrorEl.textContent = msg;
        mfaErrorEl.removeAttribute('hidden');
      }
      if (mfaBtn) { mfaBtn.disabled = false; mfaBtn.textContent = 'Verify'; }
    }
  });

  // Toggle between TOTP code and backup code input
  document.querySelector('[data-testid="use-backup-link"]')?.addEventListener('click', (e) => {
    e.preventDefault();
    const totpRow = document.querySelector('[data-testid="mfa-totp-row"]') as HTMLElement | null;
    const backupRow = document.querySelector('[data-testid="mfa-backup-row"]') as HTMLElement | null;
    if (totpRow?.hasAttribute('hidden')) {
      totpRow?.removeAttribute('hidden');
      backupRow?.setAttribute('hidden', '');
    } else {
      totpRow?.setAttribute('hidden', '');
      backupRow?.removeAttribute('hidden');
    }
  });
</script>

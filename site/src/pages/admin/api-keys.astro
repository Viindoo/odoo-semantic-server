---
// SPDX-License-Identifier: AGPL-3.0-or-later
// API Keys management page — SSR fetch from FastAPI W1
// W-5 (M10B P0-ext): plan column + overrides modal + reactivate button.
import AdminLayout from '../../layouts/AdminLayout.astro';
import { FASTAPI_BASE } from '../../lib/fastapi';
import ApiKeysOverridesIsland from './_api-keys-overrides-island';

const cookieHeader = Astro.request.headers.get('cookie') ?? '';

type Key = {
  id: number;
  name: string;
  active: boolean;
  created_at: string;
  last_used_at?: string | null;
  owner_username: string | null;
  user_id: number | null;
  // Plan + per-key overrides (exposed by list_api_keys so the UI can prefill).
  // null = unset (use plan default); a number (incl. 0) = an explicit override.
  plan_id: number | null;
  rate_limit_override: number | null;
  quota_override: number | null;
};

type Plan = {
  id: number;
  slug: string;
  display_name: string;
  quota_calls_per_month: number;
  rate_limit_rpm: number;
  seat_limit: number | null;
  is_public: boolean;
};

let keysData: {
  keys: Key[];
  error?: string | null;
} = { keys: [] };

// Fetch active users for the assign-owner dropdown.
// Per ADR-0026 §Decision 2: all active (non-deactivated) webui_users are
// valid owners — not just admins. System (NULL-owner) keys can be claimed
// by any active user, including non-admins.
type AssignableUser = { id: number; username: string; is_admin: boolean; is_active: boolean };
let assignableUsers: AssignableUser[] = [];
let plans: Plan[] = [];

try {
  const res = await fetch(`${FASTAPI_BASE}/api/api-keys`, {
    headers: { cookie: cookieHeader },
  });
  if (res.ok) keysData = await res.json();
} catch {
  keysData.error = 'Could not connect to API server.';
}

try {
  const res = await fetch(`${FASTAPI_BASE}/api/admin/users`, {
    headers: { cookie: cookieHeader },
  });
  if (res.ok) {
    const data = await res.json();
    assignableUsers = (data.users ?? []).filter((u: AssignableUser) => u.is_active !== false);
  }
} catch {
  // silently ignore — dropdown will be empty
}

// Fetch plan catalogue for plan assignment dropdown (W-5, ADR-0039).
// Admin-only; silently skip if the endpoint is unavailable.
try {
  const res = await fetch(`${FASTAPI_BASE}/api/admin/plans`, {
    headers: { cookie: cookieHeader },
  });
  if (res.ok) {
    const data = await res.json();
    plans = data.plans ?? [];
  }
} catch {
  // silently ignore — plan column will be hidden
}

const activeKeys = keysData.keys.filter((k) => k.active);
const inactiveKeys = keysData.keys.filter((k) => !k.active);
const nullOwnerCount = activeKeys.filter((k) => k.user_id === null).length;
---

<AdminLayout title="API Keys — Admin">
  <!-- Flash banner -->
  <div data-testid="flash-banner" hidden class="fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border"></div>

  <!-- New key reveal panel (hidden by default). Persists until manual page
       reload — the raw key is not stored server-side and cannot be re-shown. -->
  <div data-testid="new-key-banner" hidden class="mb-4 bg-green-50 border border-green-300 rounded-xl px-5 py-4">
    <p class="text-sm font-semibold text-green-800 mb-1">New API key created — copy it now. It will not be shown again.</p>
    <div class="flex items-stretch gap-2">
      <code data-testid="new-key-value" class="flex-1 text-sm font-mono bg-white border border-green-200 rounded-lg px-3 py-2 select-all text-green-900 break-all"></code>
      <button
        type="button"
        data-testid="copy-key-button"
        aria-label="Copy API key to clipboard"
        class="shrink-0 inline-flex items-center gap-1.5 bg-white hover:bg-green-100 border border-green-300 text-green-800 text-sm font-medium px-3 py-2 rounded-lg transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <span data-testid="copy-key-button-label">Copy</span>
      </button>
    </div>
  </div>

  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">API Keys</h1>
      <p class="text-sm text-gray-500 mt-1">Manage MCP server access keys</p>
    </div>
    <button
      data-testid="generate-key-button"
      class="bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0 text-sm font-medium px-4 py-2 rounded-lg transition-colors"
    >
      + Generate Key
    </button>
  </div>

  <!-- Generate key form (hidden, toggle via button) -->
  <div data-testid="generate-key-form-container" hidden class="bg-white rounded-xl border border-gray-200 p-5 mb-6 shadow-sm">
    <h2 class="text-base font-semibold text-gray-800 mb-4">Generate New API Key</h2>
    <form data-testid="generate-key-form" class="flex gap-3 items-end">
      <div class="flex-1">
        <label class="block text-xs font-medium text-gray-600 mb-1">Key Name</label>
        <input
          name="name"
          type="text"
          placeholder="my-tool-key"
          data-testid="api-key-name-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-viindoo-primary-deep"
          required
        />
      </div>
      <button
        type="submit"
        data-testid="create-key-button"
        class="bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0 text-sm font-medium px-4 py-2 rounded-lg transition-colors"
      >
        Create
      </button>
    </form>
  </div>

  {keysData.error && (
    <div data-testid="api-keys-error" class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm">
      ⚠️ {keysData.error}
    </div>
  )}

  <!-- Unowned-key warning banner -->
  {nullOwnerCount > 0 && (
    <div class="rounded-lg bg-amber-50 border border-amber-200 p-4 mb-4 text-sm">
      <strong>{nullOwnerCount} key(s) have no owner</strong> — assign each below to track ownership.
      {assignableUsers.length === 0 && (
        <span class="block mt-1 text-amber-700">Could not load user list — refresh or check admin permissions.</span>
      )}
    </div>
  )}

  <!-- Active keys -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-6">
    <div class="px-5 py-4 border-b border-gray-100">
      <h2 class="text-base font-semibold text-gray-800">Active Keys ({activeKeys.length})</h2>
    </div>

    {activeKeys.length === 0 ? (
      <div data-testid="api-keys-empty-state" class="py-12 text-center text-gray-500">
        <p class="text-3xl mb-2">🔑</p>
        <p class="font-medium">No active API keys.</p>
        <p class="text-sm mt-1">Click "Generate Key" to create one.</p>
      </div>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
            <tr>
              <th class="px-4 py-3 text-left">Name</th>
              <th class="px-4 py-3 text-left">Owner</th>
              {plans.length > 0 && <th class="px-4 py-3 text-left">Plan</th>}
              {plans.length > 0 && <th class="px-4 py-3 text-left">Overrides</th>}
              <th class="px-4 py-3 text-left">Created</th>
              <th class="px-4 py-3 text-left">Last Used</th>
              <th class="px-4 py-3 text-right">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {activeKeys.map((key) => (
              <tr data-testid="api-key-row" data-testid-id={`api-key-row-${key.id}`} class="hover:bg-gray-50">
                <td class="px-4 py-3 font-medium text-gray-800">{key.name}</td>
                <td class="px-4 py-3 text-gray-500 text-xs">
                  {key.owner_username !== null && key.owner_username !== undefined
                    ? key.owner_username
                    : <em class="text-slate-400">(system)</em>
                  }
                </td>
                {plans.length > 0 && (
                  <td class="px-4 py-3 text-xs">
                    {/* Plan inline select: admin picks plan → Save → PATCH plan_id (no override change). */}
                    <div class="flex items-center gap-1 plan-assign-row" data-key-id={String(key.id)}>
                      <select
                        class="text-xs border border-gray-300 rounded px-2 py-1 plan-select"
                        aria-label={`Plan for key ${key.name}`}
                        data-key-id={String(key.id)}
                      >
                        <option value="" selected={key.plan_id === null || key.plan_id === undefined}>— select plan —</option>
                        {plans.map((p) => (
                          <option value={String(p.id)} selected={String(p.id) === String(key.plan_id)}>{p.display_name} ({p.slug})</option>
                        ))}
                      </select>
                      <button
                        class="text-xs bg-blue-50 hover:bg-blue-100 text-blue-700 px-2 py-1.5 rounded-lg transition-colors save-plan-btn"
                        data-key-id={String(key.id)}
                      >
                        Save
                      </button>
                    </div>
                  </td>
                )}
                {plans.length > 0 && (
                  <td class="px-4 py-3 text-xs">
                    {/* Overrides button: opens singleton modal; passes selected plan from dropdown. */}
                    <button
                      class="text-xs bg-violet-50 hover:bg-violet-100 text-violet-700 px-2 py-1.5 rounded-lg transition-colors overrides-btn"
                      data-overrides-trigger
                      data-key-id={String(key.id)}
                      data-key-name={key.name}
                      data-current-plan-id={key.plan_id == null ? '' : String(key.plan_id)}
                      data-rate={key.rate_limit_override == null ? '' : String(key.rate_limit_override)}
                      data-quota={key.quota_override == null ? '' : String(key.quota_override)}
                      title="Set per-key rate/quota overrides"
                    >
                      Overrides…
                    </button>
                  </td>
                )}
                <td class="px-4 py-3 text-gray-500 text-xs">{key.created_at?.slice(0, 16).replace('T', ' ') ?? '—'}</td>
                <td class="px-4 py-3 text-gray-500 text-xs">{key.last_used_at?.slice(0, 16).replace('T', ' ') ?? 'Never'}</td>
                <td class="px-4 py-3 text-right">
                  <div class="flex items-center justify-end gap-2 flex-wrap">
                    {key.user_id === null && assignableUsers.length > 0 && (
                      <div class="flex items-center gap-1 assign-owner-row" data-key-id={String(key.id)}>
                        <select
                          class="text-xs border border-gray-300 rounded px-2 py-1 assign-owner-select"
                          aria-label={`Assign owner for key ${key.name}`}
                        >
                          <option value="">— assign owner —</option>
                          {assignableUsers.map((u) => (
                            <option value={String(u.id)}>{u.username}</option>
                          ))}
                        </select>
                        <button
                          class="text-xs bg-blue-50 hover:bg-blue-100 text-blue-700 px-2 py-1.5 rounded-lg transition-colors assign-owner-btn"
                          data-key-id={String(key.id)}
                        >
                          Save
                        </button>
                      </div>
                    )}
                    <button
                      data-testid={`deactivate-key-button-${key.id}`}
                      data-key-id={String(key.id)}
                      class="text-xs bg-red-50 hover:bg-red-100 text-red-700 px-3 py-1.5 rounded-lg transition-colors deactivate-key-btn"
                    >
                      Deactivate
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <!-- Singleton React island for per-key overrides modal (W-5).
       Mounted once; opens when any [data-overrides-trigger] button is clicked.
       The island reads data-current-plan-id / data-rate / data-quota from the trigger. -->
  {plans.length > 0 && <ApiKeysOverridesIsland client:load />}

  <!-- Inactive keys. Why: `open` by default so admins see deactivated keys
       without an extra click, and so Playwright's `to_be_visible()` resolves
       on `api-key-row-inactive` (a closed <details> CSS-hides its children
       and Playwright treats them as not visible). -->
  {inactiveKeys.length > 0 && (
    <details open class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <summary class="px-5 py-4 cursor-pointer text-sm font-medium text-gray-500 hover:text-gray-800 list-none flex items-center gap-2">
        <span>▶ Deactivated Keys ({inactiveKeys.length})</span>
      </summary>
      <div class="border-t border-gray-100">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
            <tr>
              <th class="px-4 py-3 text-left">Name</th>
              <th class="px-4 py-3 text-left">Owner</th>
              <th class="px-4 py-3 text-left">Created</th>
              <th class="px-4 py-3 text-right">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {inactiveKeys.map((key) => (
              <tr data-testid="api-key-row-inactive" class="hover:bg-gray-50 opacity-60">
                <td class="px-4 py-3 text-gray-500 line-through">{key.name}</td>
                <td class="px-4 py-3 text-gray-400 text-xs">
                  {key.owner_username !== null && key.owner_username !== undefined
                    ? key.owner_username
                    : <em class="text-slate-400">(system)</em>
                  }
                </td>
                <td class="px-4 py-3 text-gray-400 text-xs">{key.created_at?.slice(0, 16).replace('T', ' ') ?? '—'}</td>
                <td class="px-4 py-3 text-right">
                  <button
                    data-testid={`reactivate-key-button-${key.id}`}
                    data-key-id={String(key.id)}
                    class="text-xs bg-green-50 hover:bg-green-100 text-green-700 px-3 py-1.5 rounded-lg transition-colors reactivate-key-btn"
                  >
                    Reactivate
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </details>
  )}
</AdminLayout>

<script>
  function showFlash(msg: string, type: 'success' | 'error' = 'success') {
    const banner = document.querySelector('[data-testid="flash-banner"]') as HTMLElement | null;
    if (!banner) return;
    banner.textContent = msg;
    banner.className = `fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border ${
      type === 'error' ? 'bg-red-100 text-red-800 border-red-300' : 'bg-green-100 text-green-800 border-green-300'
    }`;
    banner.removeAttribute('hidden');
    setTimeout(() => banner.setAttribute('hidden', ''), 4000);
  }

  // C-1 post-reload: if a raw key was stashed before a reload (key just created),
  // pop it and reveal the copy-once banner. The Active Keys table is now fresh.
  (function revealStashedKey() {
    let raw: string | null = null;
    try {
      raw = sessionStorage.getItem('osm-new-api-key');
      if (raw) sessionStorage.removeItem('osm-new-api-key');
    } catch {
      raw = null;
    }
    if (!raw) return;
    const banner = document.querySelector('[data-testid="new-key-banner"]') as HTMLElement | null;
    const keyVal = document.querySelector('[data-testid="new-key-value"]') as HTMLElement | null;
    if (banner && keyVal) {
      keyVal.textContent = raw;
      banner.removeAttribute('hidden');
      banner.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  })();

  // Toggle generate form
  document.querySelector('[data-testid="generate-key-button"]')?.addEventListener('click', () => {
    const container = document.querySelector('[data-testid="generate-key-form-container"]') as HTMLElement | null;
    if (!container) return;
    if (container.hasAttribute('hidden')) container.removeAttribute('hidden');
    else container.setAttribute('hidden', '');
  });

  // Generate key form submit
  document.querySelector('[data-testid="generate-key-form"]')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const fd = new FormData(form);
    const res = await fetch('/api/api-keys', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: fd.get('name') }),
    });
    const data = await res.json().catch(() => ({}));
    if (res.ok && data.raw_key) {
      // C-1: previously the Active Keys table stayed stale until a manual F5
      // (no reload, to avoid losing the raw key to a timeout). Fix: stash the
      // raw key in sessionStorage and reload so the server re-renders the table
      // fresh — the new row appears immediately with correct plan/override
      // prefill (single source of truth = SSR markup, no client-side row
      // duplication). The banner is re-shown post-reload from the stash.
      try {
        sessionStorage.setItem('osm-new-api-key', data.raw_key);
        // Safety net: if the reload below never navigates (e.g. a JS error),
        // purge the raw secret rather than leaving it readable for the whole
        // tab session. The normal path discards this timer when the reload
        // navigates away, and the next page pops the key on load.
        setTimeout(() => { try { sessionStorage.removeItem('osm-new-api-key'); } catch { /* ignore */ } }, 15000);
      } catch {
        // sessionStorage unavailable (private mode / disabled) — fall back to
        // showing the banner now without reload so the key is never lost.
      }
      form.reset();
      if (sessionStorage.getItem('osm-new-api-key') === data.raw_key) {
        location.reload();
      } else {
        const banner = document.querySelector('[data-testid="new-key-banner"]') as HTMLElement | null;
        const keyVal = document.querySelector('[data-testid="new-key-value"]') as HTMLElement | null;
        if (banner && keyVal) {
          keyVal.textContent = data.raw_key;
          banner.removeAttribute('hidden');
          banner.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    } else {
      showFlash(data.error ?? 'Failed to create key.', 'error');
    }
  });

  // Copy-to-clipboard for the freshly revealed key.
  // Primary: navigator.clipboard.writeText (modern browsers on https/loopback).
  // Fallback: hidden <textarea> + document.execCommand('copy') — required for
  // older browsers and some non-secure contexts (e.g. http loopback in Firefox).
  async function copyTextCrossBrowser(text: string): Promise<boolean> {
    try {
      if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
        await navigator.clipboard.writeText(text);
        return true;
      }
    } catch {
      // fall through to execCommand fallback
    }
    try {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.setAttribute('readonly', '');
      ta.style.position = 'fixed';
      ta.style.top = '0';
      ta.style.left = '0';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.focus();
      ta.select();
      ta.setSelectionRange(0, text.length);
      const ok = document.execCommand('copy');
      document.body.removeChild(ta);
      return ok;
    } catch {
      return false;
    }
  }

  document.querySelector('[data-testid="copy-key-button"]')?.addEventListener('click', async () => {
    const keyVal = document.querySelector('[data-testid="new-key-value"]') as HTMLElement | null;
    const label = document.querySelector('[data-testid="copy-key-button-label"]') as HTMLElement | null;
    const text = (keyVal?.textContent ?? '').trim();
    if (!text) return;
    const ok = await copyTextCrossBrowser(text);
    if (ok) {
      if (label) {
        const prev = label.textContent ?? 'Copy';
        label.textContent = 'Copied!';
        setTimeout(() => { label.textContent = prev; }, 1500);
      }
    } else {
      showFlash('Copy failed — select the key manually and press Ctrl+C.', 'error');
    }
  });

  // Deactivate key buttons
  document.querySelectorAll('.deactivate-key-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const keyId = (btn as HTMLElement).dataset.keyId;
      if (!confirm('Deactivate this API key? All tools using it will lose access.')) return;
      // Content-Type: application/json is required to bypass Astro's default
      // `security.checkOrigin` CSRF guard, which rejects POST/DELETE with
      // form-like content types (none, urlencoded, multipart, text/plain) as
      // "Cross-site form submission". JSON requests are exempt from that check.
      const res = await fetch(`/api/api-keys/${keyId}/deactivate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      if (res.ok) {
        showFlash('API key deactivated.', 'success');
        setTimeout(() => location.reload(), 800);
      } else {
        const data = await res.json().catch(() => ({}));
        showFlash(data.error ?? 'Deactivation failed.', 'error');
      }
    });
  });

  // Save Plan buttons — PATCH /api/admin/api-keys/{key_id}/plan
  // Mirrors the assign-owner pattern. Sends plan_id only (no overrides in this path).
  document.querySelectorAll('.save-plan-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const keyId = (btn as HTMLElement).dataset.keyId;
      const row = (btn as HTMLElement).closest('.plan-assign-row') as HTMLElement | null;
      const select = row?.querySelector('.plan-select') as HTMLSelectElement | null;
      const planId = select?.value;
      if (!planId) {
        showFlash('Please select a plan first.', 'error');
        return;
      }
      const res = await fetch(`/api/admin/api-keys/${keyId}/plan`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ plan_id: parseInt(planId, 10) }),
      });
      if (res.ok) {
        showFlash('Plan updated.', 'success');
        setTimeout(() => location.reload(), 800);
      } else {
        const data = await res.json().catch(() => ({}));
        showFlash(data.detail ?? data.error ?? 'Failed to update plan.', 'error');
      }
    });
  });

  // Overrides buttons — sync the currently selected plan_id into the trigger's
  // data-current-plan-id attribute so the React island can PATCH with the right plan.
  document.querySelectorAll('.overrides-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      // Sync the dropdown's current selection into data-current-plan-id so the
      // island PATCHes with whichever plan the admin currently has chosen
      // (the dropdown is SSR-selected to the saved plan, but the admin may have
      // changed it before opening the modal).
      const row = el.closest('tr');
      const planSelect = row?.querySelector('.plan-select') as HTMLSelectElement | null;
      // Sync unconditionally — including '' when the admin de-selects back to the
      // placeholder — so a stale planId is never left on the element from an
      // earlier selection (which would PATCH overrides against the wrong plan).
      if (planSelect) {
        el.dataset.currentPlanId = planSelect.value;
      }
      // data-rate / data-quota are SSR-prefilled from list_api_keys (null -> '',
      // explicit override incl. 0 -> the number). The island treats '' as
      // "use plan default" and '0' as a real zero override (ADR-0041).
    });
  });

  // Reactivate key buttons — mirrors deactivate pattern.
  document.querySelectorAll('.reactivate-key-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const keyId = (btn as HTMLElement).dataset.keyId;
      if (!confirm('Reactivate this API key? It will immediately be able to authenticate again.')) return;
      const res = await fetch(`/api/api-keys/${keyId}/reactivate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      if (res.ok) {
        showFlash('API key reactivated.', 'success');
        setTimeout(() => location.reload(), 800);
      } else {
        const data = await res.json().catch(() => ({}));
        showFlash(data.error ?? 'Reactivation failed.', 'error');
      }
    });
  });

  // Assign owner buttons
  document.querySelectorAll('.assign-owner-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const keyId = (btn as HTMLElement).dataset.keyId;
      const row = (btn as HTMLElement).closest('.assign-owner-row') as HTMLElement | null;
      const select = row?.querySelector('.assign-owner-select') as HTMLSelectElement | null;
      const userId = select?.value;
      if (!userId) {
        showFlash('Please select a user to assign.', 'error');
        return;
      }
      const res = await fetch(`/api/admin/api-keys/${keyId}/owner`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: parseInt(userId, 10) }),
      });
      if (res.ok) {
        showFlash('Owner assigned.', 'success');
        setTimeout(() => location.reload(), 800);
      } else {
        const data = await res.json().catch(() => ({}));
        showFlash(data.detail ?? data.error ?? 'Failed to assign owner.', 'error');
      }
    });
  });
</script>

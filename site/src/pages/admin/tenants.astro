---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Admin Tenants page — SSR (W1, ADR-0038)
// Middleware enforces requireAdmin before rendering this page.
import AdminLayout from '../../layouts/AdminLayout.astro';
import { FASTAPI_BASE } from '../../lib/fastapi';
import TenantsIsland from './_tenants-island';

const cookieHeader = Astro.request.headers.get('cookie') ?? '';

type Tenant = {
  id: number;
  name: string;
  active: boolean;
  created_at: string | null;
  member_count: number;
  repo_count: number;
  profile_count: number;
};

type User = {
  id: number;
  username: string;
  email: string | null;
};

let tenantsData: { tenants: Tenant[]; error?: string | null } = { tenants: [] };
let usersData: { users: User[] } = { users: [] };

try {
  const [tenantsRes, usersRes] = await Promise.all([
    fetch(`${FASTAPI_BASE}/api/tenants`, { headers: { cookie: cookieHeader } }),
    fetch(`${FASTAPI_BASE}/api/admin/users`, { headers: { cookie: cookieHeader } }),
  ]);
  if (tenantsRes.ok) {
    tenantsData = await tenantsRes.json();
  } else if (tenantsRes.status === 403) {
    return Astro.redirect('/admin?error=admin_required');
  } else {
    tenantsData.error = `API error ${tenantsRes.status}`;
  }
  if (usersRes.ok) {
    usersData = await usersRes.json();
  }
} catch {
  tenantsData.error = 'Could not connect to API server.';
}
---

<AdminLayout title="Tenants — Admin">
  <!-- Flash banner -->
  <div data-testid="flash-banner" hidden class="fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border"></div>

  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Tenants</h1>
      <p class="text-sm text-gray-500 mt-1">Manage tenant organizations and member assignments</p>
    </div>
    <span class="text-xs bg-blue-100 text-blue-800 px-3 py-1 rounded-full font-medium">
      {tenantsData.tenants.length} tenant{tenantsData.tenants.length !== 1 ? 's' : ''}
    </span>
  </div>

  {tenantsData.error && (
    <div data-testid="tenants-error" class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm">
      {tenantsData.error}
    </div>
  )}

  <!-- React island handles all mutations (create/edit/delete tenant, add/remove members, assign resources) -->
  <TenantsIsland
    client:load
    initialTenants={tenantsData.tenants}
    allUsers={usersData.users}
  />
</AdminLayout>

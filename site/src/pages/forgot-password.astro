---
// SPDX-License-Identifier: AGPL-3.0-or-later
// forgot-password.astro — Public forgot-password page (W1D-1)
// prerender=false: SSR so we can redirect already-authed users server-side.
export const prerender = false;

import AuthLayout from '../layouts/AuthLayout.astro';
import { FASTAPI_BASE } from '../lib/fastapi';
import { resolveAuthLanding } from '../lib/auth-landing';

// Redirect already-authed users to their role-appropriate landing (H3).
// Previously redirected unconditionally to /admin — non-admin customers were
// then bounced by middleware to /account/api-keys (two hops, confusing flash).
// resolveAuthLanding() resolves the correct destination in a single hop.
const cookieHeader = Astro.request.headers.get('cookie') ?? '';
let alreadyAuthed = false;
let alreadyAuthedIsAdmin = false;
try {
  const verify = await fetch(`${FASTAPI_BASE}/api/auth/verify`, {
    headers: { cookie: cookieHeader },
  });
  alreadyAuthed = verify.ok;
  if (verify.ok) {
    const vb = await verify.json().catch(() => ({ is_admin: false }));
    alreadyAuthedIsAdmin = vb.is_admin === true;
  }
} catch {
  // server down — allow forgot-password page
}

if (alreadyAuthed) {
  return Astro.redirect(resolveAuthLanding(alreadyAuthedIsAdmin));
}
---

<AuthLayout title="Forgot Password — Odoo Semantic MCP" subtitle="Forgot your password?">
  <!-- Card -->
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <!-- Success state (shown after submit — identical whether email exists or not) -->
    <div data-testid="forgot-success" hidden class="text-center py-4" role="status" aria-live="polite">
      <p class="text-lg font-semibold text-gray-900 mb-2">Check your inbox</p>
      <p class="text-sm text-gray-600" data-testid="forgot-success-msg">
        If that email is registered, a reset link has been sent. Check your inbox.
      </p>
      <p class="text-xs text-gray-500 mt-3">The link expires in 24 hours.</p>
      <p class="text-center text-sm text-gray-500 mt-6">
        <a href="/login" class="text-viindoo-primary-text hover:underline font-medium">Back to sign in</a>
      </p>
    </div>

    <!-- The form itself -->
    <form data-testid="forgot-form" class="space-y-4">
      <p class="text-sm text-gray-600 mb-2">
        Enter your email address and we will send you a link to reset your password.
      </p>

      <div>
        <label for="fp-email" class="block text-sm font-medium text-gray-700 mb-1">
          Email
        </label>
        <input
          id="fp-email"
          name="email"
          type="email"
          autocomplete="email"
          required
          autofocus
          data-testid="forgot-email-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-viindoo-primary-deep focus:border-viindoo-primary-deep"
          placeholder="you@example.com"
        />
      </div>

      <!-- Error message (only shown on 429 rate-limit) -->
      <p
        data-testid="forgot-error"
        hidden
        role="alert"
        aria-live="assertive"
        class="text-sm text-red-600 bg-red-50 px-3 py-2 rounded-lg border border-red-200"
      ></p>

      <button
        type="submit"
        data-testid="forgot-submit-button"
        class="w-full bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0 font-medium py-2.5 rounded-lg transition-colors text-sm"
      >
        Send reset link
      </button>
    </form>
  </div>

  <!-- Nav links: sign in + sign up (item #17) -->
  <p class="text-center text-sm text-gray-500 mt-4">
    Remembered your password?
    <a href="/login" class="text-viindoo-primary-text hover:underline font-medium">Sign in</a>
    &nbsp;&middot;&nbsp;
    New here?
    <a href="/signup" class="text-viindoo-primary-text hover:underline font-medium">Sign up</a>
  </p>
</AuthLayout>

<script>
  import { submitJson } from '../lib/apiClient';

  const form = document.querySelector('[data-testid="forgot-form"]') as HTMLFormElement | null;
  const successDiv = document.querySelector('[data-testid="forgot-success"]') as HTMLElement | null;
  const errorEl = document.querySelector('[data-testid="forgot-error"]') as HTMLElement | null;
  const submitBtn = document.querySelector('[data-testid="forgot-submit-button"]') as HTMLButtonElement | null;

  function showError(msg: string): void {
    if (errorEl) {
      errorEl.textContent = msg;
      errorEl.removeAttribute('hidden');
    }
  }

  function clearError(): void {
    if (errorEl) errorEl.setAttribute('hidden', '');
  }

  function setLoading(loading: boolean): void {
    if (submitBtn) {
      submitBtn.disabled = loading;
      submitBtn.textContent = loading ? 'Sending…' : 'Send reset link';
    }
  }

  form?.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    clearError();
    setLoading(true);

    const fd = new FormData(form!);
    const email = (fd.get('email') as string)?.trim() ?? '';

    try {
      const r = await submitJson('/api/auth/forgot-password', {
        method: 'POST',
        body: { email },
        stepUp: false,
      });

      if (r.status === 429) {
        showError('Too many attempts. Please wait a minute.');
        setLoading(false);
        return;
      }

      // For any other response (200 OK, or unexpected error), show the
      // same neutral success message — never reveal whether the email exists.
      form!.setAttribute('hidden', '');
      successDiv?.removeAttribute('hidden');
    } catch {
      // Network error — still show neutral message to avoid enumeration.
      form!.setAttribute('hidden', '');
      successDiv?.removeAttribute('hidden');
    }
  });
</script>

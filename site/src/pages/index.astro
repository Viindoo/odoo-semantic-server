---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import InstallSnippets from '../components/InstallSnippets.astro';
import Hero from '../components/Hero.astro';
import PersonaCards from '../components/PersonaCards.astro';
import GraphShowcase from '../components/GraphShowcase.tsx';
---

<BaseLayout
  title="Odoo Semantic MCP — Ship Odoo with verified knowledge, not hallucinations"
  description="A semantic knowledge engine for the entire Odoo ecosystem. Resolve models, trace overrides, prove what's standard — across v8 to v20+. Queryable by any AI tool via MCP."
>
  <!-- Sticky nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur bg-viindoo-bg-0/70 border-b border-white/5">
    <div class="mx-auto max-w-7xl px-6 h-16 flex items-center justify-between">
      <a href="/" class="inline-flex items-center gap-3 font-display font-bold text-viindoo-on-dark text-[15px] tracking-tight hover:text-viindoo-primary transition-colors duration-200">
        <span
          class="w-7 h-7 rounded-lg flex-shrink-0"
          style="background: linear-gradient(135deg, #00BBCE, #7F4282);"
          aria-hidden="true"
        />
        Odoo Semantic
        <span class="font-mono text-[10px] text-viindoo-primary tracking-widest mt-0.5 hidden sm:block">MCP</span>
      </a>
      <div class="flex items-center gap-6 lg:gap-8 text-sm font-medium text-viindoo-on-dark-muted">
        <a href="#showcase" class="hover:text-viindoo-on-dark transition-colors duration-200 hidden md:block">Live demo</a>
        <a href="#tools" class="hover:text-viindoo-on-dark transition-colors duration-200 hidden md:block">Tools</a>
        <a href="#benchmark" class="hover:text-viindoo-on-dark transition-colors duration-200 hidden md:block">Benchmark</a>
        <a href="#install" class="hover:text-viindoo-on-dark transition-colors duration-200 hidden md:block">Install</a>
        <a
          href="#install"
          class="inline-flex items-center gap-2 bg-viindoo-primary text-viindoo-bg-0 font-semibold text-sm px-4 py-2 rounded-lg hover:bg-viindoo-primary-bright hover:-translate-y-px transition-all duration-200"
        >
          Get started
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero section -->
  <Hero />

  <!-- Social proof strip -->
  <section
    id="social-proof"
    class="relative bg-viindoo-bg-0 border-t border-b py-6 overflow-hidden"
    style="border-color: rgba(230,242,244,0.08);"
    aria-label="Trust signals"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 600px 80px at 50% 50%, rgba(0,187,206,0.06), transparent 70%);"
      aria-hidden="true"
    />
    <div class="relative mx-auto max-w-7xl px-6">
      <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-8 font-mono text-[12px] uppercase tracking-widest text-viindoo-on-dark-dim">
        <span>Built by <strong class="text-viindoo-primary-bright font-semibold">Viindoo</strong></span>
        <span class="opacity-40" aria-hidden="true">&middot;</span>
        <span>Indexes <strong class="text-viindoo-primary-bright font-semibold">70+ repos</strong></span>
        <span class="opacity-40" aria-hidden="true">&middot;</span>
        <span><strong class="text-viindoo-primary-bright font-semibold">12,400 models</strong></span>
        <span class="opacity-40" aria-hidden="true">&middot;</span>
        <span>v8 &rarr; v20+</span>
        <span class="opacity-40" aria-hidden="true">&middot;</span>
        <span><strong class="text-viindoo-primary-bright font-semibold">14 MCP tools</strong></span>
      </div>
    </div>
  </section>

  <!-- 01 · Personas -->
  <section id="personas" class="bg-white text-viindoo-dark py-24">
    <div class="mx-auto max-w-7xl px-6" data-section="01">
      <div class="text-sm font-mono text-viindoo-secondary uppercase tracking-widest mb-3 flex items-center gap-2">
        <span class="w-7 h-px bg-viindoo-secondary" aria-hidden="true" />
        01 &middot; WHO IT&apos;S FOR
      </div>
      <h2 class="text-4xl font-display font-bold text-viindoo-dark tracking-tight leading-tight">Built for everyone shipping Odoo.</h2>
      <p class="text-viindoo-muted mt-4 text-lg max-w-2xl leading-relaxed">
        Three workflows we serve deeply, and two more where MCP shines. Whether you write code,
        scope projects, or quantify upgrade risk — get answers in seconds, not days.
      </p>
      <PersonaCards />
    </div>
  </section>

  <!-- 02 · Live Graph / Showcase -->
  <section id="showcase" class="bg-viindoo-bg-0 py-24">
    <div class="mx-auto max-w-7xl px-6" data-section="02">
      <div class="text-sm font-mono text-viindoo-primary uppercase tracking-widest mb-3 flex items-center gap-2">
        <span class="w-7 h-px bg-viindoo-primary" aria-hidden="true" />
        02 &middot; LIVE GRAPH
      </div>
      <h2 class="text-4xl font-display font-bold text-viindoo-on-dark tracking-tight leading-tight">Explore the inheritance web.</h2>
      <p class="text-viindoo-on-dark-muted mt-4 text-lg max-w-2xl leading-relaxed">
        Interactive graph of the full Odoo model hierarchy. Click any node to resolve fields, methods, and override points — live.
      </p>
      <div class="mt-12">
        <GraphShowcase client:visible />
      </div>
    </div>
  </section>

  <!-- 03 · Toolbox -->
  <section id="tools" class="py-24 bg-viindoo-bg-1">
    <div class="mx-auto max-w-7xl px-6" data-section="03">
      <div class="text-sm font-mono text-viindoo-primary uppercase tracking-widest mb-3 flex items-center gap-2">
        <span class="w-7 h-px bg-viindoo-primary" aria-hidden="true" />
        03 &middot; THE TOOLBOX
      </div>
      <h2 class="text-4xl font-display font-bold text-viindoo-on-dark tracking-tight leading-tight">
        14 specialized tools.<br />One MCP endpoint.
      </h2>
      <p class="text-viindoo-on-dark-muted mt-4 text-lg max-w-2xl leading-relaxed">
        resolve_model · resolve_field · resolve_method · resolve_view · find_examples · impact_analysis
        · lookup_core_api · api_version_diff · find_deprecated_usage · lint_check · cli_help
        · suggest_pattern · check_module_exists · find_override_point
      </p>
      <!-- W9 will fill with 14 tools grid inline -->
      <div class="mt-12 text-sm font-mono text-viindoo-on-dark-dim opacity-60">{/* 14-tool grid — W9 */}</div>
    </div>
  </section>

  <!-- 04 · The Difference / Prompt Simulator -->
  <section id="prompt" class="bg-viindoo-bg-0 py-24">
    <div class="mx-auto max-w-7xl px-6" data-section="04">
      <div class="text-sm font-mono text-viindoo-primary uppercase tracking-widest mb-3 flex items-center gap-2">
        <span class="w-7 h-px bg-viindoo-primary" aria-hidden="true" />
        04 &middot; THE DIFFERENCE
      </div>
      <h2 class="text-4xl font-display font-bold text-viindoo-on-dark tracking-tight leading-tight">
        Without MCP, your AI invents field names.
      </h2>
      <p class="text-viindoo-on-dark-muted mt-4 text-lg max-w-2xl leading-relaxed">
        Side-by-side: what an AI hallucinates without context vs. what it answers with Odoo Semantic MCP.
        Real queries, real results.
      </p>
      <!-- W7 will fill with PromptSimulator.tsx -->
      <div
        data-testid="prompt-simulator-slot"
        class="mt-12 min-h-[400px] rounded-2xl border border-white/10 bg-viindoo-bg-1"
        aria-label="Prompt simulator — coming in W7"
      />
    </div>
  </section>

  <!-- 05 · Token Economics / Benchmark -->
  <section id="benchmark" class="bg-white text-viindoo-dark py-24">
    <div class="mx-auto max-w-7xl px-6" data-section="05">
      <div class="text-sm font-mono text-viindoo-secondary uppercase tracking-widest mb-3 flex items-center gap-2">
        <span class="w-7 h-px bg-viindoo-secondary" aria-hidden="true" />
        05 &middot; TOKEN ECONOMICS
      </div>
      <h2 class="text-4xl font-display font-bold text-viindoo-dark tracking-tight leading-tight">
        99% fewer tokens.<br />Zero fabrications.
      </h2>
      <p class="text-viindoo-muted mt-4 text-lg max-w-2xl leading-relaxed">
        Measured on 40 real Odoo developer tasks. Precision: 100% with MCP vs 43% without. Context window savings pay for the server in week one.
      </p>
      <!-- W8 will fill with TokenBenchmark.tsx -->
      <div
        data-testid="token-benchmark-slot"
        class="mt-12 min-h-[300px] rounded-2xl border border-gray-200 bg-gray-50"
        aria-label="Token benchmark — coming in W8"
      />
    </div>
  </section>

  <!-- 06 · Install -->
  <section id="install" class="bg-viindoo-bg-0 py-24">
    <div class="mx-auto max-w-7xl px-6" data-section="06">
      <div class="text-sm font-mono text-viindoo-primary uppercase tracking-widest mb-3 flex items-center gap-2">
        <span class="w-7 h-px bg-viindoo-primary" aria-hidden="true" />
        06 &middot; WIRE IT UP
      </div>
      <h2 class="text-4xl font-display font-bold text-viindoo-on-dark tracking-tight leading-tight">One URL. Any AI tool.</h2>
      <p class="text-viindoo-on-dark-muted mt-4 text-lg max-w-2xl leading-relaxed">
        No installation required on your end. Add the URL + API key to your AI tool config — done in under 5 minutes.
        W9 will add Step 0 and a CTA band here.
      </p>
      <div class="mt-10">
        <InstallSnippets />
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-viindoo-bg-0 border-t py-10 px-6 text-center" style="border-color: rgba(230,242,244,0.08);">
    <div class="mx-auto max-w-7xl">
      <p class="font-mono text-[11px] text-viindoo-on-dark-dim">
        &copy; Viindoo &middot; Built on the Model Context Protocol &middot;
        <span class="text-viindoo-primary">v0.3.0</span>
      </p>
      <div class="flex items-center justify-center gap-6 mt-3 text-[12px] text-viindoo-on-dark-dim">
        <a href="/admin/login" class="hover:text-viindoo-primary-bright transition-colors duration-200">Admin</a>
        <a href="https://github.com/Viindoo/odoo-semantic-mcp" class="hover:text-viindoo-primary-bright transition-colors duration-200">GitHub</a>
        <a href="/install/" class="hover:text-viindoo-primary-bright transition-colors duration-200">Install</a>
      </div>
    </div>
  </footer>
</BaseLayout>

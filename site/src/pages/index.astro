---
// SPDX-License-Identifier: AGPL-3.0-or-later
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import InstallSnippets from '../components/InstallSnippets.astro';
import Hero from '../components/Hero.astro';
import PersonaCards from '../components/PersonaCards.astro';
import GraphShowcase from '../components/GraphShowcase.tsx';
import PromptSimulator from '../components/PromptSimulator.tsx';
import TokenBenchmark from '../components/TokenBenchmark.tsx';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import OpenSourcePlugins from '../components/OpenSourcePlugins.astro';
import { TOOL_COUNT, RESOURCE_COUNT, BRAND_FULL } from '../lib/constants';
import { TOOLS, RESOURCES, TOOL_GROUP_COLORS, TOOL_GROUP_LABELS } from '../lib/tools-data';
import { SCENARIOS } from '../lib/examples-data';

const softwareAppJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: BRAND_FULL,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  description: 'A semantic knowledge engine for the entire Odoo ecosystem. Resolve models, trace overrides, prove what\'s standard — across v8 to v19+. Queryable by any AI tool via MCP.',
  url: 'https://odoo-semantic.viindoo.com',
  offers: {
    '@type': 'AggregateOffer',
    url: 'https://odoo-semantic.viindoo.com/pricing',
    priceCurrency: 'USD',
    lowPrice: '0',
    offerCount: '3',
  },
  author: {
    '@type': 'Organization',
    name: 'Viindoo',
    url: 'https://viindoo.com',
  },
});
---

<BaseLayout
  title="Odoo Semantic MCP — Ship Odoo with verified knowledge, not hallucinations"
  description="A semantic knowledge engine for the entire Odoo ecosystem. Resolve models, trace overrides, prove what's standard — across v8 to v19+. Queryable by any AI tool via MCP."
  theme="dark"
  showFooter={false}
>
  <script type="application/ld+json" set:html={softwareAppJsonLd} slot="head" />
  <SiteHeader currentPath={Astro.url.pathname} />

  <!-- Hero section -->
  <Hero />

  <!-- Social proof strip -->
  <section
    id="social-proof"
    class="relative bg-viindoo-bg-0 border-t border-b py-6 overflow-hidden"
    style="border-color: rgba(230,242,244,0.08);"
    aria-label="Trust signals"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 600px 80px at 50% 50%, rgba(0,187,206,0.06), transparent 70%);"
      aria-hidden="true"
    />
    <div class="relative mx-auto max-w-7xl px-6">
      <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-8 font-mono text-[12px] uppercase tracking-widest text-viindoo-on-dark-dim">
        <span>Built by <strong class="text-viindoo-primary-bright font-semibold">Viindoo</strong></span>
        <span class="opacity-40" aria-hidden="true">&middot;</span>
        <span>Indexes <strong class="text-viindoo-primary-bright font-semibold">70+ repos</strong></span>
        <span class="opacity-40" aria-hidden="true">&middot;</span>
        <span><strong class="text-viindoo-primary-bright font-semibold">12,400 models</strong></span>
        <span class="opacity-40" aria-hidden="true">&middot;</span>
        <span>v8 &rarr; v19+</span>
        <span class="opacity-40" aria-hidden="true">&middot;</span>
        <span><strong class="text-viindoo-primary-bright font-semibold">{TOOL_COUNT} MCP tools</strong></span>
      </div>
    </div>
  </section>

  <!-- 01 · Personas -->
  <section id="personas" class="bg-white text-viindoo-dark py-24">
    <div class="mx-auto max-w-7xl px-6" data-section="01">
      <div class="text-sm font-mono text-viindoo-secondary uppercase tracking-widest mb-3 flex items-center gap-2">
        <span class="w-7 h-px bg-viindoo-secondary" aria-hidden="true" />
        01 &middot; BUILT FOR DEVELOPERS
      </div>
      <h2 class="text-4xl font-display font-bold text-viindoo-dark tracking-tight leading-tight">The Odoo intelligence layer<br class="hidden sm:block" /> your AI was missing.</h2>
      <p class="text-viindoo-muted mt-4 text-lg max-w-2xl leading-relaxed">
        Made for the developers who ship Odoo &mdash; resolve models, trace overrides, and catch
        deprecations grounded in a real graph. And because the same answers are plain English,
        your consultants, PMs, and sales team get the truth too.
      </p>
      <PersonaCards />
    </div>
  </section>

  <!-- 02 · Live Graph / Showcase -->
  <section id="showcase" class="bg-viindoo-bg-0 py-24">
    <div class="mx-auto max-w-7xl px-6" data-section="02">
      <div class="text-sm font-mono text-viindoo-primary uppercase tracking-widest mb-3 flex items-center gap-2">
        <span class="w-7 h-px bg-viindoo-primary" aria-hidden="true" />
        02 &middot; LIVE GRAPH
      </div>
      <h2 class="text-4xl font-display font-bold text-viindoo-on-dark tracking-tight leading-tight">Explore the inheritance web.</h2>
      <p class="text-viindoo-on-dark-muted mt-4 text-lg max-w-2xl leading-relaxed">
        Interactive graph of the full Odoo model hierarchy. Click any node to resolve fields, methods, and override points — live.
      </p>
      <div class="mt-12">
        <GraphShowcase client:visible />
      </div>
    </div>
  </section>

  <!-- 03 · Toolbox -->
  <section id="tools" class="py-24 bg-viindoo-bg-1">
    <div class="mx-auto max-w-7xl px-6" data-section="03">
      <div class="text-sm font-mono text-viindoo-primary uppercase tracking-widest mb-3 flex items-center gap-2">
        <span class="w-7 h-px bg-viindoo-primary" aria-hidden="true" />
        03 &middot; THE TOOLBOX
      </div>
      <h2 class="text-4xl font-display font-bold text-viindoo-on-dark tracking-tight leading-tight">
        {TOOL_COUNT} specialized tools.<br />One MCP endpoint.
      </h2>
      <p class="text-viindoo-on-dark-muted mt-4 text-lg max-w-2xl leading-relaxed">
        Resolve models, fields, methods, views. Find examples, measure impact. Version diffs, deprecation scans, pattern suggestions — all atomic. Plus supersets, session-state tools, and ORM validation (domains, @api.depends, relations) for streamlined AI agent workflows.
      </p>

      <!-- tool grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-px bg-white/5 rounded-2xl overflow-hidden mt-12 border border-white/10">
        {TOOLS.map((tool) => (
          <div class="group relative bg-viindoo-bg-1 hover:bg-viindoo-bg-2 transition p-5 min-h-[120px]" data-tool-group={tool.group}>
            <span class="absolute top-3 right-4 font-mono text-[10px] text-viindoo-on-dark-dim">{tool.num}</span>
            <div class="font-mono text-sm font-semibold text-viindoo-on-dark mb-1.5">{tool.name}</div>
            <p class="text-xs text-viindoo-on-dark-muted leading-relaxed">{tool.desc}</p>
            <span class:list={['absolute top-0 left-0 h-px w-8 group-hover:w-full transition-all duration-300', TOOL_GROUP_COLORS[tool.group]]}></span>
          </div>
        ))}
      </div>

      <!-- Tool legend — data-driven from TOOL_GROUP_LABELS / TOOL_GROUP_COLORS -->
      <div class="mt-6 flex flex-wrap items-center justify-center gap-5 font-mono text-xs text-viindoo-on-dark-muted">
        {(Object.entries(TOOL_GROUP_LABELS) as [keyof typeof TOOL_GROUP_LABELS, string][]).map(([group, label]) => (
          <span class="inline-flex items-center gap-2">
            <span class:list={['w-2 h-2 rounded-full', TOOL_GROUP_COLORS[group]]}></span>
            {label}
          </span>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/tools" class="inline-flex items-center gap-2 font-semibold text-viindoo-primary hover:gap-3 transition text-sm">
          See all {TOOL_COUNT} tools &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- 03b · Resources -->
  <section id="resources" class="py-24 bg-viindoo-bg-0">
    <div class="mx-auto max-w-7xl px-6" data-section="03b">
      <div class="text-sm font-mono text-viindoo-primary uppercase tracking-widest mb-3 flex items-center gap-2">
        <span class="w-7 h-px bg-viindoo-primary" aria-hidden="true" />
        03B &middot; RESOURCES
      </div>
      <h2 class="text-4xl font-display font-bold text-viindoo-on-dark tracking-tight leading-tight">
        7 MCP Resources.<br />Bookmark any entity.
      </h2>
      <p class="text-viindoo-on-dark-muted mt-4 text-lg max-w-2xl leading-relaxed">
        Stable <code class="font-mono text-viindoo-primary-bright">odoo://&#123;version&#125;/&#123;kind&#125;/&#123;path&#125;</code> URIs for direct entity reads. Bookmark-stable across sessions — works as native pinned context in VS Code, Claude, and any MCP-aware client.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-white/5 rounded-2xl overflow-hidden mt-12 border border-white/10">
        {RESOURCES.map((resource) => (
          <div class="group relative bg-viindoo-bg-1 hover:bg-viindoo-bg-2 transition p-5 min-h-[110px]">
            <div class="font-mono text-xs text-viindoo-primary-bright mb-1.5">{resource.uri}</div>
            <p class="text-xs text-viindoo-on-dark-muted leading-relaxed">{resource.desc}</p>
          </div>
        ))}
      </div>

      <p class="text-xs text-viindoo-on-dark-dim mt-6 font-mono text-center">
        Resources are read-only · per-tenant cache · same auth as tools (X-API-Key).
      </p>
    </div>
  </section>

  <!-- 04 · The Difference / Prompt Simulator -->
  <section id="prompt" class="bg-viindoo-bg-0 py-24">
    <div class="mx-auto max-w-7xl px-6" data-section="04">
      <div class="text-sm font-mono text-viindoo-primary uppercase tracking-widest mb-3 flex items-center gap-2">
        <span class="w-7 h-px bg-viindoo-primary" aria-hidden="true" />
        04 &middot; THE DIFFERENCE
      </div>
      <h2 class="text-4xl font-display font-bold text-viindoo-on-dark tracking-tight leading-tight">
        Without MCP, your AI invents field names.
      </h2>
      <p class="text-viindoo-on-dark-muted mt-4 text-lg max-w-2xl leading-relaxed">
        Side-by-side: what an AI hallucinates without context vs. what it answers with Odoo Semantic MCP.
        Real queries, real results.
      </p>
      <div class="mt-12">
        <PromptSimulator client:visible />
      </div>
      <div class="mt-8 text-center">
        <a href="/examples" class="inline-flex items-center gap-2 font-semibold text-viindoo-primary hover:gap-3 transition text-sm">
          See all {SCENARIOS.length} live examples &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- 05 · Token Economics / Benchmark teaser -->
  <section id="benchmark" class="bg-white text-viindoo-dark py-24">
    <div class="mx-auto max-w-7xl px-6" data-section="05">
      <div class="text-sm font-mono text-viindoo-secondary uppercase tracking-widest mb-3 flex items-center gap-2">
        <span class="w-7 h-px bg-viindoo-secondary" aria-hidden="true" />
        05 &middot; TOKEN ECONOMICS
      </div>
      <h2 class="text-4xl font-display font-bold text-viindoo-dark tracking-tight leading-tight">
        99% fewer tokens.<br />Zero fabrications.
      </h2>
      <p class="text-viindoo-muted mt-4 text-lg max-w-2xl leading-relaxed">
        7 real Odoo workflows, live-measured. 4 axes: accuracy, full-codebase coverage, token savings, speed.
        Context window savings pay for the server in week one.
      </p>
      <div class="mt-12">
        <TokenBenchmark client:visible />
      </div>
      <div class="mt-8 text-center flex flex-wrap justify-center gap-6">
        <a href="/benchmark" class="inline-flex items-center gap-2 font-semibold text-viindoo-secondary hover:gap-3 transition text-sm">
          Full benchmark showcase (7 cases, 4 axes) &rarr;
        </a>
        <a href="/benchmarks" class="inline-flex items-center gap-2 font-semibold text-viindoo-muted hover:gap-3 transition text-sm">
          Methodology &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- 06 · Install -->
  <section id="install" class="bg-viindoo-bg-0 py-24">
    <div class="mx-auto max-w-7xl px-6" data-section="06">
      <div class="text-sm font-mono text-viindoo-primary uppercase tracking-widest mb-3 flex items-center gap-2">
        <span class="w-7 h-px bg-viindoo-primary" aria-hidden="true" />
        06 &middot; WIRE IT UP
      </div>
      <h2 class="text-4xl font-display font-bold text-viindoo-on-dark tracking-tight leading-tight">One URL. Any AI tool.</h2>
      <p class="text-viindoo-on-dark-muted mt-4 text-lg max-w-2xl leading-relaxed">
        No installation required on your end. Add the URL + API key to your AI tool config — done in under 5 minutes.
      </p>
      <div class="mt-10">
        <InstallSnippets />
      </div>
    </div>
  </section>

  <!-- 06b · Open-source plugins -->
  <OpenSourcePlugins />

  <!-- CTA band before footer -->
  <section class="bg-viindoo-bg-0 px-6 pb-24">
    <div class="mx-auto max-w-5xl relative overflow-hidden rounded-3xl border border-white/10 p-12 text-center" style="background: radial-gradient(circle at 20% 30%, rgba(0,187,206,0.18), transparent 50%), radial-gradient(circle at 80% 70%, rgba(127,66,130,0.18), transparent 50%), linear-gradient(120deg, var(--viindoo-bg-1), var(--viindoo-bg-2));">
      <h2 class="font-display text-3xl md:text-4xl font-extrabold leading-tight mb-4">
        Stop guessing. Start shipping.
      </h2>
      <p class="text-viindoo-on-dark-muted text-lg max-w-2xl mx-auto mb-8">
        Get an API key, pick your client, and query the Odoo ecosystem in your next prompt.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/signup" class="inline-flex items-center gap-2 bg-viindoo-primary text-viindoo-bg-0 font-semibold text-sm px-5 py-2.5 rounded-lg hover:bg-viindoo-primary-bright hover:-translate-y-px transition-all duration-200">
          Create your free account
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="/install/" class="inline-flex items-center gap-2 border border-white/20 text-viindoo-on-dark font-semibold text-sm px-5 py-2.5 rounded-lg hover:bg-white/5 transition-all duration-200">
          Read the docs
        </a>
      </div>
      <p class="mt-4 text-sm text-viindoo-on-dark-dim">
        Already have an account? <a href="/login" class="text-viindoo-primary-bright hover:underline">Sign in &rarr;</a>
      </p>
    </div>
  </section>

  <SiteFooter />
</BaseLayout>

---
// SPDX-License-Identifier: AGPL-3.0-or-later
//
// /odoo-ai-agents — flagship "Odoo AI Agent Team" landing page (issue #291).
//
// Prerendered static marketing page (prerender=true → auto-discovered by the
// sitemap, no astro.config edit needed). Renders the v2 design spec
// (phase5-landing-design-v2.md) at flagship intensity in the site's "Living
// Cartography" language.
//
// Data discipline (D1 / A1-A8):
//  - All agents/skills/commands/personas/FAQ + counts come from
//    odoo-ai-agents-data.ts → plugins-data.ts (SSOT). Nothing capability-related
//    is hardcoded here.
//  - The FAQPage JSON-LD is built FROM the same `faqs` array the visible <details>
//    render, so H3 text === Question.name exactly (Rich Result prerequisite).
//  - A1: no infrastructure names (knowledge graph / indexed source only).
//  - A3: every GitHub link → odoo-mcp-client (never the server repo).
//  - A4: zero license tokens on this page.
//  - A5: many descriptive internal links (/tools /pricing /examples /benchmark
//        / /install /signup).
//
// SEO/GEO (A8): exactly one <h1> (in AgentHero), one descriptive <h2> per
// section, <h3> for agents / skill groups / personas / commands? (no — commands
// use <code>, not headings) / install steps / FAQ. Three JSON-LD blocks injected
// via BaseLayout slot="head".
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import AgentHero from '../components/AgentHero.astro';
import AgentPersonaCards from '../components/AgentPersonaCards.astro';
import { PLUGIN_REPO_URL } from '../lib/plugins-data';
import { TOOL_COUNT, RESOURCE_COUNT } from '../lib/constants';
import {
  agents,
  skillGroups,
  commands,
  faqs,
  SKILLS_COUNT,
  AGENTS_COUNT,
  COMMANDS_COUNT,
  PERSONAS_COUNT,
} from '../lib/odoo-ai-agents-data';

export const prerender = true;

// ---- Exact meta (r2-seo-geo-spec §2) -------------------------------------
const PAGE_TITLE = 'Odoo AI Agent Team - 42 Skills, 8 Agents for Claude Code';
const PAGE_DESC =
  '42 pre-built AI skills, 8 specialist agents, 10 slash commands grounded on an indexed Odoo knowledge graph. Zero config for Claude Code, Codex, Gemini. Free tier: 1,000 tool calls/month.';
const PAGE_URL = 'https://odoo-semantic.viindoo.com/odoo-ai-agents';

// ---- JSON-LD block 1: SoftwareApplication (r2-seo-geo-spec §3.1) ----------
// featureList counts derived from SSOT so they never drift.
const softwareAppJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Odoo AI Agent Team',
  alternateName: 'OSM Claude Code Plugin',
  description:
    `${SKILLS_COUNT} pre-built AI skills, ${AGENTS_COUNT} autonomous agents, and ${COMMANDS_COUNT} slash commands grounded on an indexed Odoo knowledge graph. Covers Odoo 8 through the latest version.`,
  applicationCategory: 'DeveloperApplication',
  applicationSubCategory: 'Odoo Development Tools',
  operatingSystem: 'Any (MCP-compatible AI tools: Claude Code, Codex CLI, Gemini CLI)',
  url: PAGE_URL,
  downloadUrl: 'https://odoo-semantic.viindoo.com/install/',
  installUrl: 'https://odoo-semantic.viindoo.com/install/',
  featureList: [
    `${SKILLS_COUNT} pre-built AI skills for Odoo development, sales, QA, and marketing`,
    `${AGENTS_COUNT} autonomous specialist agents (architect, coder, reviewer, debugger, UI)`,
    `${COMMANDS_COUNT} slash commands for multi-phase workflow automation`,
    'Grounded on 12,000+ indexed Odoo models and 184,000+ fields',
    'Supports Odoo 8 through the latest version (recent releases actively maintained)',
    'Zero configuration after install - auto-routes to the right agent',
    `${PERSONAS_COUNT} persona types covered: developer, consultant, sales, CEO, QA, and more`,
  ],
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    description: 'Free tier: 1,000 tool calls/month, no credit card required. Paid plans with higher limits available - see the pricing page.',
    url: 'https://odoo-semantic.viindoo.com/pricing',
    availability: 'https://schema.org/InStock',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Viindoo',
    url: 'https://viindoo.com',
    sameAs: ['https://github.com/Viindoo'],
  },
});

// ---- JSON-LD block 2: FAQPage — built from the SAME faqs SSOT the <details>
//      render, so name/text match exactly (Rich Result prerequisite). ---------
const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.answer,
    },
  })),
});

// ---- JSON-LD block 3: BreadcrumbList (r2-seo-geo-spec §3.2) ----------------
const breadcrumbJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Odoo Semantic MCP', item: 'https://odoo-semantic.viindoo.com/' },
    { '@type': 'ListItem', position: 2, name: 'Odoo AI Agent Team', item: PAGE_URL },
  ],
});

// ---- Section helpers ------------------------------------------------------
// The opus architect is agents[0]; the remaining 7 are sonnet/haiku-tier.
const architect = agents[0];
const sonnetAgents = agents.slice(1);

// One-line tool hint per agent for the card footer (benefit copy lives in data;
// these are illustrative tool names, not capability counts — A1-safe, generic).
const agentTools: Record<string, string> = {
  'odoo-solution-architect': 'model_inspect · find_override_point · impact_analysis',
  'odoo-coder': 'validate_depends · resolve_orm_chain',
  'odoo-frontend-coder': 'resolve_stylesheet · api_version_diff',
  'odoo-code-reviewer': 'lint_check · impact_analysis',
  'odoo-backend-debugger': 'resolve_orm_chain · find_override_point',
  'odoo-ui-debugger': 'browser tools · resolve_stylesheet',
  'odoo-ui-reviewer': 'browser tools · find_style_override',
  'odoo-intent-extractor': 'entity_lookup · find_examples · api_version_diff',
};

// Tier label for the badge: opus, sonnet, or "sonnet + browser" for UI agents.
function tierBadge(id: string, tier: string): string {
  if (id === 'odoo-ui-debugger' || id === 'odoo-ui-reviewer') return 'sonnet + browser';
  return tier;
}

// Short display name for a skill-group card heading (strip the trailing
// "Skills" suffix so the count badge reads cleanly).
function groupShortName(name: string): string {
  return name.replace(/\s*Skills$/i, '').replace(/\s*&\s*/g, ' & ');
}

// Trim the `odoo-` prefix for compact chips; flag the first 3 of each group.
function chip(id: string): string {
  return id.replace(/^odoo-/, '');
}

// Featured commands (first 3) shown as cards; all are listed in the terminal.
const featuredCommands = commands.slice(0, 3);
---

<BaseLayout title={PAGE_TITLE} description={PAGE_DESC} theme="dark" showFooter={false} ogImage="/og-odoo-ai-agents.png">
  <script type="application/ld+json" set:html={softwareAppJsonLd} slot="head" />
  <script type="application/ld+json" set:html={faqJsonLd} slot="head" />
  <script type="application/ld+json" set:html={breadcrumbJsonLd} slot="head" />

  <SiteHeader currentPath="/odoo-ai-agents" />

  <!-- ===== S1 · HERO (constellation) ===== -->
  <AgentHero
    skillsCount={SKILLS_COUNT}
    agentsCount={AGENTS_COUNT}
    commandsCount={COMMANDS_COUNT}
    personasCount={PERSONAS_COUNT}
  />

  <!-- ===== S2 · PROBLEM ===== -->
  <section id="problem" class="cv-grain relative bg-viindoo-bg-0 py-24 overflow-hidden" aria-labelledby="problem-h2">
    <div class="relative z-10 mx-auto max-w-7xl px-6">
      <div class="cv-reveal">
        <span class="cv-kicker text-viindoo-primary-bright">The Problem</span>
        <h2 id="problem-h2" class="mt-4 font-display font-bold tracking-tight text-viindoo-on-dark" style="font-size:clamp(28px,3.4vw,44px); line-height:1.08;">
          Ungrounded AI multiplies hallucinations across every task.
        </h2>
        <p class="mt-5 text-viindoo-on-dark-muted text-lg leading-relaxed max-w-3xl">
          When an AI coding assistant guesses without grounding, each task accumulates errors. An ungrounded coder
          suggests <code class="font-mono text-viindoo-danger text-[0.95em]">account.invoice</code> &mdash; deprecated
          since v13. An ungrounded reviewer approves it. An ungrounded tester misses it. One wrong field name compounds
          through design, code, review, and ship.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="cv-reveal rounded-2xl border border-viindoo-danger/25 bg-viindoo-danger/[0.04] p-7" style="transition-delay:.06s;">
          <div class="flex items-center gap-2 font-mono text-[12px] uppercase tracking-widest text-viindoo-danger mb-5">
            <span class="w-2 h-2 rounded-full bg-viindoo-danger" aria-hidden="true"></span> Ungrounded team
          </div>
          <ul class="space-y-3 font-mono text-[13px] text-viindoo-on-dark-muted">
            <li class="flex gap-2"><span class="text-viindoo-danger" aria-hidden="true">&times;</span> <span><code class="text-viindoo-on-dark">account.invoice.search(...)</code> &mdash; model removed in v13</span></li>
            <li class="flex gap-2"><span class="text-viindoo-danger" aria-hidden="true">&times;</span> <span><code class="text-viindoo-on-dark">@api.depends('amout_total')</code> &mdash; typo, silent fail</span></li>
            <li class="flex gap-2"><span class="text-viindoo-danger" aria-hidden="true">&times;</span> <span>misses the 12-module inheritance chain on <code class="text-viindoo-on-dark">sale.order</code></span></li>
            <li class="flex gap-2"><span class="text-viindoo-danger" aria-hidden="true">&times;</span> <span>changes <code class="text-viindoo-on-dark">amount_total</code> with no idea what breaks downstream</span></li>
          </ul>
        </div>
        <div class="cv-reveal rounded-2xl border border-viindoo-primary/30 bg-viindoo-primary/[0.05] p-7" style="transition-delay:.12s;">
          <div class="flex items-center gap-2 font-mono text-[12px] uppercase tracking-widest text-viindoo-primary mb-5">
            <span class="w-2 h-2 rounded-full bg-viindoo-primary" aria-hidden="true"></span> Grounded team
          </div>
          <ul class="space-y-3 font-mono text-[13px] text-viindoo-on-dark-muted">
            <li class="flex gap-2"><span class="text-viindoo-success" aria-hidden="true">&#10003;</span> <span><code class="text-viindoo-on-dark">account.move.search(...)</code> &mdash; resolved against the index</span></li>
            <li class="flex gap-2"><span class="text-viindoo-success" aria-hidden="true">&#10003;</span> <span><code class="text-viindoo-on-dark">@api.depends('amount_total')</code> &mdash; path validated</span></li>
            <li class="flex gap-2"><span class="text-viindoo-success" aria-hidden="true">&#10003;</span> <span>full inheritance chain + every module extension surfaced</span></li>
            <li class="flex gap-2"><span class="text-viindoo-success" aria-hidden="true">&#10003;</span> <span>impact analysis lists everything a field change touches</span></li>
          </ul>
        </div>
      </div>

      <div class="cv-reveal mt-12 rounded-2xl cv-glass p-8" style="transition-delay:.16s;">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div>
            <p class="font-mono text-[12px] uppercase tracking-widest text-viindoo-on-dark-dim">Answer accuracy on 40 real Odoo tasks</p>
            <p class="mt-2 font-display font-extrabold tracking-tight" style="font-size:clamp(34px,4vw,56px);">
              <span class="text-viindoo-on-dark-dim">43%</span>
              <span class="text-viindoo-on-dark-dim mx-2" aria-hidden="true">&rarr;</span>
              <span class="cv-grad-text">95%</span>
            </p>
            <p class="mt-1 text-sm text-viindoo-on-dark-muted">ungrounded vs grounded, same model on the same task set</p>
          </div>
          <div class="md:w-1/2">
            <div class="h-3 w-full rounded-full bg-white/[0.06] overflow-hidden">
              <div class="bench-bar h-full rounded-full" style="background:linear-gradient(110deg,#00bbce,#a263a5);"></div>
            </div>
            <p class="mt-3 text-[12px] font-mono text-viindoo-on-dark-dim">
              Tested 2026-05, Claude claude-sonnet-4-5.
              <a href="/benchmark" class="text-viindoo-primary-bright underline decoration-viindoo-primary/40 underline-offset-2 hover:decoration-viindoo-primary">See the 40-task benchmark methodology</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== S3 · 8 AGENTS (data-driven) ===== -->
  <section id="agents" class="bg-viindoo-bg-1 py-24" aria-labelledby="agents-h2">
    <div class="mx-auto max-w-7xl px-6">
      <div class="cv-reveal">
        <span class="cv-kicker text-viindoo-primary-bright">The Team</span>
        <h2 id="agents-h2" class="mt-4 font-display font-bold tracking-tight text-viindoo-on-dark" style="font-size:clamp(28px,3.4vw,44px); line-height:1.08;">
          Eight specialist agents. One shared knowledge graph.
        </h2>
        <p class="mt-5 text-viindoo-on-dark-muted text-lg leading-relaxed max-w-3xl">
          Odoo AI Agent Team provides eight specialist agents: an architect (Opus-tier, design-gate), four engineering
          agents (Sonnet-tier), two UI agents with live browser tools, and a Haiku-tier intent extractor for forward-port pipelines. Each agent queries the indexed knowledge
          graph on every run &mdash; not its training memory. They cross-link through
          <a href="/tools" class="text-viindoo-primary-bright underline decoration-viindoo-primary/40 underline-offset-2 hover:decoration-viindoo-primary">{TOOL_COUNT} MCP tools</a>.
        </p>
      </div>

      <!-- Architect spotlight (opus) — agents[0] -->
      <div class="cv-reveal group relative mt-12 rounded-2xl cv-glass p-8 overflow-hidden shadow-glass" style="transition-delay:.06s;">
        <span class="agent-accent absolute top-0 left-0 right-0 h-[3px]" style="background:linear-gradient(90deg,#7F4282,#00BBCE);"></span>
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-6 items-start">
          <div>
            <div class="flex items-center gap-3 flex-wrap">
              <h3 class="font-mono text-viindoo-on-dark text-lg font-semibold">{architect.name}</h3>
              <span class="font-mono text-[11px] px-2 py-0.5 rounded-full bg-viindoo-secondary/15 border border-viindoo-secondary/40 text-viindoo-secondary-bright">{architect.tier}</span>
              <span class="font-mono text-[11px] px-2 py-0.5 rounded-full bg-white/[0.04] border border-white/10 text-viindoo-on-dark-dim">design gate</span>
            </div>
            <p class="mt-3 text-viindoo-on-dark-muted leading-relaxed max-w-2xl">{architect.benefit}</p>
            <p class="mt-3 font-mono text-[12px] text-viindoo-on-dark-dim">tools: {agentTools[architect.id]}</p>
          </div>
          <div class="shrink-0 hidden lg:flex h-14 w-14 items-center justify-center rounded-xl bg-viindoo-secondary/12 ring-1 ring-viindoo-secondary/40 text-viindoo-secondary-bright" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h20v14H2z" /><path d="M2 21h20M9 7l3 3-3 3M15 7l-3 6" /></svg>
          </div>
        </div>
      </div>

      <!-- 7 sonnet/haiku agents -->
      <div class="mt-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sonnetAgents.map((agent, i) => (
          <article class="cv-reveal group relative rounded-2xl cv-glass p-6 overflow-hidden" style={`transition-delay:${0.08 + i * 0.02}s;`}>
            <span class="agent-accent absolute top-0 left-0 right-0 h-[3px]" style="background:linear-gradient(90deg,#00BBCE,#2DD4E8);"></span>
            <h3 class="font-mono text-viindoo-on-dark font-semibold">{agent.name}</h3>
            <span class="mt-2 inline-block font-mono text-[10px] px-2 py-0.5 rounded-full bg-viindoo-primary/12 border border-viindoo-primary/35 text-viindoo-primary-bright">{tierBadge(agent.id, agent.tier)}</span>
            <p class="mt-3 text-sm text-viindoo-on-dark-muted leading-relaxed">{agent.benefit}</p>
            <p class="mt-3 font-mono text-[11px] text-viindoo-on-dark-dim">{agentTools[agent.id]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== S4 · SKILLS / GROUPS (data-driven) ===== -->
  <section id="skills" class="bg-viindoo-bg-0 py-24" aria-labelledby="skills-h2">
    <div class="mx-auto max-w-7xl px-6">
      <div class="cv-reveal">
        <span class="cv-kicker text-viindoo-primary-bright">The Skills</span>
        <h2 id="skills-h2" class="mt-4 font-display font-bold tracking-tight text-viindoo-on-dark" style="font-size:clamp(28px,3.4vw,44px); line-height:1.08;">
          {SKILLS_COUNT} skills that fire from plain language &mdash; no slash commands to memorize.
        </h2>
        <p class="mt-5 text-viindoo-on-dark-muted text-lg leading-relaxed max-w-3xl">
          Odoo AI Agent Team's {SKILLS_COUNT} skills cover the full Odoo development lifecycle &mdash; from architecture
          and coding through review, testing, deployment, sales, and marketing. Describe an outcome in plain English
          ("discount can never exceed 20% of unit price") and the right specialist auto-routes to the right agent and
          the right tool.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {skillGroups.map((group, gi) => (
          <article class:list={['cv-reveal rounded-2xl cv-glass p-6', gi === skillGroups.length - 1 && 'lg:col-span-3']} style={`transition-delay:${0.06 + gi * 0.02}s;`}>
            <div class="flex items-baseline justify-between gap-3">
              <h3 class="font-display font-semibold text-viindoo-on-dark">{groupShortName(group.name)}</h3>
              <span class="font-mono text-[12px] text-viindoo-primary shrink-0">{group.skills.length} skills</span>
            </div>
            <div class="mt-4 flex flex-wrap gap-2">
              {group.skills.map((id, si) => (
                <span class:list={['chip', si < 2 && 'chip-flag']}>{chip(id)}</span>
              ))}
            </div>
          </article>
        ))}
      </div>

      <p class="cv-reveal mt-6 text-sm text-viindoo-on-dark-dim max-w-3xl">
        Every skill grounds its output against the index &mdash; field names, editions, API signatures, and override
        chains. Skills can be assembled into 12 declarative multi-phase workflows behind the slash commands below.
      </p>
    </div>
  </section>

  <!-- ===== S5 · 10 COMMANDS (data-driven) ===== -->
  <section id="commands" class="bg-viindoo-bg-1 py-24" aria-labelledby="commands-h2">
    <div class="mx-auto max-w-7xl px-6">
      <div class="cv-reveal">
        <span class="cv-kicker text-viindoo-primary-bright">The Commands</span>
        <h2 id="commands-h2" class="mt-4 font-display font-bold tracking-tight text-viindoo-on-dark" style="font-size:clamp(28px,3.4vw,44px); line-height:1.08;">
          {COMMANDS_COUNT} workflow commands that chain multi-phase pipelines.
        </h2>
        <p class="mt-5 text-viindoo-on-dark-muted text-lg leading-relaxed max-w-3xl">
          Odoo AI Agent Team ships {COMMANDS_COUNT} slash commands for when you want a named multi-phase pipeline instead
          of a single skill. Each command chains skills and agents in a fixed sequence &mdash; from a full bid response
          to a git-wave that lands multiple changes safely.
        </p>
      </div>

      <!-- 3 featured commands -->
      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
        {featuredCommands.map((cmd, i) => (
          <article class="cv-reveal group relative rounded-2xl cv-glass p-6 overflow-hidden" style={`transition-delay:${0.06 + i * 0.02}s;`}>
            <span class="agent-accent absolute top-0 left-0 right-0 h-[3px]" style="background:linear-gradient(90deg,#00BBCE,#2DD4E8);"></span>
            <code class="font-mono text-viindoo-primary-bright text-sm">/{cmd.name}</code>
            <p class="mt-3 text-sm text-viindoo-on-dark-muted leading-relaxed">{cmd.description}</p>
          </article>
        ))}
      </div>

      <!-- terminal panel: all commands -->
      <div class="cv-reveal mt-6 rounded-xl border border-white/10 bg-viindoo-bg-0 overflow-hidden shadow-lift" style="transition-delay:.12s;">
        <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-white/10">
          <span class="w-2.5 h-2.5 rounded-full" style="background:#FF5F57" aria-hidden="true"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:#FEBC2E" aria-hidden="true"></span>
          <span class="w-2.5 h-2.5 rounded-full" style="background:#27C93F" aria-hidden="true"></span>
          <span class="ml-2 font-mono text-[11px] text-viindoo-on-dark-dim">{COMMANDS_COUNT} slash commands</span>
        </div>
        <div class="px-5 py-5 font-mono text-[12.5px] leading-relaxed overflow-x-auto">
          {commands.map((cmd) => (
            <p>
              <span class="text-viindoo-primary-bright">/{cmd.name}</span>
              <span class="text-viindoo-on-dark-dim"> &mdash; {cmd.description.split(/[.:]/)[0].toLowerCase()}</span>
            </p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== S6 · WHY GROUNDED (A1: no infra names) ===== -->
  <section id="why-grounded" class="cv-grain relative bg-viindoo-bg-0 py-24 overflow-hidden" aria-labelledby="grounded-h2">
    <div class="cv-aurora-field" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-6">
      <div class="cv-reveal">
        <span class="cv-kicker text-viindoo-primary-bright">Why It Does Not Hallucinate</span>
        <h2 id="grounded-h2" class="mt-4 font-display font-bold tracking-tight text-viindoo-on-dark" style="font-size:clamp(28px,3.4vw,44px); line-height:1.08;">
          Every agent verifies against indexed source, not training memory.
        </h2>
        <p class="mt-5 text-viindoo-on-dark-muted text-lg leading-relaxed max-w-3xl">
          Every agent in Odoo AI Agent Team makes its claims verifiable. When the coder suggests
          <code class="font-mono text-viindoo-primary-bright text-[0.95em]">amount_total</code>, it verified that field
          exists on <code class="font-mono text-viindoo-primary-bright text-[0.95em]">sale.order</code> at your target
          version first. When the reviewer flags a dependency, it ran
          <code class="font-mono text-viindoo-primary-bright text-[0.95em]">validate_depends</code> against the indexed
          graph. Graph lookup does not hallucinate: either the field exists in the index at that version, or it does not.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
        <div class="cv-reveal space-y-3" style="transition-delay:.06s;">
          <div class="flex items-center gap-3 rounded-xl cv-glass p-4">
            <span class="font-mono text-[11px] text-viindoo-primary shrink-0 w-7">01</span>
            <p class="text-sm text-viindoo-on-dark">You describe an outcome in plain language</p>
          </div>
          <div class="pl-5 text-viindoo-on-dark-dim" aria-hidden="true">&darr;</div>
          <div class="flex items-center gap-3 rounded-xl cv-glass p-4">
            <span class="font-mono text-[11px] text-viindoo-primary shrink-0 w-7">02</span>

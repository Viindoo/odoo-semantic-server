---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Pricing page — data-driven tiers from GET /api/plans (M10B P1, ADR-0039).
// prerender=false: plan prices are DB-driven (admin can change them without
// redeploy); billing.paid_checkout_enabled gates the live checkout CTA.
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { FASTAPI_BASE } from '../lib/fastapi';
import { TOOL_COUNT } from '../lib/constants';
import { HELPDESK_URL_FALLBACK } from '../lib/contact';

type Plan = {
  id: number;
  slug: string;
  display_name: string;
  quota_calls_per_month: number;
  rate_limit_rpm: number;
  seat_limit: number | null;
  price_cents: number | null;
  currency: string | null;
  billing_interval: string | null;
  prices: Record<string, number> | null;
  pricing_model: 'flat' | 'per_seat';
  min_seats: number | null;  // m13_016 — per-plan display SSOT; null = no minimum
};

// Fetch public plan tiers (no auth required)
let plans: Plan[] = [];
let plansError: string | null = null;

try {
  const res = await fetch(`${FASTAPI_BASE}/api/plans`);
  if (res.ok) {
    const data = await res.json();
    plans = (data.plans ?? []) as Plan[];
    // Note: data.team_min_seats (top-level) is kept in the API response for
    // backward-compat but the pricing page now reads per-plan min_seats (m13_016)
    // via seatSubLabel(plan) — no global teamMinSeats variable needed here.
  } else {
    plansError = `Could not load pricing (${res.status}).`;
  }
} catch {
  plansError = 'Could not connect to API server.';
}

// Fetch billing settings server-side (admin endpoint).
// pricing.astro is a public page — a non-admin visitor's cookie will
// yield 401/403, which is the expected safe default: show waitlist CTA.
// Only when an admin loads the page (or internal SSR tooling hits it)
// will paid_checkout_enabled be respected.  Because this is server-side,
// the actual checkout URL is never sent to the browser when the flag is off.
let paidCheckoutEnabled = false;
let checkoutUrlMap: Record<string, string> = {};

try {
  const cookieHeader = Astro.request.headers.get('cookie') ?? '';
  const res = await fetch(`${FASTAPI_BASE}/api/admin/settings`, {
    headers: { cookie: cookieHeader },
  });
  if (res.ok) {
    const data = await res.json() as { categories: Record<string, Array<{ key: string; value: unknown }>> };
    const billingSettings: Array<{ key: string; value: unknown }> = data.categories['billing'] ?? [];
    for (const s of billingSettings) {
      if (s.key === 'billing.paid_checkout_enabled') {
        paidCheckoutEnabled = s.value === true || s.value === 'true';
      }
      if (s.key === 'billing.polar_checkout_url_map' && s.value && typeof s.value === 'object') {
        checkoutUrlMap = s.value as Record<string, string>;
      }
    }
  }
  // 401/403 = not admin; default stays false (safe — no checkout links for public visitors)
} catch {
  // Network or parse error — keep safe default
}

// Fetch public site-config for helpdesk_url (no auth required)
let helpdeskUrl: string = HELPDESK_URL_FALLBACK;

try {
  const res = await fetch(`${FASTAPI_BASE}/api/site-config`);
  if (res.ok) {
    const data = await res.json() as { helpdesk_url?: string; site_version?: string };
    if (data.helpdesk_url) {
      helpdeskUrl = data.helpdesk_url;
    }
  }
} catch {
  // Network error — fall back to constant
}

// Logged-in user email for ?reference_id= pre-fill (pass-through only when checkout enabled)
const currentEmail = Astro.locals.user?.email ?? '';

// Highlight the middle paid tier (Pro) by default;
// fall back to second plan if only 2 tiers, or first if only 1.
function isHighlighted(plan: Plan, all: Plan[]): boolean {
  if (all.length <= 1) return true;
  const paidPlans = all.filter((p) => p.billing_interval && p.billing_interval !== 'free');
  if (paidPlans.length === 0) return false;
  // Highlight the cheapest paid plan (Pro), not the most expensive (Team)
  return plan.id === paidPlans[0]?.id;
}

// Format a price for display in USD (cent-based, /100).
// Returns the numeric portion only — suffix ("/seat /mo" vs "/mo") is rendered separately.
function formatPrice(plan: Plan): string {
  // If the plan is free tier, show $0 (distinct from the plan name "Free")
  if (!plan.billing_interval || plan.billing_interval === 'free') {
    return '$0';
  }
  // Try the per-currency prices map first (C3 — ADR-0039)
  if (plan.prices && typeof plan.prices === 'object') {
    const raw = plan.prices['USD'];
    if (raw !== undefined) {
      const usd = Number(raw) / 100;
      return `$${usd.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
    }
  }
  // Fallback to scalar price_cents (USD cents)
  if (plan.price_cents !== null && plan.price_cents !== undefined) {
    const usd = plan.price_cents / 100;
    return `$${usd.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
  }
  return 'Contact us';
}

// Determine the price suffix based on pricing_model and billing_interval.
// per_seat → "/seat /mo"; flat → "/mo" (or "/yr"); free → no suffix.
function priceSuffix(plan: Plan): string {
  if (!plan.billing_interval || plan.billing_interval === 'free') return '';
  const interval = plan.billing_interval === 'monthly' ? 'mo' : plan.billing_interval === 'annual' ? 'yr' : plan.billing_interval;
  if (plan.pricing_model === 'per_seat') {
    return `/seat /${interval}`;
  }
  return `/${interval}`;
}

// Sub-label shown beneath the price for per-seat plans to clarify minimum cost.
// Returns null for flat plans (no sub-label needed).
// Uses per-plan min_seats column (m13_016) as the display SSOT — no heuristics.
function seatSubLabel(plan: Plan): string | null {
  if (!plan.pricing_model || plan.pricing_model !== 'per_seat') return null;
  if (plan.billing_interval === 'free' || !plan.billing_interval) return null;

  // Derive the seat price in cents for the minimum calculation
  let priceCents: number | null = null;
  if (plan.prices && typeof plan.prices === 'object' && plan.prices['USD'] !== undefined) {
    priceCents = Number(plan.prices['USD']);
  } else if (plan.price_cents !== null && plan.price_cents !== undefined) {
    priceCents = plan.price_cents;
  }

  // Per-plan min_seats (m13_016) is the display SSOT. No seat_limit heuristic.
  // min_seats > 1 → show minimum commitment sub-label.
  // min_seats === 1 or null → "billed per seat" (no enforced minimum).
  const minSeats = plan.min_seats;
  if (minSeats !== null && minSeats !== undefined && minSeats > 1 && priceCents !== null) {
    const fromUsd = (minSeats * priceCents) / 100;
    const fromFormatted = `$${fromUsd.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
    return `min. ${minSeats} seats — from ${fromFormatted}/mo`;
  }

  // per_seat plans with min_seats <= 1 or null: "billed per seat" (no seat minimum)
  return 'billed per seat';
}

// Build feature bullets from plan fields — readable summary
function planFeatures(plan: Plan): string[] {
  const features: string[] = [];
  if (plan.quota_calls_per_month === 0) {
    features.push('Unlimited MCP tool calls / month');
  } else {
    features.push(`${plan.quota_calls_per_month.toLocaleString()} tool calls / month`);
  }
  // Rate limit label: "calls / minute" (not "requests / minute") — terminology per ADR Phase 4 §2b
  features.push(`${plan.rate_limit_rpm} calls / minute`);
  if (plan.seat_limit && plan.seat_limit > 1) {
    features.push(`Up to ${plan.seat_limit} seats`);
  }
  // "All N MCP tools" rendered as link to /tools (not plain text)
  // Note: this is rendered as HTML in the template, not in this string array.
  // The tools bullet is handled separately in the template to support the link.
  return features;
}

// Per-plan description copy
const PLAN_DESCRIPTIONS: Record<string, string> = {
  free: 'Get started for free. Index your first Odoo repo and explore the full tool surface.',
  pro: 'For professional developers. Unlimited repos, full version range, email support.',
  team: 'For growing teams. High quota, multi-seat, priority support, dedicated instance.',
};

function planDescription(slug: string): string {
  return PLAN_DESCRIPTIONS[slug] ?? 'Odoo Semantic MCP plan';
}
---

<BaseLayout
  title="Pricing — Odoo Semantic MCP"
  description="Transparent pricing for Odoo Semantic MCP. Free, Pro, and Team plans."
  theme="dark"
  showFooter={false}
>
  <!-- Shared site header (replaces the old "Back to home" link) -->
  <SiteHeader currentPath="/pricing" />

  <!-- Spacer to clear the fixed header -->
  <div class="h-16"></div>

  <section class="bg-gray-950 min-h-screen py-20 px-4">
    <!-- Page heading -->
    <div class="max-w-4xl mx-auto text-center mb-14">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Pricing</h1>
      <p class="text-gray-400 text-lg max-w-xl mx-auto">
        Simple, transparent tiers for every team size.
      </p>
    </div>

    {plansError && (
      <div class="max-w-4xl mx-auto mb-8 bg-red-900/30 border border-red-700 text-red-300 px-4 py-3 rounded-xl text-sm text-center">
        {plansError} Showing default tier overview below.
      </div>
    )}

    <!-- Tier cards -->
    {plans.length > 0 ? (
      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        {plans.map((plan) => {
          const highlight = isHighlighted(plan, plans);
          const isFree = !plan.billing_interval || plan.billing_interval === 'free';
          const checkoutUrl = paidCheckoutEnabled ? (checkoutUrlMap[plan.slug] ?? null) : null;
          const ctaHref = checkoutUrl
            ? `${checkoutUrl}${currentEmail ? `?reference_id=${encodeURIComponent(currentEmail)}` : ''}`
            : '#waitlist';
          const ctaLabel = isFree
            ? 'Get started free'
            : (checkoutUrl ? `Subscribe to ${plan.display_name}` : 'Join Waitlist');
          const features = planFeatures(plan);
          const suffix = priceSuffix(plan);
          const subLabel = seatSubLabel(plan);
          return (
            <div
              class:list={[
                'relative flex flex-col rounded-2xl p-6 border',
                highlight
                  ? 'bg-viindoo-secondary/10 border-viindoo-secondary shadow-lg shadow-viindoo-secondary/20'
                  : 'bg-gray-900 border-gray-800',
              ]}
            >
              {highlight && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                  <span class="bg-viindoo-secondary text-white text-xs font-bold px-3 py-1 rounded-full">
                    Most Popular
                  </span>
                </div>
              )}

              <div class="mb-4">
                <h2 class:list={['text-xl font-bold mb-1', highlight ? 'text-viindoo-secondary-bright' : 'text-white']}>
                  {plan.display_name}
                </h2>
                <p class="text-gray-400 text-xs mb-3">{planDescription(plan.slug)}</p>

                <!-- Price display — USD only -->
                <div class="price-block">
                  <div class="flex items-baseline gap-1">
                    <span class="text-4xl font-bold text-white" data-plan={plan.slug}>
                      {formatPrice(plan)}
                    </span>
                    {suffix && (
                      <span class="text-gray-400 text-sm font-normal">
                        {suffix}
                      </span>
                    )}
                  </div>
                  {subLabel && (
                    <p class="text-xs text-gray-400 mt-1">{subLabel}</p>
                  )}
                </div>
              </div>

              <ul class="flex-1 space-y-2 mb-8">
                {features.map((f) => (
                  <li class="flex items-start gap-2 text-sm text-gray-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class:list={['w-4 h-4 mt-0.5 flex-shrink-0', highlight ? 'text-viindoo-secondary-bright' : 'text-gray-600']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {f}
                  </li>
                ))}
                {/* Metric tooltips — calls / minute */}
                <!-- All N MCP tools bullet rendered as a link -->
                <li class="flex items-start gap-2 text-sm text-gray-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class:list={['w-4 h-4 mt-0.5 flex-shrink-0', highlight ? 'text-viindoo-secondary-bright' : 'text-gray-600']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <a href="/tools" class="text-viindoo-primary hover:underline">
                    All {TOOL_COUNT} MCP tools &rarr;
                  </a>
                </li>
              </ul>

              {isFree ? (
                <a
                  href="/signup"
                  class:list={[
                    'w-full text-center py-3 rounded-xl font-semibold text-sm transition-colors',
                    'bg-gray-800 hover:bg-gray-700 text-gray-300 border border-gray-700',
                  ]}
                >
                  {ctaLabel}
                </a>
              ) : checkoutUrl ? (
                <!-- Live checkout CTA (only rendered when paid_checkout_enabled=true) -->
                <a
                  href={ctaHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class:list={[
                    'w-full text-center py-3 rounded-xl font-semibold text-sm transition-colors',
                    highlight
                      ? 'bg-viindoo-secondary hover:bg-viindoo-secondary-bright text-white'
                      : 'bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0',
                  ]}
                >
                  {ctaLabel}
                </a>
              ) : (
                <!-- Waitlist CTA (default when checkout not yet enabled) -->
                <a
                  href="#waitlist"
                  class:list={[
                    'w-full text-center py-3 rounded-xl font-semibold text-sm transition-colors',
                    highlight
                      ? 'bg-viindoo-secondary hover:bg-viindoo-secondary-bright text-white'
                      : 'bg-gray-800 hover:bg-gray-700 text-gray-300 border border-gray-700',
                  ]}
                >
                  Join Waitlist
                </a>
              )}
            </div>
          );
        })}
      </div>
    ) : (
      <!-- Fallback static tiers when API is unavailable -->
      <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        {[
          { name: 'Free', desc: 'For individuals exploring Odoo AI tooling.', price: 'Free', highlight: false },
          { name: 'Pro', desc: 'For professional Odoo developers.', price: 'Coming soon', highlight: true },
          { name: 'Team', desc: 'For growing development teams.', price: 'Coming soon', highlight: false },
        ].map((tier) => (
          <div
            class:list={[
              'relative flex flex-col rounded-2xl p-6 border',
              tier.highlight
                ? 'bg-viindoo-secondary/10 border-viindoo-secondary shadow-lg shadow-viindoo-secondary/20'
                : 'bg-gray-900 border-gray-800',
            ]}
          >
            {tier.highlight && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="bg-viindoo-secondary text-white text-xs font-bold px-3 py-1 rounded-full">Most Popular</span>
              </div>
            )}
            <h2 class:list={['text-xl font-bold mb-1', tier.highlight ? 'text-viindoo-secondary-bright' : 'text-white']}>
              {tier.name}
            </h2>
            <p class="text-gray-400 text-xs mb-3">{tier.desc}</p>
            <div class="text-4xl font-bold text-white mb-8">{tier.price}</div>
            <a
              href="#waitlist"
              class:list={[
                'w-full text-center py-3 rounded-xl font-semibold text-sm transition-colors mt-auto',
                tier.highlight
                  ? 'bg-viindoo-secondary hover:bg-viindoo-secondary-bright text-white'
                  : 'bg-gray-800 hover:bg-gray-700 text-gray-300 border border-gray-700',
              ]}
            >
              Join Waitlist
            </a>
          </div>
        ))}
      </div>
    )}

    <!-- Plan note -->
    <p class="text-center text-gray-400 text-sm max-w-2xl mx-auto mb-8">
      All accounts — including existing beta users — are on the unified <strong>Free plan</strong>.
      Your current plan and usage are visible at <a href="/account/usage" class="text-viindoo-primary hover:underline">/account/usage</a>.
    </p>

    <!-- Waitlist form (shown when checkout not enabled, or as a fallback) -->
    <div id="waitlist" class="max-w-lg mx-auto bg-gray-900 border border-gray-800 rounded-2xl p-8 text-center mb-12">
      <h2 class="text-2xl font-bold text-white mb-3">Join the Waitlist</h2>
      <p class="text-gray-400 text-sm mb-6">
        Be first to know when paid plans launch. We'll notify you by email — no spam.
      </p>
      <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          id="waitlist-email"
          name="email"
          placeholder="you@company.com"
          required
          class="flex-1 bg-gray-800 border border-gray-700 text-gray-200 placeholder-gray-500 text-sm px-4 py-2.5 rounded-xl focus:outline-none focus:border-viindoo-primary focus:ring-1 focus:ring-viindoo-primary"
        />
        <button
          type="submit"
          id="waitlist-submit"
          class="bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0 font-semibold text-sm px-6 py-2.5 rounded-xl transition-colors whitespace-nowrap"
        >
          Notify Me
        </button>
      </form>
      <p id="waitlist-msg" class="text-sm mt-3 hidden"></p>
    </div>

    <!-- FAQ -->
    <div class="max-w-2xl mx-auto space-y-4 mb-12">
      <h3 class="text-lg font-semibold text-white text-center mb-6">Frequently Asked Questions</h3>

      <details class="bg-gray-900 border border-gray-800 rounded-xl p-4 group">
        <summary class="text-gray-300 font-medium cursor-pointer list-none flex items-center justify-between">
          Can I cancel anytime?
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <p class="text-gray-400 text-sm mt-3">
          Yes. You can cancel at any time from your
          <a href="/account/billing" class="text-viindoo-primary hover:underline">billing page</a> or
          the Polar customer portal. Your subscription stays active until the end of the current billing period — there is no refund for the remaining days.
          See our <a href="/refund" class="text-viindoo-primary hover:underline">Refund &amp; Cancellation Policy</a>.
        </p>
      </details>

      <details class="bg-gray-900 border border-gray-800 rounded-xl p-4 group">
        <summary class="text-gray-300 font-medium cursor-pointer list-none flex items-center justify-between">
          What happens when I hit my monthly quota?
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <p class="text-gray-400 text-sm mt-3">
          MCP tool calls are rate-limited to your plan's monthly quota. When exhausted, calls return a quota error until the next billing cycle. Upgrade any time to get a higher limit immediately.
        </p>
      </details>

      <!-- NEW FAQ: seat-based pricing explanation (Phase 4 §1b) -->
      <details class="bg-gray-900 border border-gray-800 rounded-xl p-4 group">
        <summary class="text-gray-300 font-medium cursor-pointer list-none flex items-center justify-between">
          How does seat-based pricing work?
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <p class="text-gray-400 text-sm mt-3">
          Paid plans are priced per seat — one seat is one developer (one API key). The Pro plan is $19 per seat per month (up to 5 seats). The Team plan is $39 per seat per month with a 3-seat minimum, so a Team subscription starts at $117 per month. You only pay for the seats you assign; add or remove seats from your billing page at any time.
        </p>
      </details>

      <!-- NEW FAQ: tool calls / month vs calls / minute (Phase 4 §2b) -->
      <details class="bg-gray-900 border border-gray-800 rounded-xl p-4 group">
        <summary class="text-gray-300 font-medium cursor-pointer list-none flex items-center justify-between">
          What's the difference between "tool calls / month" and "calls / minute"?
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="text-gray-400 text-sm mt-3 space-y-2">
          <p>They are two separate limits, and you'll rarely hit them at the same time:</p>
          <ul class="list-disc list-inside space-y-1 pl-1">
            <li><strong class="text-gray-300">Tool calls / month</strong> is your total monthly allowance. Every time your AI tool runs an MCP tool (like <code class="font-mono text-xs bg-gray-800 px-1 rounded">model_inspect</code> or <code class="font-mono text-xs bg-gray-800 px-1 rounded">find_examples</code>), that's one call toward the monthly number. It resets at the start of each billing cycle.</li>
            <li><strong class="text-gray-300">Calls / minute</strong> is a speed limit (a rate limit). It caps how many calls you can make in any 60-second window so no single client can overwhelm the service. Hitting it just means "slow down for a moment" — it does not use up your monthly allowance.</li>
          </ul>
          <p>In everyday use, one tool call equals one request. Most users never notice the per-minute limit; it only matters for heavy automated workflows.</p>
        </div>
      </details>

      <details class="bg-gray-900 border border-gray-800 rounded-xl p-4 group">
        <summary class="text-gray-300 font-medium cursor-pointer list-none flex items-center justify-between">
          Monthly vs annual — any difference?
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <p class="text-gray-400 text-sm mt-3">
          Annual plans offer a discounted rate (equivalent to ~2 months free) billed upfront. Monthly plans let you pay as you go with the flexibility to cancel each month. Both plans include the same features.
        </p>
      </details>

      <details class="bg-gray-900 border border-gray-800 rounded-xl p-4 group">
        <summary class="text-gray-300 font-medium cursor-pointer list-none flex items-center justify-between">
          How do I upgrade or downgrade?
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <p class="text-gray-400 text-sm mt-3">
          Upgrade or switch plans from your <a href="/account/billing" class="text-viindoo-primary hover:underline">billing page</a> or the Polar customer portal. Downgrades take effect at the end of your current billing period.
        </p>
      </details>

      <details class="bg-gray-900 border border-gray-800 rounded-xl p-4 group">
        <summary class="text-gray-300 font-medium cursor-pointer list-none flex items-center justify-between">
          Where are my invoices?
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <p class="text-gray-400 text-sm mt-3">

---
// SPDX-License-Identifier: AGPL-3.0-or-later
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';

const tiers = [
  {
    name: 'Free',
    price: 'Coming Soon',
    color: 'gray',
    highlight: false,
    features: [
      '1 Odoo repo indexed',
      'Up to Odoo 17.0',
      '5 MCP tool calls / day',
      'resolve_model + resolve_field',
      'Community support',
    ],
    cta: 'Join Waitlist',
  },
  {
    name: 'Pro',
    price: 'Coming Soon',
    color: 'violet',
    highlight: true,
    features: [
      'Unlimited repos',
      'v8 → v19+ cross-version',
      'All 21 MCP tools',
      'Claude Code plugin included',
      'Email support (48h SLA)',
      'API key management',
    ],
    cta: 'Join Waitlist',
  },
  {
    name: 'Team',
    price: 'Coming Soon',
    color: 'blue',
    highlight: false,
    features: [
      'Everything in Pro',
      'Team API key management',
      'SSO / SAML (planned)',
      'Dedicated Neo4j instance',
      'Priority support (24h SLA)',
      'Custom deployment options',
    ],
    cta: 'Contact Us',
  },
] as const;
---

<BaseLayout
  title="Pricing — Odoo Semantic MCP"
  description="Pricing tiers for Odoo Semantic MCP. Free, Pro, and Team plans coming soon."
>
  <section class="bg-gray-950 min-h-screen py-20 px-4">
    <!-- Header -->
    <div class="max-w-4xl mx-auto text-center mb-14">
      <a href="/" class="inline-flex items-center gap-1 text-viindoo-primary text-sm hover:text-viindoo-primary-bright transition-colors mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to home
      </a>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Pricing</h1>
      <p class="text-gray-400 text-lg max-w-xl mx-auto">
        Simple, transparent tiers. Pricing is in development — join the waitlist to be notified when we launch.
      </p>
    </div>

    <!-- Tier cards -->
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      {tiers.map((tier) => (
        <div
          class={`
            relative flex flex-col rounded-2xl p-6 border
            ${tier.highlight
              ? 'bg-viindoo-secondary/10 border-viindoo-secondary shadow-lg shadow-viindoo-secondary/20'
              : 'bg-gray-900 border-gray-800'}
          `}
        >
          {tier.highlight && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="bg-viindoo-secondary text-white text-xs font-bold px-3 py-1 rounded-full">
                Most Popular
              </span>
            </div>
          )}

          <div class="mb-6">
            <h2 class={`text-xl font-bold mb-2 ${tier.highlight ? 'text-viindoo-secondary-bright' : 'text-white'}`}>
              {tier.name}
            </h2>
            <div class="text-2xl font-semibold text-gray-300">{tier.price}</div>
          </div>

          <ul class="flex-1 space-y-3 mb-8">
            {tier.features.map((f) => (
              <li class="flex items-start gap-2 text-sm text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class={`w-4 h-4 mt-0.5 flex-shrink-0 ${tier.highlight ? 'text-viindoo-secondary-bright' : 'text-gray-600'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {f}
              </li>
            ))}
          </ul>

          <a
            href="https://forms.gle/odoo-semantic-waitlist"
            target="_blank"
            rel="noopener noreferrer"
            class={`
              w-full text-center py-3 rounded-xl font-semibold text-sm transition-colors
              ${tier.highlight
                ? 'bg-viindoo-secondary hover:bg-viindoo-secondary-bright text-white'
                : 'bg-gray-800 hover:bg-gray-700 text-gray-300 border border-gray-700'}
            `}
          >
            {tier.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Waitlist form -->
    <div class="max-w-lg mx-auto bg-gray-900 border border-gray-800 rounded-2xl p-8 text-center mb-12">
      <h2 class="text-2xl font-bold text-white mb-3">Join the Waitlist</h2>
      <p class="text-gray-400 text-sm mb-6">
        Be first to know when pricing launches. We'll notify you by email — no spam.
      </p>
      <form
        action="https://formspree.io/f/placeholder-odoo-semantic"
        method="POST"
        class="flex flex-col sm:flex-row gap-3"
      >
        <input
          type="email"
          name="email"
          placeholder="you@company.com"
          required
          class="flex-1 bg-gray-800 border border-gray-700 text-gray-200 placeholder-gray-500 text-sm px-4 py-2.5 rounded-xl focus:outline-none focus:border-viindoo-primary focus:ring-1 focus:ring-viindoo-primary"
        />
        <button
          type="submit"
          class="bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0 font-semibold text-sm px-6 py-2.5 rounded-xl transition-colors whitespace-nowrap"
        >
          Notify Me
        </button>
      </form>
      <p class="text-xs text-gray-600 mt-3">
        Or use the <a href="https://forms.gle/odoo-semantic-waitlist" target="_blank" rel="noopener noreferrer" class="text-viindoo-primary hover:underline">Google Form</a> if you prefer.
      </p>
    </div>

    <!-- FAQ teaser -->
    <div class="max-w-2xl mx-auto space-y-4 mb-12">
      <h3 class="text-lg font-semibold text-white text-center mb-6">Common Questions</h3>

      <details class="bg-gray-900 border border-gray-800 rounded-xl p-4 group">
        <summary class="text-gray-300 font-medium cursor-pointer list-none flex items-center justify-between">
          Can I self-host?
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <p class="text-gray-500 text-sm mt-3">
          Yes. The full stack (Neo4j + PostgreSQL + MCP server) can be self-hosted via Docker Compose.
          See <a href="https://github.com/Viindoo/odoo-semantic-mcp" target="_blank" rel="noopener noreferrer" class="text-viindoo-primary hover:underline">GitHub</a> for deploy guide.
          Self-hosted is always free.
        </p>
      </details>

      <details class="bg-gray-900 border border-gray-800 rounded-xl p-4 group">
        <summary class="text-gray-300 font-medium cursor-pointer list-none flex items-center justify-between">
          Is my Odoo code sent to your servers?
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <p class="text-gray-500 text-sm mt-3">
          For the cloud-hosted plan: we index metadata only (model names, field names, method signatures).
          Source code lines are not stored. For sensitive EE code, use self-hosted.
        </p>
      </details>

      <details class="bg-gray-900 border border-gray-800 rounded-xl p-4 group">
        <summary class="text-gray-300 font-medium cursor-pointer list-none flex items-center justify-between">
          Which AI tools are supported?
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-500 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <p class="text-gray-500 text-sm mt-3">
          Claude Code (plugin + manual), Codex CLI, Gemini CLI, VS Code Copilot (v1.99+), Google Antigravity.
          Any MCP-compatible client works.
        </p>
      </details>
    </div>

    <!-- Footer note -->
    <p class="text-center text-gray-600 text-sm">
      Pricing in development — ETA Q3 2026.
      Questions? <a href="mailto:admin@viindoo.com" class="text-viindoo-primary hover:underline">admin@viindoo.com</a>
    </p>
  </section>
</BaseLayout>

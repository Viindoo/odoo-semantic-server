---
// SPDX-License-Identifier: AGPL-3.0-or-later
// /account/password — self-service change-password page (WS2c).
// Backend: POST /api/auth/change-password { current_password, new_password }
import AccountLayout from '../../layouts/AccountLayout.astro';
---

<AccountLayout title="Change Password">
  <!-- Flash banner (JS-driven, role-aware) -->
  <div
    data-testid="flash-banner"
    hidden
    role="alert"
    aria-live="assertive"
    class="fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border"
  ></div>

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Change Password</h1>
    <p class="text-sm text-gray-500 mt-1">Update your account password</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden max-w-lg">
    <div class="px-5 py-4 border-b border-gray-100">
      <h2 class="text-base font-semibold text-gray-800">New Password</h2>
      <p class="text-sm text-gray-500 mt-1">
        Enter your current password and choose a new one.
        Minimum 12 characters required.
      </p>
    </div>

    <div class="px-5 py-5">
      <!-- Success state (shown after 200) -->
      <div
        data-testid="change-password-success"
        hidden
        role="status"
        aria-live="polite"
        class="mb-4 bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg text-sm font-medium"
      >
        Password updated successfully.
      </div>

      <form data-testid="change-password-form" class="space-y-4" novalidate>
        <!-- Current password -->
        <div>
          <label for="current_password" class="block text-sm font-medium text-gray-700 mb-1">
            Current Password
          </label>
          <input
            id="current_password"
            name="current_password"
            type="password"
            required
            autocomplete="current-password"
            data-testid="current-password-input"
            placeholder="Your current password"
            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-viindoo-primary-deep focus:border-viindoo-primary-deep"
          />
        </div>

        <!-- New password -->
        <div>
          <label for="new_password" class="block text-sm font-medium text-gray-700 mb-1">
            New Password
          </label>
          <input
            id="new_password"
            name="new_password"
            type="password"
            required
            minlength="12"
            autocomplete="new-password"
            data-testid="new-password-input"
            placeholder="Min 12 characters"
            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-viindoo-primary-deep focus:border-viindoo-primary-deep"
          />
          <p class="mt-1 text-xs text-gray-500">At least 12 characters.</p>
        </div>

        <!-- Confirm new password -->
        <div>
          <label for="confirm_password" class="block text-sm font-medium text-gray-700 mb-1">
            Confirm New Password
          </label>
          <input
            id="confirm_password"
            name="confirm_password"
            type="password"
            required
            minlength="12"
            autocomplete="new-password"
            data-testid="confirm-password-input"
            placeholder="Repeat new password"
            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-viindoo-primary-deep focus:border-viindoo-primary-deep"
          />
        </div>

        <!-- Error region (role="alert" + aria-live for a11y) -->
        <div
          data-testid="change-password-error"
          hidden
          role="alert"
          aria-live="polite"
          class="text-sm text-red-600 bg-red-50 px-3 py-2 rounded-lg border border-red-200"
        ></div>

        <button
          type="submit"
          data-testid="change-password-submit"
          class="w-full bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0 text-sm font-medium py-2.5 rounded-lg transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
        >
          Update Password
        </button>
      </form>
    </div>
  </div>
</AccountLayout>

<script>
  function showFlash(msg: string, type: 'success' | 'error' = 'success') {
    const banner = document.querySelector('[data-testid="flash-banner"]') as HTMLElement | null;
    if (!banner) return;
    banner.textContent = msg;
    banner.className = `fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border ${
      type === 'error'
        ? 'bg-red-100 text-red-800 border-red-300'
        : 'bg-green-100 text-green-800 border-green-300'
    }`;
    banner.removeAttribute('hidden');
    setTimeout(() => banner.setAttribute('hidden', ''), 5000);
  }

  const form = document.querySelector('[data-testid="change-password-form"]') as HTMLFormElement | null;
  const errorEl = document.querySelector('[data-testid="change-password-error"]') as HTMLElement | null;
  const successEl = document.querySelector('[data-testid="change-password-success"]') as HTMLElement | null;
  const submitBtn = document.querySelector('[data-testid="change-password-submit"]') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const fd = new FormData(form!);
    const currentPassword = (fd.get('current_password') as string).trim();
    const newPassword = (fd.get('new_password') as string);
    const confirmPassword = (fd.get('confirm_password') as string);

    // Hide previous error/success
    if (errorEl) errorEl.setAttribute('hidden', '');
    if (successEl) successEl.setAttribute('hidden', '');

    // Client-side: confirm match
    if (newPassword !== confirmPassword) {
      if (errorEl) {
        errorEl.textContent = 'New passwords do not match.';
        errorEl.removeAttribute('hidden');
      }
      return;
    }

    // Client-side: minimum length (mirrors backend default of 12)
    if (newPassword.length < 12) {
      if (errorEl) {
        errorEl.textContent = 'New password must be at least 12 characters.';
        errorEl.removeAttribute('hidden');
      }
      return;
    }

    // Loading state
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Updating…';
    }

    try {
      const res = await fetch('/api/auth/change-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ current_password: currentPassword, new_password: newPassword }),
      });

      const data = await res.json().catch(() => ({}));

      if (res.ok) {
        if (successEl) successEl.removeAttribute('hidden');
        form!.reset();
        showFlash('Password updated successfully.', 'success');
      } else {
        const msg =
          data.error === 'invalid_credentials'
            ? 'Current password is incorrect.'
            : data.error === 'password_too_short'
            ? 'New password is too short. Minimum 12 characters required.'
            : data.error === 'password_too_common'
            ? 'That password is too common. Please choose a stronger one.'
            : data.error === 'same_password'
            ? 'New password must be different from the current one.'
            : data.error ?? data.detail ?? 'Failed to update password.';
        if (errorEl) {
          errorEl.textContent = msg;
          errorEl.removeAttribute('hidden');
        }
        showFlash(msg, 'error');
      }
    } catch {
      const msg = 'Could not connect to the server. Please try again.';
      if (errorEl) {
        errorEl.textContent = msg;
        errorEl.removeAttribute('hidden');
      }
      showFlash(msg, 'error');
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Update Password';
      }
    }
  });
</script>

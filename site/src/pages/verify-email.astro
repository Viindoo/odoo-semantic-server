---
// SPDX-License-Identifier: AGPL-3.0-or-later
// verify-email.astro — Email verification landing page (M9 W-SG)
// prerender=false: SSR required to read token from URL and call backend.
export const prerender = false;

import AuthLayout from '../layouts/AuthLayout.astro';
import { FASTAPI_BASE } from '../lib/fastapi';
import { resolveAuthLanding } from '../lib/auth-landing';

const token = Astro.url.searchParams.get('token') ?? '';

type VerifyStatus = 'success' | 'expired' | 'no_token';
let status: VerifyStatus = 'no_token';
let autoRedirect = false;
// Plaintext API key minted by the backend on first verify (auto-onboarding).
// Forwarded to the client so it can be stashed for a one-time copy on the
// landing page; null when the backend did not mint a key.
let newApiKey: string | null = null;
// SSR fallback landing shown before JS runs (pre-verify state) — conservative
// default to customer landing since we haven't verified yet.
// The client-side script will override this with the real is_admin from the
// API response after a successful verify.
let verifyLanding = resolveAuthLanding(false);

if (token) {
  try {
    const resp = await fetch(`${FASTAPI_BASE}/api/auth/verify-email`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token }),
    });

    if (resp.ok) {
      // Forward the Set-Cookie from FastAPI to the browser so the session is live
      const setCookie = resp.headers.get('set-cookie');
      if (setCookie) {
        Astro.response.headers.set('set-cookie', setCookie);
      }
      // Use real is_admin from the API response so an admin-invite-via-email
      // flow lands on /admin/ instead of /account/api-keys.
      // Guard against parse failure — default to non-admin (safest fallback).
      const respBody = await resp.json().catch(() => ({ is_admin: false })) as { is_admin?: boolean; new_api_key?: string | null };
      verifyLanding = resolveAuthLanding(respBody.is_admin === true);
      newApiKey = typeof respBody.new_api_key === 'string' && respBody.new_api_key ? respBody.new_api_key : null;
      status = 'success';
      autoRedirect = true;
    } else {
      status = 'expired';
    }
  } catch {
    status = 'expired';
  }
}

// Derive heading and subtitle based on verification status.
// The brand lockup always shows "Odoo Semantic MCP" + a contextual subtitle.
const subtitleMap: Record<VerifyStatus, string> = {
  success: 'Email verified!',
  expired: 'Verification link expired',
  no_token: 'Invalid link',
};
const subtitle = subtitleMap[status];
---

<!-- item #8: max-w-sm via AuthLayout (was max-w-md); items #1/#2: brand lockup present -->
<AuthLayout title="Email Verification — Odoo Semantic MCP" subtitle={subtitle}>
  {status === 'success' && (
    <div data-testid="verify-success" class="text-center" role="status" aria-live="polite">
      <p class="text-gray-600 mb-6">
        Your account is now active. Redirecting you to the dashboard…
      </p>
      <a
        href={verifyLanding}
        data-testid="verify-go-dashboard"
        class="inline-block bg-viindoo-primary hover:bg-viindoo-primary-bright
               text-viindoo-bg-0 font-medium py-2.5 px-6 rounded-lg transition-colors text-sm"
      >
        Go to Dashboard
      </a>
    </div>
  )}

  {status === 'expired' && (
    <div data-testid="verify-expired" class="text-center">
      <p class="text-gray-600 mb-6">
        This verification link has expired or was already used.
        Request a new one below.
      </p>

      <!-- Resend form -->
      <form data-testid="resend-form" class="space-y-3 text-left bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <label for="resend-email" class="block text-sm font-medium text-gray-700 mb-1">
          Your email address
        </label>
        <input
          id="resend-email"
          name="email"
          type="email"
          required
          autofocus
          data-testid="resend-email-input"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-white placeholder-gray-500
                 focus:outline-none focus:ring-2 focus:ring-viindoo-primary-deep focus:border-viindoo-primary-deep"
          placeholder="you@example.com"
        />

        <p
          data-testid="resend-error"
          hidden
          role="alert"
          aria-live="assertive"
          class="text-sm text-red-600 bg-red-50 px-3 py-2 rounded-lg border border-red-200"
        ></p>
        <p
          data-testid="resend-success"
          hidden
          role="status"
          aria-live="polite"
          class="text-sm text-viindoo-success bg-green-50 px-3 py-2 rounded-lg border border-green-200"
        >
          Verification email sent! Check your inbox.
        </p>

        <button
          type="submit"
          data-testid="resend-submit-button"
          class="w-full bg-viindoo-primary hover:bg-viindoo-primary-bright
                 text-viindoo-bg-0 font-medium py-2.5 rounded-lg transition-colors text-sm"
        >
          Resend Verification Email
        </button>
      </form>

      <!-- item #19: added /login link on expired state -->
      <p class="text-sm text-gray-500 mt-4">
        <a href="/signup" class="text-viindoo-primary-text hover:underline">Back to Sign Up</a>
        &nbsp;&middot;&nbsp;
        <a href="/login" class="text-viindoo-primary-text hover:underline">Sign in</a>
      </p>
    </div>
  )}

  {status === 'no_token' && (
    <div data-testid="verify-no-token" class="text-center">
      <p class="text-gray-600 mb-6">
        This URL does not contain a verification token.
        Check your email for the correct link.
      </p>
      <a href="/signup" class="text-viindoo-primary-text hover:underline text-sm">
        Back to Sign Up
      </a>
    </div>
  )}
</AuthLayout>

<script define:vars={{ autoRedirect, verifyLanding, newApiKey }}>
  if (autoRedirect) {
    // Stash the auto-minted plaintext key so the landing page can reveal it
    // once for copy. Only when landing on the customer API-keys page (the page
    // that knows how to reveal it) — admin landings never stash. The contract
    // key name is shared with admin/api-keys.astro and the OAuth cookie path.
    if (newApiKey && verifyLanding === '/account/api-keys') {
      try { sessionStorage.setItem('osm-new-api-key', newApiKey); } catch { /* private mode */ }
    }
    // Small delay so the user can read the success message before redirect
    setTimeout(() => {
      window.location.href = verifyLanding;
    }, 1500);
  }

  // Resend form handler
  const resendForm = document.querySelector('[data-testid="resend-form"]');
  resendForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget;
    const fd = new FormData(form);
    const errorEl = document.querySelector('[data-testid="resend-error"]');
    const successEl = document.querySelector('[data-testid="resend-success"]');
    const submitBtn = document.querySelector('[data-testid="resend-submit-button"]');

    if (errorEl) errorEl.setAttribute('hidden', '');
    if (successEl) successEl.setAttribute('hidden', '');
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending…'; }

    try {
      const res = await fetch('/api/auth/resend-verification', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: fd.get('email') }),
      });
      const data = await res.json().catch(() => ({}));

      if (res.status === 429) {
        if (errorEl) {
          errorEl.textContent = data.error ?? 'Too many attempts. Try again later.';
          errorEl.removeAttribute('hidden');
        }
      } else if (res.ok) {
        if (successEl) successEl.removeAttribute('hidden');
      } else {
        if (errorEl) {
          errorEl.textContent = data.error ?? 'Failed to resend email. Try again.';
          errorEl.removeAttribute('hidden');
        }
      }
    } catch {
      if (errorEl) {
        errorEl.textContent = 'Network error. Check your connection and try again.';
        errorEl.removeAttribute('hidden');
      }
    } finally {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Resend Verification Email'; }
    }
  });
</script>

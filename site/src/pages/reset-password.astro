---
// Reset Password page — M9 W-UM
// Prerendered: false (needs token from query string at request time).
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';

const token = Astro.url.searchParams.get('token') ?? '';
---

<BaseLayout title="Reset Password — Odoo Semantic MCP">
  <div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
    <!-- Flash banner -->
    <div data-testid="flash-banner" hidden class="fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border"></div>

    <div class="w-full max-w-sm">
      <!-- Logo / heading -->
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-900 mt-4">Reset Password</h1>
        <p class="text-sm text-gray-500 mt-1">Enter your new password below.</p>
      </div>

      {!token ? (
        <div data-testid="no-token-error" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm text-center">
          Invalid or missing reset token. Please request a new password reset link.
        </div>
      ) : (
        <form
          data-testid="reset-password-form"
          class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4"
        >
          <input type="hidden" name="token" value={token} />

          <div>
            <label for="new_password" class="block text-sm font-medium text-gray-700 mb-1">
              New Password
            </label>
            <input
              id="new_password"
              name="new_password"
              type="password"
              required
              minlength="8"
              data-testid="new-password-input"
              placeholder="At least 8 characters"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500"
            />
          </div>

          <div>
            <label for="confirm_password" class="block text-sm font-medium text-gray-700 mb-1">
              Confirm Password
            </label>
            <input
              id="confirm_password"
              name="confirm_password"
              type="password"
              required
              minlength="8"
              data-testid="confirm-password-input"
              placeholder="Repeat new password"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500"
            />
          </div>

          <button
            type="submit"
            data-testid="submit-reset-button"
            class="w-full bg-violet-600 hover:bg-violet-700 text-white text-sm font-medium py-2.5 rounded-lg transition-colors"
          >
            Set New Password
          </button>

          <div data-testid="reset-error" hidden class="text-red-600 text-sm text-center"></div>
          <div data-testid="reset-success" hidden class="text-green-700 text-sm text-center">
            Password updated. <a href="/admin/login" class="underline">Log in</a>
          </div>
        </form>
      )}
    </div>
  </div>
</BaseLayout>

<script>
  function showFlash(msg: string, type: 'success' | 'error' = 'success') {
    const banner = document.querySelector('[data-testid="flash-banner"]') as HTMLElement | null;
    if (!banner) return;
    banner.textContent = msg;
    banner.className = `fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border ${
      type === 'error'
        ? 'bg-red-100 text-red-800 border-red-300'
        : 'bg-green-100 text-green-800 border-green-300'
    }`;
    banner.removeAttribute('hidden');
    setTimeout(() => banner.setAttribute('hidden', ''), 5000);
  }

  const form = document.querySelector('[data-testid="reset-password-form"]') as HTMLFormElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form!);
    const token = fd.get('token') as string;
    const newPw = fd.get('new_password') as string;
    const confirmPw = fd.get('confirm_password') as string;

    const errEl = document.querySelector('[data-testid="reset-error"]') as HTMLElement | null;
    const okEl = document.querySelector('[data-testid="reset-success"]') as HTMLElement | null;

    if (newPw !== confirmPw) {
      if (errEl) {
        errEl.textContent = 'Passwords do not match.';
        errEl.removeAttribute('hidden');
      }
      return;
    }

    const res = await fetch('/api/auth/reset-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token, new_password: newPw }),
    });

    const data = await res.json().catch(() => ({}));

    if (res.ok) {
      if (okEl) okEl.removeAttribute('hidden');
      if (errEl) errEl.setAttribute('hidden', '');
      showFlash('Password updated successfully.');
      setTimeout(() => { location.href = '/admin/login'; }, 2000);
    } else {
      const msgMap: Record<string, string> = {
        expired: 'This reset link has expired. Please request a new one.',
        used: 'This reset link has already been used. Please request a new one.',
        not_found: 'Invalid reset token.',
      };
      const msg = msgMap[data.error] ?? data.detail ?? data.error ?? 'Reset failed.';
      if (errEl) {
        errEl.textContent = msg;
        errEl.removeAttribute('hidden');
      }
      showFlash(msg, 'error');
    }
  });
</script>

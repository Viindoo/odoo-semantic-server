---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Reset Password page — M9 W-UM
// Prerendered: false (needs token from query string at request time).
export const prerender = false;

import AuthLayout from '../layouts/AuthLayout.astro';

const token = Astro.url.searchParams.get('token') ?? '';
---

<AuthLayout title="Reset Password — Odoo Semantic MCP" subtitle="Set a new password">
  <!-- Flash banner — item #11: added role="alert" aria-live="assertive" -->
  <div
    data-testid="flash-banner"
    hidden
    role="alert"
    aria-live="assertive"
    class="fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border"
  ></div>

  {!token ? (
    <!-- No-token error state — item #18: added link to /forgot-password -->
    <div data-testid="no-token-error" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm text-center">
      Invalid or missing reset token. Please request a new password reset link.
    </div>
    <p class="text-center text-sm text-gray-500 mt-4">
      <a href="/forgot-password" class="text-viindoo-primary-text hover:underline font-medium">Request a new reset link</a>
    </p>
  ) : (
    <!-- item #5: rounded-2xl (was rounded-xl) -->
    <form
      data-testid="reset-password-form"
      class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 space-y-4"
    >
      <input type="hidden" name="token" value={token} />

      <div>
        <label for="new_password" class="block text-sm font-medium text-gray-700 mb-1">
          New Password
        </label>
        <!-- item #6: py-2.5 (was py-2) -->
        <input
          id="new_password"
          name="new_password"
          type="password"
          required
          minlength="12"
          autofocus
          autocomplete="new-password"
          data-testid="new-password-input"
          placeholder="Min 12 characters"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-viindoo-primary-deep focus:border-viindoo-primary-deep"
        />
      </div>

      <div>
        <label for="confirm_password" class="block text-sm font-medium text-gray-700 mb-1">
          Confirm Password
        </label>
        <!-- item #6: py-2.5 (was py-2) -->
        <input
          id="confirm_password"
          name="confirm_password"
          type="password"
          required
          minlength="12"
          autocomplete="new-password"
          data-testid="confirm-password-input"
          placeholder="Repeat new password"
          class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-viindoo-primary-deep focus:border-viindoo-primary-deep"
        />
      </div>

      <button
        type="submit"
        data-testid="submit-reset-button"
        class="w-full bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0 text-sm font-medium py-2.5 rounded-lg transition-colors"
      >
        Set New Password
      </button>

      <!-- item #9: error now has bg/border/padding pill style; item #13: role+aria-live -->
      <div
        data-testid="reset-error"
        hidden
        role="alert"
        aria-live="assertive"
        class="text-sm text-red-600 bg-red-50 px-3 py-2 rounded-lg border border-red-200"
      ></div>

      <!-- item #10: text-viindoo-success; item #14: link gets color + hover:underline; item #16: "Sign in" not "Log in" -->
      <div data-testid="reset-success" hidden role="status" aria-live="polite" class="text-sm text-viindoo-success text-center">
        Password updated.
        <a href="/login" class="text-viindoo-primary-text hover:underline font-medium">Sign in</a>
      </div>
    </form>
  )}
</AuthLayout>

<script>
  function showFlash(msg: string, type: 'success' | 'error' = 'success') {
    const banner = document.querySelector('[data-testid="flash-banner"]') as HTMLElement | null;
    if (!banner) return;
    banner.textContent = msg;
    banner.className = `fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium border ${
      type === 'error'
        ? 'bg-red-100 text-red-800 border-red-300'
        : 'bg-green-100 text-green-800 border-green-300'
    }`;
    banner.removeAttribute('hidden');
    setTimeout(() => banner.setAttribute('hidden', ''), 5000);
  }

  const form = document.querySelector('[data-testid="reset-password-form"]') as HTMLFormElement | null;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form!);
    const token = fd.get('token') as string;
    const newPw = fd.get('new_password') as string;
    const confirmPw = fd.get('confirm_password') as string;

    const errEl = document.querySelector('[data-testid="reset-error"]') as HTMLElement | null;
    const okEl = document.querySelector('[data-testid="reset-success"]') as HTMLElement | null;

    if (newPw !== confirmPw) {
      if (errEl) {
        errEl.textContent = 'Passwords do not match.';
        errEl.removeAttribute('hidden');
      }
      return;
    }

    const res = await fetch('/api/auth/reset-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token, new_password: newPw }),
    });

    const data = await res.json().catch(() => ({}));

    if (res.ok) {
      if (okEl) okEl.removeAttribute('hidden');
      if (errEl) errEl.setAttribute('hidden', '');
      showFlash('Password updated successfully.');
      setTimeout(() => { location.href = '/login'; }, 2000);
    } else {
      const msgMap: Record<string, string> = {
        expired: 'This reset link has expired. Please request a new one.',
        used: 'This reset link has already been used. Please request a new one.',
        not_found: 'Invalid reset token.',
      };
      const msg = msgMap[data.error] ?? data.detail ?? data.error ?? 'Reset failed.';
      if (errEl) {
        errEl.textContent = msg;
        errEl.removeAttribute('hidden');
      }
      showFlash(msg, 'error');
    }
  });
</script>

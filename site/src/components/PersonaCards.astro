---
// SPDX-License-Identifier: AGPL-3.0-or-later
// PersonaCards.astro — W4: 5-persona cards (3 large tier-1 + 2 compact tier-2)
---

<!-- Tier 1: 3 large cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">

  <!-- Developer -->
  <article
    class="persona-card group relative rounded-2xl border border-gray-200 bg-white p-8 transition hover:-translate-y-1 hover:shadow-xl hover:border-viindoo-primary"
    data-testid="persona-card-developer"
  >
    <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-viindoo-primary/10 text-viindoo-primary">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="16,18 22,12 16,6"/>
        <polyline points="8,6 2,12 8,18"/>
      </svg>
    </div>
    <p class="font-mono text-xs uppercase tracking-widest text-viindoo-primary-deep mb-3">For Developers</p>
    <h3 class="font-display text-xl font-bold text-viindoo-dark mb-2 leading-tight">Stop guessing field names. Trace overrides in 1 call.</h3>
    <p class="text-viindoo-body text-sm leading-relaxed mb-4">Resolve any model, field, or method across versions and modules. Find the right override point. Catch deprecations before upgrade.</p>
    <div class="font-mono text-xs text-viindoo-muted bg-gray-50 rounded p-3 border-l-2 border-viindoo-primary">
      <span class="text-viindoo-primary-deep font-semibold">&gt;_</span> find_override_point(sale.order, action_confirm) → 4 hooks · 312 tk
    </div>
    <a href="/install/" class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-viindoo-primary-deep group-hover:gap-2 transition">See examples →</a>
    <span class="absolute top-0 left-0 right-0 h-[3px] origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300 bg-viindoo-primary rounded-t-2xl"></span>
  </article>

  <!-- Consultant -->
  <article
    class="persona-card group relative rounded-2xl border border-gray-200 bg-white p-8 transition hover:-translate-y-1 hover:shadow-xl hover:border-viindoo-success"
    data-testid="persona-card-consultant"
  >
    <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-viindoo-success/10 text-viindoo-success">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <polygon points="16.24,7.76 14.12,14.12 7.76,16.24 9.88,9.88"/>
      </svg>
    </div>
    <p class="font-mono text-xs uppercase tracking-widest text-viindoo-success-deep mb-3">For Consultants</p>
    <h3 class="font-display text-xl font-bold text-viindoo-dark mb-2 leading-tight">Fit/gap in 30 minutes. Not 2 days.</h3>
    <p class="text-viindoo-body text-sm leading-relaxed mb-4">Map 50 requirements against standard Odoo coverage instantly. Know what's already built, what extends what, which version delivers what.</p>
    <div class="font-mono text-xs text-viindoo-muted bg-gray-50 rounded p-3 border-l-2 border-viindoo-success">
      <span class="text-viindoo-success-deep font-semibold">&gt;_</span> check_module_exists(loyalty, v=17.0) → ✓ sale_loyalty (CE) · 43 tk
    </div>
    <a href="/install/" class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-viindoo-success-deep group-hover:gap-2 transition">See examples →</a>
    <span class="absolute top-0 left-0 right-0 h-[3px] origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300 bg-viindoo-success rounded-t-2xl"></span>
  </article>

  <!-- CEO / PM -->
  <article
    class="persona-card group relative rounded-2xl border border-gray-200 bg-white p-8 transition hover:-translate-y-1 hover:shadow-xl hover:border-viindoo-secondary"
    data-testid="persona-card-pm"
  >
    <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-viindoo-secondary/10 text-viindoo-secondary">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 3v18h18M7 14l3-3 4 4 5-5"/>
      </svg>
    </div>
    <p class="font-mono text-xs uppercase tracking-widest text-viindoo-secondary mb-3">For CEOs &amp; PMs</p>
    <h3 class="font-display text-xl font-bold text-viindoo-dark mb-2 leading-tight">Measure blast radius before greenlight.</h3>
    <p class="text-viindoo-body text-sm leading-relaxed mb-4">Quantify upgrade risk. See how many modules depend on a field you want to change. Make data-driven decisions on what to refactor.</p>
    <div class="font-mono text-xs text-viindoo-muted bg-gray-50 rounded p-3 border-l-2 border-viindoo-secondary">
      <span class="text-viindoo-secondary font-semibold">&gt;_</span> impact_analysis(sale.order, amount_total) → 12 mods · 38 refs · 3,218 tk
    </div>
    <a href="/install/" class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-viindoo-secondary group-hover:gap-2 transition">See examples →</a>
    <span class="absolute top-0 left-0 right-0 h-[3px] origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300 bg-viindoo-secondary rounded-t-2xl"></span>
  </article>

</div>

<!-- Tier 2 divider -->
<div class="mt-12 mb-6 flex items-center gap-4 text-sm font-mono text-viindoo-muted uppercase tracking-widest">
  <span>And two more where MCP shines</span>
  <span class="h-px flex-1 bg-gray-200"></span>
</div>

<!-- Tier 2: 2 compact cards -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">

  <!-- BA / Sales -->
  <article
    class="rounded-2xl border border-gray-200 bg-white p-6 transition hover:border-viindoo-warning flex gap-5"
    data-testid="persona-card-sales"
  >
    <div class="flex-shrink-0 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-viindoo-warning/10 text-viindoo-warning">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
      </svg>
    </div>
    <div class="flex-1">
      <p class="font-mono text-xs uppercase tracking-widest text-viindoo-warning-deep mb-1">For BA / Sales</p>
      <h3 class="font-display text-lg font-bold text-viindoo-dark mb-1 leading-tight">Answer the prospect before they hang up.</h3>
      <p class="text-viindoo-body text-sm leading-snug">Confirm capability claims with evidence — real module names, real field paths.</p>
      <a href="/install/" class="mt-2 inline-block text-xs font-semibold text-viindoo-warning-deep">See examples →</a>
    </div>
  </article>

  <!-- Marketer -->
  <article
    class="rounded-2xl border border-gray-200 bg-white p-6 transition hover:border-viindoo-info flex gap-5"
    data-testid="persona-card-marketer"
  >
    <div class="flex-shrink-0 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-viindoo-info/10 text-viindoo-info">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 11l18-5v12L3 14M11.6 16.8a3 3 0 1 1-5.8-1.6"/>
      </svg>
    </div>
    <div class="flex-1">
      <p class="font-mono text-xs uppercase tracking-widest text-viindoo-info-deep mb-1">For Marketers</p>
      <h3 class="font-display text-lg font-bold text-viindoo-dark mb-1 leading-tight">Turn version diffs into marketing copy.</h3>
      <p class="text-viindoo-body text-sm leading-snug">Diff features across versions, generate marketing-friendly summaries anchored in truth.</p>
      <a href="/install/" class="mt-2 inline-block text-xs font-semibold text-viindoo-info-deep">See examples →</a>
    </div>
  </article>

</div>

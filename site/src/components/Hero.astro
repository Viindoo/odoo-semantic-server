---
// SPDX-License-Identifier: AGPL-3.0-or-later
// Hero.astro — "Living Cartography" aesthetic
// Aurora field + blueprint grid + grain, staggered load reveal, developer-first
// copy, a living inheritance graph (pulsing nodes + tracing edges), and a
// source-grounded proof quote. Motion degrades under prefers-reduced-motion.
import { TOOL_COUNT, RESOURCE_COUNT } from '../lib/constants';
---

<section
  class="cv-grain relative min-h-screen flex items-center bg-viindoo-bg-1 overflow-hidden pt-[140px] pb-20"
  aria-label="Hero"
>
  <!-- Living aurora field (drifts) + blueprint grid + ambient depth -->
  <div class="cv-aurora-field" aria-hidden="true"></div>
  <div class="cv-blueprint absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <!-- Main content grid -->
  <div class="relative z-10 mx-auto max-w-7xl w-full px-6">
    <div class="grid grid-cols-1 lg:grid-cols-[1.05fr_1fr] gap-14 lg:gap-20 items-center">

      <!-- Left: copy column -->
      <div class="flex flex-col">

        <!-- Tag pill -->
        <div
          class="animate-cv-rise inline-flex items-center gap-2.5 self-start bg-viindoo-primary/10 border border-viindoo-primary/30 rounded-full px-3.5 py-1.5 mb-7 font-mono text-xs text-viindoo-primary-bright tracking-wide"
          style="animation-delay: 0.05s;"
        >
          <span class="w-2 h-2 rounded-full bg-viindoo-success flex-shrink-0 animate-cv-pulse" style="box-shadow: 0 0 0 4px rgba(0,179,101,0.18);" aria-hidden="true"></span>
          {TOOL_COUNT} MCP tools + {RESOURCE_COUNT} Resources &middot; Odoo v8 &rarr; v19+ &middot; Cross-repo indexed
        </div>

        <!-- Headline -->
        <h1
          class="animate-cv-rise font-display font-extrabold text-viindoo-on-dark m-0 leading-[1.02] tracking-[-0.035em] text-[clamp(36px,5.2vw,68px)]"
          style="animation-delay: 0.12s;"
          data-testid="hero-heading"
        >
          Ship Odoo features with<br />
          <em class="cv-grad-text not-italic font-extrabold inline-block">verified knowledge</em><br />
          not hallucinations.
        </h1>

        <!-- Sub-copy (developer-first) -->
        <p
          class="animate-cv-rise mt-7 text-[19px] leading-[1.55] text-viindoo-on-dark-muted max-w-[54ch]"
          style="animation-delay: 0.18s;"
        >
          The semantic intelligence layer for Odoo. Resolve any model, field, or override
          across v8&ndash;v19+ &mdash; so <strong class="text-viindoo-on-dark font-medium">Cursor, Claude Code, and Gemini</strong>
          stop inventing names that don&apos;t exist.
        </p>

        <!-- Proof quote — grounds the pain in a real, citable developer voice -->
        <figure
          class="animate-cv-rise mt-7 max-w-[52ch] border-l-2 border-viindoo-primary/40 pl-4"
          style="animation-delay: 0.24s;"
        >
          <blockquote class="text-[15px] leading-relaxed text-viindoo-on-dark-muted italic">
            &ldquo;It invents method names that look right but don&apos;t exist &mdash;
            <code class="not-italic font-mono text-viindoo-danger/90 text-[13px]">account.invoice.search</code>
            instead of <code class="not-italic font-mono text-viindoo-primary-bright text-[13px]">account.move</code>,
            <code class="not-italic font-mono text-viindoo-danger/90 text-[13px]">customer_id</code>
            instead of <code class="not-italic font-mono text-viindoo-primary-bright text-[13px]">partner_id</code>.&rdquo;
          </blockquote>
          <figcaption class="mt-2 font-mono text-[11px] uppercase tracking-widest text-viindoo-on-dark-dim">
            &mdash; Marc Fargas, Odoo developer
          </figcaption>
        </figure>

        <!-- CTAs -->
        <div class="animate-cv-rise flex flex-wrap gap-3.5 mt-9" style="animation-delay: 0.3s;">
          <a
            href="/examples"
            data-testid="cta-try-demo"
            class="group inline-flex items-center gap-2.5 font-semibold text-[15px] px-[26px] py-[15px] rounded-lg transition-all duration-200 hover:-translate-y-0.5"
            style="background: #00BBCE; color: #07131A; box-shadow: 0 8px 24px -8px rgba(0,187,206,0.5), inset 0 1px 0 rgba(255,255,255,0.2);"
          >
            See it resolve, live
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </a>
          <a
            href="#install"
            data-testid="cta-connect-ai"
            class="inline-flex items-center gap-2.5 font-semibold text-[15px] px-[26px] py-[15px] rounded-lg transition-all duration-200 text-viindoo-on-dark hover:bg-viindoo-primary/8 hover:border-viindoo-primary"
            style="background: rgba(255,255,255,0.04); border: 1px solid rgba(0,187,206,0.16);"
          >
            Connect your AI
          </a>
        </div>

        <!-- Stats row -->
        <div
          class="animate-cv-rise grid grid-cols-2 sm:grid-cols-4 gap-7 mt-14 pt-7 border-t"
          style="animation-delay: 0.36s; border-top-color: rgba(230,242,244,0.08);"
        >
          <div class="flex flex-col gap-1">
            <span class="font-mono text-2xl font-semibold text-viindoo-primary-bright tracking-tight">12,400</span>
            <span class="font-mono text-[11px] text-viindoo-on-dark-dim uppercase tracking-widest">Models indexed</span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="font-mono text-2xl font-semibold text-viindoo-primary-bright tracking-tight">184,000</span>
            <span class="font-mono text-[11px] text-viindoo-on-dark-dim uppercase tracking-widest">Fields cross-linked</span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="font-mono text-2xl font-semibold text-viindoo-primary-bright tracking-tight">70+</span>
            <span class="font-mono text-[11px] text-viindoo-on-dark-dim uppercase tracking-widest">Repos &middot; v8&rarr;v19+</span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="font-mono text-2xl font-semibold text-viindoo-primary-bright tracking-tight">{TOOL_COUNT}</span>
            <span class="font-mono text-[11px] text-viindoo-on-dark-dim uppercase tracking-widest">MCP tools + {RESOURCE_COUNT} resources</span>
          </div>
        </div>
      </div>

      <!-- Right: living inheritance graph in a glass frame -->
      <div
        class="animate-cv-rise relative w-full max-w-[540px] mx-auto lg:ml-auto aspect-square"
        style="animation-delay: 0.42s;"
        data-testid="hero-graph-slot"
        aria-label="Live inheritance graph preview for sale.order"
      >
        <!-- Glass frame -->
        <div
          class="cv-glass absolute inset-0 rounded-2xl overflow-hidden shadow-lift"
          style="background-image: linear-gradient(rgba(0,187,206,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(0,187,206,0.04) 1px, transparent 1px); background-size: 32px 32px;"
          aria-hidden="true"
        ></div>

        <!-- Frame label chips -->
        <div class="absolute top-4 left-4 z-10 flex items-center gap-2 font-mono text-[11px]">
          <span class="bg-viindoo-primary/12 border border-viindoo-primary/40 px-2 py-0.5 rounded-full text-viindoo-primary-bright">sale.order</span>
          <span class="bg-viindoo-secondary/14 border border-viindoo-secondary/42 px-2 py-0.5 rounded-full text-viindoo-secondary-bright">Odoo 17.0</span>
        </div>

        <!-- Resolving status -->
        <div class="absolute bottom-4 right-4 z-10 inline-flex items-center gap-2 font-mono text-[11px] text-viindoo-on-dark-dim">
          <span class="w-1.5 h-1.5 rounded-full bg-viindoo-success animate-cv-pulse" aria-hidden="true"></span>
          resolved &middot; 148 fields &middot; 4 modules
        </div>

        <!-- Graph SVG: pulsing nodes + tracing edges -->
        <svg
          viewBox="0 0 540 540"
          preserveAspectRatio="xMidYMid meet"
          class="absolute inset-0 w-full h-full"
          role="img"
          aria-label="Graph preview of sale.order inheritance chain"
        >
          <defs>
            <radialGradient id="hero-node-glow" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#00BBCE" stop-opacity="0.4" />
              <stop offset="100%" stop-color="#00BBCE" stop-opacity="0" />
            </radialGradient>
          </defs>

          <!-- Glow behind primary node -->
          <ellipse cx="270" cy="270" rx="140" ry="80" fill="url(#hero-node-glow)" class="animate-cv-pulse" style="transform-origin: 270px 270px;" />

          <!-- Edges (dashes trace toward children) -->
          <path d="M 270,290 Q 170,360 105,415" fill="none" stroke="#00BBCE" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.5" class="animate-cv-dash" />
          <path d="M 270,290 Q 270,400 270,440" fill="none" stroke="#00BBCE" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.5" class="animate-cv-dash" />
          <path d="M 270,290 Q 370,360 435,415" fill="none" stroke="#7F4282" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.55" class="animate-cv-dash" />
          <path d="M 270,250 Q 270,160 270,115" fill="none" stroke="#00BBCE" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.5" class="animate-cv-dash" />

          <!-- Top node: parent -->
          <g transform="translate(190, 85)">
            <rect x="0" y="0" width="160" height="50" rx="8" fill="#112B36" stroke="#7F4282" stroke-width="1.5" />
            <text x="14" y="22" font-family="JetBrains Mono, monospace" font-size="11" font-weight="500" fill="#E6F2F4">_inherit base</text>
            <text x="14" y="38" font-family="JetBrains Mono, monospace" font-size="9" fill="#7E9BA6">root model</text>
          </g>

          <!-- Center node: definition (primary) -->
          <g transform="translate(170, 240)">
            <rect x="0" y="0" width="200" height="58" rx="8" fill="rgba(0,187,206,0.10)" stroke="#00BBCE" stroke-width="2" />
            <text x="14" y="24" font-family="JetBrains Mono, monospace" font-size="13" font-weight="600" fill="#E6F2F4">sale.order</text>
            <text x="14" y="42" font-family="JetBrains Mono, monospace" font-size="9" fill="#7E9BA6">DEFINITION · sale · 148 fields</text>
            <rect x="160" y="8" width="32" height="14" rx="3" fill="rgba(0,187,206,0.15)" stroke="#00BBCE" stroke-width="0.8" />
            <text x="166" y="18" font-family="JetBrains Mono, monospace" font-size="8" font-weight="600" fill="#2DD4E8">DEF</text>
          </g>

          <!-- Bottom-left: CE module -->
          <g transform="translate(25, 400)">
            <rect x="0" y="0" width="160" height="50" rx="8" fill="#173846" stroke="rgba(0,187,206,0.16)" stroke-width="1.5" />
            <text x="14" y="22" font-family="JetBrains Mono, monospace" font-size="11" font-weight="500" fill="#E6F2F4">sale_management</text>
            <text x="14" y="38" font-family="JetBrains Mono, monospace" font-size="9" fill="#7E9BA6">CE · +6 fields</text>
          </g>

          <!-- Bottom-center: CE module -->
          <g transform="translate(190, 425)">
            <rect x="0" y="0" width="160" height="50" rx="8" fill="#173846" stroke="rgba(0,187,206,0.16)" stroke-width="1.5" />
            <text x="14" y="22" font-family="JetBrains Mono, monospace" font-size="11" font-weight="500" fill="#E6F2F4">sale_stock</text>
            <text x="14" y="38" font-family="JetBrains Mono, monospace" font-size="9" fill="#7E9BA6">CE · +12 fields</text>
          </g>

          <!-- Bottom-right: EE module -->
          <g transform="translate(355, 400)">
            <rect x="0" y="0" width="160" height="50" rx="8" fill="rgba(127,66,130,0.10)" stroke="#7F4282" stroke-width="1.5" />
            <text x="14" y="22" font-family="JetBrains Mono, monospace" font-size="11" font-weight="500" fill="#E6F2F4">sale_subscription</text>
            <text x="14" y="38" font-family="JetBrains Mono, monospace" font-size="9" fill="#A263A5">EE only · +18 fields</text>
            <rect x="130" y="6" width="22" height="12" rx="2" fill="rgba(127,66,130,0.2)" stroke="#7F4282" stroke-width="0.8" />
            <text x="134" y="15" font-family="JetBrains Mono, monospace" font-size="7" font-weight="600" fill="#A263A5">EE</text>
          </g>

          <!-- Edge labels -->
          <text x="105" y="385" font-family="JetBrains Mono, monospace" font-size="9" fill="#2DD4E8">_inherit</text>
          <text x="278" y="405" font-family="JetBrains Mono, monospace" font-size="9" fill="#2DD4E8">_inherit</text>
          <text x="425" y="385" font-family="JetBrains Mono, monospace" font-size="9" fill="#A263A5">_inherit</text>
          <text x="278" y="180" font-family="JetBrains Mono, monospace" font-size="9" fill="#2DD4E8">extends</text>
        </svg>
      </div>

    </div>
  </div>
</section>

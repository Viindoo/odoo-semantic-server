---
// SPDX-License-Identifier: AGPL-3.0-or-later
// AgentPersonaCards.astro — the 9 personas the plugin serves, data-driven from
// odoo-ai-agents-data.ts (no hardcoded persona content). The primary (developer
// family) persona is rendered as a full-width spotlight; the other 8 fill a
// responsive grid. Each H3 is a persona name — part of the page H3 inventory.
//
// Skill chips per card are derived from the curated skill identifiers embedded
// in each persona's description in the data SSOT, so the chip set never drifts
// from the prose. Living Cartography aesthetic: glass cards, cyan/purple accent
// bar on hover, reduced-motion safe via global.css.
import { personas } from '../lib/odoo-ai-agents-data';

/** Pull the skill identifiers a persona's description references (the words that
 *  start with `odoo-`), trimmed of the `odoo-` prefix for compact chips. We cap
 *  the spotlight at 5 and the grid cards at 2 so the layout stays clean. */
function chipsFor(description: string, limit: number): string[] {
  const ids = description.match(/odoo-[a-z0-9-]+/g) ?? [];
  // dedupe while preserving order
  const seen = new Set<string>();
  const out: string[] = [];
  for (const id of ids) {
    const chip = id.replace(/^odoo-/, '');
    if (!seen.has(chip)) {
      seen.add(chip);
      out.push(chip);
    }
    if (out.length >= limit) break;
  }
  return out;
}

const primary = personas.find((p) => p.primary);
const rest = personas.filter((p) => !p.primary);
---

{primary && (
  <div
    class="cv-reveal group relative mt-12 rounded-2xl cv-glass p-8 overflow-hidden shadow-glass"
    style="transition-delay:.06s;"
    data-testid="persona-spotlight"
  >
    <span
      class="accent-bar absolute top-0 left-0 right-0 h-[3px]"
      style="background:linear-gradient(90deg,#00BBCE,#7F4282); transform:scaleX(0); transform-origin:left; transition:transform .5s cubic-bezier(.16,1,.3,1);"
    ></span>
    <span class="font-mono text-[11px] px-2 py-0.5 rounded-full bg-viindoo-primary/12 border border-viindoo-primary/40 text-viindoo-primary-bright">Primary persona</span>
    <h3 class="mt-3 font-display text-xl sm:text-2xl font-semibold text-viindoo-on-dark leading-tight">
      {primary.name} &amp; Tech Lead
    </h3>
    <p class="mt-2 text-viindoo-on-dark-muted leading-relaxed max-w-2xl">{primary.description}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {chipsFor(primary.description, 5).map((chip, i) => (
        <span class:list={['chip', i === 0 && 'chip-flag']}>{chip}</span>
      ))}
    </div>
  </div>
)}

<div class="mt-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
  {rest.map((persona, i) => (
    <article
      class="cv-reveal group relative rounded-2xl cv-glass p-6 overflow-hidden transition-transform duration-200 hover:-translate-y-0.5"
      style={`transition-delay:${0.08 + i * 0.02}s;`}
      data-testid="persona-card"
    >
      <span
        class="accent-bar absolute top-0 left-0 right-0 h-[3px]"
        style="background:linear-gradient(90deg,#00BBCE,#2DD4E8); transform:scaleX(0); transform-origin:left; transition:transform .4s cubic-bezier(.16,1,.3,1);"
      ></span>
      <h3 class="font-display font-semibold text-viindoo-on-dark">{persona.name}</h3>
      <p class="mt-2 text-sm text-viindoo-on-dark-muted leading-relaxed">{persona.description}</p>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {chipsFor(persona.description, 2).map((chip) => (
          <span class="chip">{chip}</span>
        ))}
      </div>
    </article>
  ))}
</div>

<style>
  /* Hover-driven accent bar reveal — scoped to this component's cards.
     Honours reduced-motion (global.css freezes ambient + reveal; this hover
     transition is harmless under reduced-motion but we still neutralise it). */
  .group:hover .accent-bar {
    transform: scaleX(1) !important;
  }
  @media (prefers-reduced-motion: reduce) {
    .accent-bar {
      transition: none !important;
    }
  }
</style>

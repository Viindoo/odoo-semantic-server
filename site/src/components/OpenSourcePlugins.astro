---
// SPDX-License-Identifier: AGPL-3.0-or-later
// OpenSourcePlugins.astro — homepage promo for the 2 free MIT Claude Code plugins.
// Sits right after section 06 "WIRE IT UP". Data from plugins-data.ts (SSOT).
import {
  MCP_PLUGIN,
  SKILLS_PLUGIN,
  PLUGIN_REPO_URL,
} from '../lib/plugins-data';
import { TOOL_COUNT, RESOURCE_COUNT } from '../lib/constants';

const cards = [
  {
    plugin: MCP_PLUGIN,
    accent: 'primary' as const,
    sub: `MCP server config · ${TOOL_COUNT} tools · ${RESOURCE_COUNT} resources`,
  },
  {
    plugin: SKILLS_PLUGIN,
    accent: 'secondary' as const,
    sub: SKILLS_PLUGIN.tagline,
  },
];
---

<section id="open-source-plugins" class="bg-viindoo-bg-0 pb-24">
  <div class="mx-auto max-w-7xl px-6" data-section="06b">
    <div class="text-sm font-mono text-viindoo-secondary uppercase tracking-widest mb-3 flex items-center gap-2">
      <span class="w-7 h-px bg-viindoo-secondary" aria-hidden="true" />
      06B &middot; FREE TOOLING LAYER
    </div>
    <div class="flex flex-wrap items-center gap-3">
      <h2 class="text-4xl font-display font-bold text-viindoo-on-dark tracking-tight leading-tight">
        Two free Claude Code plugins.
      </h2>
      <span class="inline-flex items-center rounded-full bg-viindoo-primary/10 px-3 py-1 text-xs font-semibold text-viindoo-primary-bright border border-viindoo-primary/30">
        MIT licensed · free forever
      </span>
    </div>
    <p class="text-viindoo-on-dark-muted mt-4 text-lg max-w-2xl leading-relaxed">
      Open-source plugins that sit on top of the MCP server &mdash; install in one command, read the
      code, contribute back. Lower the bar to try Odoo Semantic, and ship faster once you're in.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12">
      {cards.map(({ plugin, accent, sub }) => (
        <article
          class:list={[
            'group relative rounded-2xl border bg-viindoo-bg-1 p-8 transition hover:-translate-y-1 hover:bg-viindoo-bg-2',
            accent === 'primary' ? 'border-viindoo-primary/20 hover:border-viindoo-primary' : 'border-viindoo-secondary/20 hover:border-viindoo-secondary',
          ]}
        >
          <div class="flex items-center gap-3 mb-4">
            <code class="font-mono text-sm font-semibold text-viindoo-on-dark">{plugin.slug}</code>
            <span class="font-mono text-[10px] text-viindoo-on-dark-dim">v{plugin.version}</span>
            <span class="inline-flex items-center rounded-full border border-white/15 px-2 py-0.5 text-[10px] font-medium text-viindoo-on-dark-dim">MIT</span>
          </div>
          <p class="font-mono text-xs text-viindoo-on-dark-muted mb-4">{sub}</p>
          <ul class="space-y-2.5">
            {plugin.highlights.map((h) => (
              <li class="flex gap-2.5 text-sm text-viindoo-on-dark-muted leading-relaxed">
                <span class:list={[accent === 'primary' ? 'text-viindoo-primary-bright' : 'text-viindoo-secondary', 'mt-0.5 shrink-0']} aria-hidden="true">&#10003;</span>
                <span>{h}</span>
              </li>
            ))}
          </ul>
          <span class:list={['absolute top-0 left-0 right-0 h-[3px] origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-300 rounded-t-2xl', accent === 'primary' ? 'bg-viindoo-primary' : 'bg-viindoo-secondary']}></span>
        </article>
      ))}
    </div>

    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a
        href="/install/"
        class="inline-flex items-center gap-2 bg-viindoo-primary text-viindoo-bg-0 font-semibold text-sm px-5 py-2.5 rounded-lg hover:bg-viindoo-primary-bright hover:-translate-y-px transition-all duration-200"
      >
        Install the plugins
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <a
        href={PLUGIN_REPO_URL}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 border border-white/20 text-viindoo-on-dark font-semibold text-sm px-5 py-2.5 rounded-lg hover:bg-white/5 transition-all duration-200"
      >
        View on GitHub
      </a>
    </div>
  </div>
</section>

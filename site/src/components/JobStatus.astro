---
// SPDX-License-Identifier: AGPL-3.0-or-later
export interface Props {
  jobId?: number | null;
  status?: string | null;
  errorMsg?: string | null;
  /** If true, component auto-polls /api/jobs/{jobId}/status every 3 s */
  autoPoll?: boolean;
  testid?: string;
}

const {
  jobId = null,
  status = null,
  errorMsg = null,
  autoPoll = false,
  testid = 'job-status',
} = Astro.props;

const badgeColor: Record<string, string> = {
  running:   'bg-viindoo-info/10 text-viindoo-info border-viindoo-info/30',
  done:      'bg-green-100 text-green-700 border-green-300',
  error:     'bg-red-100 text-red-700 border-red-300',
  pending:   'bg-yellow-100 text-yellow-700 border-yellow-300',
  cancelled: 'bg-gray-100 text-gray-600 border-gray-300',
};

const safeStatus = status ?? 'unknown';
const badgeClass = badgeColor[safeStatus] ?? 'bg-gray-100 text-gray-600 border-gray-300';
---

{jobId !== null && (
  <div data-testid={testid} data-job-id={String(jobId)} class="inline-flex flex-col gap-1">
    <span
      data-testid={`${testid}-badge`}
      data-status={safeStatus}
      class:list={['inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium border', badgeClass]}
    >
      {safeStatus === 'running' && (
        <svg class="w-3 h-3 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
        </svg>
      )}
      Job #{jobId}: {safeStatus}
    </span>
    {errorMsg && (
      <p data-testid={`${testid}-error`} class="text-xs text-red-600 max-w-xs">{errorMsg}</p>
    )}
  </div>
)}

{autoPoll && jobId !== null && (
  <script define:vars={{ jobId, testid }}>
    (function () {
      const container = document.querySelector(`[data-testid="${testid}"]`);
      if (!container) return;

      function poll() {
        fetch(`/api/jobs/${jobId}/status`)
          .then((r) => r.json())
          .then((data) => {
            const badge = container.querySelector(`[data-testid="${testid}-badge"]`);
            if (badge) {
              badge.textContent = `Job #${jobId}: ${data.status}`;
              badge.setAttribute('data-status', data.status ?? 'unknown');
            }
            if (data.status === 'running' || data.status === 'pending') {
              setTimeout(poll, 3000);
            }
          })
          .catch(() => setTimeout(poll, 5000));
      }

      const initialStatus = container.querySelector(`[data-status]`)?.getAttribute('data-status');
      if (initialStatus === 'running' || initialStatus === 'pending') {
        setTimeout(poll, 3000);
      }
    })();
  </script>
)}

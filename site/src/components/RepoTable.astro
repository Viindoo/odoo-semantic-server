---
// SPDX-License-Identifier: AGPL-3.0-or-later
export interface Repo {
  id: number;
  url: string;
  branch: string;
  local_path: string;
  odoo_version?: string;
  clone_status?: string;
  clone_error_msg?: string | null;
  error_msg?: string | null;
  last_indexed_at?: string | null;
  head_sha?: string | null;
  last_job?: { id: number; status: string; error_msg?: string } | null;
}

export interface Profile {
  id: number;
  name: string;
  odoo_version?: string;
  description?: string;
  repos?: Repo[];
}

export interface SshKey {
  id: number;
  name: string;
}

export interface Props {
  repos: Repo[];
  profiles: Profile[];
  sshKeys: SshKey[];
}

const { repos = [], profiles = [], sshKeys = [] } = Astro.props;

const cloneStatusColor: Record<string, string> = {
  manual:  'bg-gray-100 text-gray-600',
  pending: 'bg-yellow-100 text-yellow-700',
  cloned:  'bg-green-100 text-green-700',
  error:   'bg-red-100 text-red-700',
};

// Helper to format ISO timestamp to "YYYY-MM-DD HH:mm"
function formatTimestamp(isoString: string | null | undefined): string {
  if (!isoString) return '—';
  try {
    const date = new Date(isoString);
    if (isNaN(date.getTime())) return '—';
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    const hours = String(date.getHours()).padStart(2, '0');
    const mins = String(date.getMinutes()).padStart(2, '0');
    return `${year}-${month}-${day} ${hours}:${mins}`;
  } catch {
    return '—';
  }
}

// Helper to truncate long error messages
function truncate(text: string | null | undefined, maxLen: number): string {
  if (!text) return '';
  return text.length > maxLen ? text.substring(0, maxLen) + '…' : text;
}
---

<!-- Add Repo Form -->
<div class="bg-white rounded-xl border border-gray-200 p-5 mb-6 shadow-sm">
  <h2 class="text-base font-semibold text-gray-800 mb-4">Add Repository</h2>
  <form data-testid="add-repo-form" data-repo-form class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    <div>
      <label class="block text-xs font-medium text-gray-600 mb-1">Profile</label>
      <select
        name="profile"
        data-testid="repos-profile-input"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
        required
      >
        <option value="">— select profile —</option>
        {profiles.map((p) => (
          <option value={p.name}>{p.name} ({p.odoo_version})</option>
        ))}
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-600 mb-1">URL</label>
      <input
        name="url"
        type="text"
        placeholder="https://... or git@..."
        data-testid="repos-url-input"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
        required
      />
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-600 mb-1">Branch</label>
      <input
        name="branch"
        type="text"
        placeholder="17.0"
        data-testid="repos-branch-input"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
        required
      />
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-600 mb-1">Local path (optional)</label>
      <input
        name="local_path"
        type="text"
        placeholder="/home/.../repo"
        data-testid="repos-local-path-input"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
      />
    </div>
    <div data-testid="ssh-key-select-wrapper" hidden>
      <label class="block text-xs font-medium text-gray-600 mb-1">SSH Key (for git@ URLs)</label>
      <select
        name="ssh_key_id"
        data-testid="repos-ssh-key-input"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
      >
        <option value="">— none —</option>
        {sshKeys.map((k) => (
          <option value={String(k.id)}>{k.name}</option>
        ))}
      </select>
    </div>
    <div class="flex items-end">
      <button
        type="submit"
        data-testid="add-repo-button"
        class="w-full bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0 text-sm font-medium px-4 py-2 rounded-lg transition-colors"
      >
        Add Repository
      </button>
    </div>
  </form>
</div>

<!-- Repos Table -->
<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between gap-3">
    <h2 class="text-base font-semibold text-gray-800">Repositories ({repos.length})</h2>
    {repos.length > 0 && (
      <div class="flex items-center gap-2">
        <label class="flex items-center gap-1.5 text-xs text-gray-600">
          <input
            type="checkbox"
            data-testid="index-all-full-checkbox"
            class="w-4 h-4 rounded border-gray-300 text-viindoo-info focus:ring-2 focus:ring-viindoo-info"
            title="Force full reindex — cleanup stale Module nodes after module rename/move (ADR-0007)"
          />
          <span>Full reindex</span>
        </label>
        <button
          data-testid="index-all-button"
          class="text-sm bg-viindoo-info hover:bg-viindoo-primary text-white px-4 py-1.5 rounded-lg transition-colors"
        >
          Index All
        </button>
      </div>
    )}
  </div>

  {repos.length === 0 ? (
    <div data-testid="repos-empty-state" class="py-16 text-center text-gray-500">
      <p class="text-4xl mb-3">📦</p>
      <p class="font-medium">No repositories added yet.</p>
      <p class="text-sm mt-1">Add one using the form above.</p>
    </div>
  ) : (
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
          <tr>
            <th class="px-4 py-3 text-left">Repo / Branch</th>
            <th class="px-4 py-3 text-left">Profile</th>
            <th class="px-4 py-3 text-left">Clone</th>
            <th class="px-4 py-3 text-left">Last Job</th>
            <th class="px-4 py-3 text-left">Last Indexed</th>
            <th class="px-4 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {repos.map((repo) => {
            const cloneClass = cloneStatusColor[repo.clone_status ?? 'manual'] ?? cloneStatusColor.manual;
            return (
              <tr data-testid="repo-row" data-testid-id={`repo-row-${repo.id}`} class="hover:bg-gray-50">
                <td class="px-4 py-3">
                  <p class="font-medium text-gray-800 truncate max-w-xs" title={repo.url}>{repo.url}</p>
                  <p class="text-gray-500 text-xs mt-0.5">{repo.branch}</p>
                </td>
                <td class="px-4 py-3 text-gray-600">
                  {profiles.find((p) => p.repos?.some((r) => r.id === repo.id))?.name ?? '—'}
                </td>
                <td class="px-4 py-3">
                  <div class="flex flex-col gap-1">
                    <span class:list={['px-2 py-0.5 rounded-full text-xs font-medium', cloneClass]}>
                      {repo.clone_status ?? 'manual'}
                    </span>
                    {repo.clone_status === 'error' && repo.clone_error_msg && (
                      <span class="text-red-700 text-xs" title={repo.clone_error_msg}>
                        {truncate(repo.clone_error_msg, 100)}
                      </span>
                    )}
                  </div>
                </td>
                <td class="px-4 py-3">
                  <div class="flex flex-col gap-1">
                    {repo.last_job ? (
                      <span class="text-xs text-gray-600">#{repo.last_job.id} {repo.last_job.status}</span>
                    ) : (
                      <span class="text-xs text-gray-400">—</span>
                    )}
                    {repo.error_msg && (
                      <span class="text-red-700 text-xs" title={repo.error_msg}>
                        {truncate(repo.error_msg, 100)}
                      </span>
                    )}
                  </div>
                </td>
                <td class="px-4 py-3">
                  <span class="text-xs text-gray-600">{formatTimestamp(repo.last_indexed_at)}</span>
                </td>
                <td class="px-4 py-3 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <label class="flex items-center gap-1.5 text-xs text-gray-600" title="Force full reindex — cleanup stale Module nodes after module rename/move (ADR-0007)">
                      <input
                        type="checkbox"
                        data-testid={`index-repo-full-checkbox-${repo.id}`}
                        data-repo-id={String(repo.id)}
                        class="w-3.5 h-3.5 rounded border-gray-300 text-viindoo-info focus:ring-2 focus:ring-viindoo-info"
                      />
                    </label>
                    <button
                      data-testid={`index-repo-button-${repo.id}`}
                      data-repo-id={String(repo.id)}
                      class="text-xs bg-viindoo-info/10 hover:bg-viindoo-info/20 text-viindoo-info px-3 py-1.5 rounded-lg transition-colors index-repo-btn"
                    >
                      Index
                    </button>
                    {repo.head_sha && (
                      <button
                        data-testid={`reset-embed-button-${repo.id}`}
                        data-repo-id={String(repo.id)}
                        class="text-xs bg-amber-50 hover:bg-amber-100 text-amber-700 px-3 py-1.5 rounded-lg transition-colors reset-embed-btn"
                      >
                        Reset
                      </button>
                    )}
                    <button
                      data-testid={`edit-repo-button-${repo.id}`}
                      data-repo-id={String(repo.id)}
                      class="text-xs bg-gray-50 hover:bg-gray-100 text-gray-700 px-3 py-1.5 rounded-lg transition-colors edit-repo-btn"
                    >
                      Edit
                    </button>
                    <button
                      data-testid={`delete-repo-button-${repo.id}`}
                      data-repo-id={String(repo.id)}
                      class="text-xs bg-red-50 hover:bg-red-100 text-red-700 px-3 py-1.5 rounded-lg transition-colors delete-repo-btn"
                    >
                      Delete
                    </button>
                  </div>
                </td>
              </tr>
              <!-- Inline edit form row (hidden by default) -->
              <tr
                data-testid={`edit-repo-form-row-${repo.id}`}
                data-repo-id={String(repo.id)}
                class="edit-repo-form-row bg-blue-50"
                hidden
              >
                <td colspan="5" class="px-4 py-4">
                  <form
                    data-testid={`edit-repo-form-${repo.id}`}
                    data-edit-repo-form
                    data-repo-id={String(repo.id)}
                    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3"
                  >
                    <div>
                      <label class="block text-xs font-medium text-gray-600 mb-1">URL</label>
                      <input
                        name="url"
                        type="text"
                        placeholder={repo.url}
                        data-testid={`edit-repo-url-${repo.id}`}
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
                      />
                    </div>
                    <div>
                      <label class="block text-xs font-medium text-gray-600 mb-1">Branch</label>
                      <input
                        name="branch"
                        type="text"
                        placeholder={repo.branch}
                        data-testid={`edit-repo-branch-${repo.id}`}
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
                      />
                    </div>
                    <div>
                      <label class="block text-xs font-medium text-gray-600 mb-1">SSH Key</label>
                      <select
                        name="ssh_key_id"
                        data-testid={`edit-repo-ssh-key-${repo.id}`}
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
                      >
                        <option value="">— unchanged —</option>
                        <option value="clear">— clear key —</option>
                        {sshKeys.map((k) => (
                          <option value={String(k.id)}>{k.name}</option>
                        ))}
                      </select>
                    </div>
                    <div>
                      <label class="block text-xs font-medium text-gray-600 mb-1">Local path</label>
                      <input
                        name="local_path"
                        type="text"
                        placeholder={repo.local_path}
                        data-testid={`edit-repo-local-path-${repo.id}`}
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-viindoo-primary"
                      />
                    </div>
                    <div class="sm:col-span-2 lg:col-span-4 flex gap-2 justify-end">
                      <button
                        type="button"
                        data-testid={`edit-repo-cancel-${repo.id}`}
                        data-repo-id={String(repo.id)}
                        class="text-xs px-4 py-2 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-100 transition-colors edit-repo-cancel-btn"
                      >
                        Cancel
                      </button>
                      <button
                        type="submit"
                        data-testid={`edit-repo-submit-${repo.id}`}
                        class="text-xs bg-viindoo-primary hover:bg-viindoo-primary-bright text-viindoo-bg-0 px-4 py-2 rounded-lg transition-colors"
                      >
                        Save changes
                      </button>
                    </div>
                  </form>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}
</div>

<script>
  function showFlash(msg: string, type: 'success' | 'error' = 'success') {
    const banner = document.querySelector('[data-testid="flash-banner"]') as HTMLElement | null;
    if (!banner) return;
    banner.textContent = msg;
    banner.className = `fixed top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg text-sm font-medium transition-opacity ${
      type === 'error' ? 'bg-red-100 text-red-800 border border-red-300' : 'bg-green-100 text-green-800 border border-green-300'
    }`;
    banner.removeAttribute('hidden');
    setTimeout(() => banner.setAttribute('hidden', ''), 4000);
  }

  // Add repo form
  document.querySelector('[data-testid="add-repo-form"]')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const fd = new FormData(form);
    const body: Record<string, string> = {};
    fd.forEach((v, k) => { body[k] = String(v); });
    const res = await fetch('/api/repos/repos', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    if (res.ok) {
      showFlash('Repository added.', 'success');
      setTimeout(() => location.reload(), 800);
    } else {
      const data = await res.json().catch(() => ({}));
      showFlash(data.error ?? 'Failed to add repository.', 'error');
    }
  });

  // Index repo buttons
  document.querySelectorAll('.index-repo-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const repoId = (btn as HTMLElement).dataset.repoId;
      const fullCheckbox = document.querySelector(`[data-testid="index-repo-full-checkbox-${repoId}"]`) as HTMLInputElement | null;
      const body: Record<string, string> = { max_workers: '1' };
      if (fullCheckbox?.checked) {
        body.full = '1';
      }
      const res = await fetch(`/api/repos/repos/${repoId}/index`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        showFlash(`Index job #${data.job_id} started.`, 'success');
      } else {
        showFlash(data.error ?? 'Failed to start index.', 'error');
      }
    });
  });

  // Reset embed buttons
  document.querySelectorAll('.reset-embed-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const repoId = (btn as HTMLElement).dataset.repoId;
      if (!confirm('Reset embeddings and re-index this repo?')) return;
      // Content-Type required to bypass Astro security.checkOrigin (see repos.astro).
      const res = await fetch(`/api/repos/repos/${repoId}/reset-embed`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        showFlash(`Reset started (job #${data.job_id}).`, 'success');
      } else {
        showFlash(data.error ?? 'Reset failed.', 'error');
      }
    });
  });

  // Delete repo buttons
  document.querySelectorAll('.delete-repo-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const repoId = (btn as HTMLElement).dataset.repoId;
      if (!confirm('Delete this repository? This cannot be undone.')) return;
      // Content-Type required to bypass Astro security.checkOrigin (see repos.astro).
      const res = await fetch(`/api/repos/repos/${repoId}`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        showFlash('Repository deleted.', 'success');
        setTimeout(() => location.reload(), 800);
      } else {
        showFlash(data.error ?? 'Delete failed.', 'error');
      }
    });
  });

  // Index all button
  document.querySelector('[data-testid="index-all-button"]')?.addEventListener('click', async () => {
    if (!confirm('Trigger index for ALL profiles?')) return;
    const fullCheckbox = document.querySelector('[data-testid="index-all-full-checkbox"]') as HTMLInputElement | null;
    const body: Record<string, string> = { max_workers: '1', profile_workers: '1' };
    if (fullCheckbox?.checked) {
      body.full = '1';
    }
    const res = await fetch('/api/repos/index-all', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json().catch(() => ({}));
    if (res.ok) {
      showFlash(`Index-all job #${data.job_id} started.`, 'success');
    } else {
      showFlash(data.error ?? 'Index-all failed.', 'error');
    }
  });

  // Edit repo buttons — toggle inline edit form row
  document.querySelectorAll('.edit-repo-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const repoId = (btn as HTMLElement).dataset.repoId;
      const formRow = document.querySelector(
        `[data-testid="edit-repo-form-row-${repoId}"]`
      ) as HTMLElement | null;
      if (formRow) {
        formRow.hidden = !formRow.hidden;
      }
    });
  });

  // Edit repo cancel buttons
  document.querySelectorAll('.edit-repo-cancel-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const repoId = (btn as HTMLElement).dataset.repoId;
      const formRow = document.querySelector(
        `[data-testid="edit-repo-form-row-${repoId}"]`
      ) as HTMLElement | null;
      if (formRow) formRow.hidden = true;
    });
  });

  // Edit repo form submit — PATCH /api/repos/repos/{id}
  document.querySelectorAll('[data-edit-repo-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = form as HTMLFormElement;
      const repoId = (form as HTMLElement).dataset.repoId;
      const fd = new FormData(f);

      const body: Record<string, unknown> = {};
      const urlVal = (fd.get('url') as string | null)?.trim();
      const branchVal = (fd.get('branch') as string | null)?.trim();
      const sshKeyVal = (fd.get('ssh_key_id') as string | null)?.trim();
      const localPathVal = (fd.get('local_path') as string | null)?.trim();

      if (urlVal) body['url'] = urlVal;
      if (branchVal) body['branch'] = branchVal;
      if (sshKeyVal === 'clear') {
        body['clear_ssh_key'] = true;
      } else if (sshKeyVal) {
        body['ssh_key_id'] = Number(sshKeyVal);
      }
      if (localPathVal) body['local_path'] = localPathVal;

      const res = await fetch(`/api/repos/repos/${repoId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json().catch(() => ({}));

      if (res.ok) {
        const fields: string[] = data.updated_fields ?? [];
        showFlash(
          fields.length ? `Repo updated: ${fields.join(', ')}.` : 'No fields changed.',
          'success'
        );
        setTimeout(() => location.reload(), 800);
      } else if (res.status === 404) {
        showFlash(data.error ?? 'Repo not found.', 'error');
      } else if (res.status === 409) {
        showFlash(data.error ?? 'URL+branch already taken by another repo.', 'error');
      } else if (res.status === 400) {
        showFlash(data.error ?? 'Invalid data.', 'error');
      } else {
        showFlash(data.error ?? 'Edit failed.', 'error');
      }
    });
  });

  // SSH key dropdown toggle — show when URL starts with git@, hide otherwise.
  // Works for all repo-form elements (currently one add-repo-form on the page).
  document.querySelectorAll('[data-repo-form]').forEach((form) => {
    const urlInput = form.querySelector('input[name="url"]') as HTMLInputElement | null;
    const sshDiv = form.querySelector('[data-testid="ssh-key-select-wrapper"]') as HTMLElement | null;
    if (!urlInput || !sshDiv) return;
    const update = () => {
      const isSsh = urlInput.value.startsWith('git@');
      sshDiv.hidden = !isSsh;
    };
    urlInput.addEventListener('input', update);
    update();  // initial state on page load
  });
</script>

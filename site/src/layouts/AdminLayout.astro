---
// SPDX-License-Identifier: AGPL-3.0-or-later
import BaseLayout from './BaseLayout.astro';
import StepUpMfaModal from '../components/StepUpMfaModal';
import MobileSidebar from '../components/MobileSidebar.astro';
import UserMenu from '../components/UserMenu';

export interface Props {
  title?: string;
}

const { title = 'Admin — Odoo Semantic MCP' } = Astro.props;

// `icon` is a key into the inline SVG map below (L12 — emoji replaced by
// consistent stroke-based line icons).
const navItems = [
  { id: 'dashboard', label: 'Dashboard', href: '/admin/', icon: 'dashboard' },
  { id: 'repos', label: 'Repositories', href: '/admin/repos', icon: 'box' },
  { id: 'api-keys', label: 'API Keys', href: '/admin/api-keys', icon: 'key' },
  { id: 'ssh-keys', label: 'SSH Keys', href: '/admin/ssh-keys', icon: 'lock' },
  { id: 'operations', label: 'Operations', href: '/admin/operations', icon: 'cog' },
  { id: 'security', label: 'Security', href: '/admin/security', icon: 'shield' },
  { id: 'users', label: 'Users', href: '/admin/users', icon: 'users' },
  { id: 'tenants', label: 'Tenants', href: '/admin/tenants', icon: 'building' },
  { id: 'audit-log', label: 'Audit Log', href: '/admin/audit-log', icon: 'list' },
  { id: 'settings', label: 'Settings', href: '/admin/settings', icon: 'sliders' },
];

const currentPath = Astro.url.pathname;
const currentUser = Astro.locals.user;
const displayName = currentUser?.username ?? 'Admin';
const displayBadge = currentUser?.is_admin === false ? 'USER' : 'ADMIN';

// L12 — inline SVG line-icon map (stroke="currentColor", 20px, aria-hidden via
// wrapping <span>). Keys match navItems[].icon.
const ICONS: Record<string, string> = {
  dashboard: '<rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect>',
  box: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line>',
  key: '<path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path>',
  lock: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path>',
  cog: '<circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>',
  users: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>',
  building: '<rect x="4" y="2" width="16" height="20" rx="1"></rect><line x1="9" y1="6" x2="9" y2="6.01"></line><line x1="15" y1="6" x2="15" y2="6.01"></line><line x1="9" y1="10" x2="9" y2="10.01"></line><line x1="15" y1="10" x2="15" y2="10.01"></line><line x1="9" y1="14" x2="9" y2="14.01"></line><line x1="15" y1="14" x2="15" y2="14.01"></line><path d="M9 22v-4h6v4"></path>',
  list: '<line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line>',
  sliders: '<line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line>',
};
---

<BaseLayout title={title}>
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[60] focus:px-4 focus:py-2 focus:rounded-lg focus:bg-viindoo-primary focus:text-viindoo-bg-0 focus:font-medium focus:shadow-lg"
  >
    Skip to main content
  </a>
  <div class="flex h-screen bg-gray-100">
    <!-- Sidebar (responsive off-canvas < md) -->
    <MobileSidebar>
      <aside class="w-64 h-full flex-shrink-0 bg-gray-900 text-white flex flex-col">
        <!-- Logo / Brand -->
        <div class="flex items-center gap-3 px-6 py-5 border-b border-gray-700">
          <img src="/logo-mark-ondark.svg" alt="Logo" class="w-8 h-8" />
          <span class="font-semibold text-sm leading-tight">
            Odoo Semantic<br />
            <span class="text-gray-400 font-normal">MCP Admin</span>
          </span>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 px-4 py-4 space-y-1 overflow-y-auto">
          {navItems.map((item) => {
            // Dashboard (`/admin/`) is active only on the exact admin root, otherwise
            // every /admin/* path would highlight Dashboard alongside the real section.
            const isActive =
              item.href === '/admin/'
                ? currentPath === '/admin' || currentPath === '/admin/'
                : currentPath.startsWith(item.href);
            return (
              <a
                href={item.href}
                data-testid={`nav-${item.id}`}
                class:list={[
                  'flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                  isActive
                    ? 'bg-viindoo-primary text-viindoo-bg-0'
                    : 'text-gray-300 hover:bg-gray-800 hover:text-white',
                ]}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="flex-shrink-0"
                  aria-hidden="true"
                  set:html={ICONS[item.icon]}
                />
                {item.label}
              </a>
            );
          })}
        </nav>
      </aside>
    </MobileSidebar>

    <!-- Main content area -->
    <div class="flex-1 flex flex-col overflow-hidden">
      <!-- Topbar -->
      <header class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between">
        <h1 class="text-lg font-semibold text-gray-800 pl-12 md:pl-0">{title}</h1>
        <div class="flex items-center gap-4">
          <span class="hidden sm:inline text-sm text-gray-500 font-medium">{displayName}</span>
          <span class="hidden sm:inline text-xs font-semibold px-2 py-0.5 rounded-full bg-viindoo-primary text-viindoo-bg-0 uppercase tracking-wide">
            {displayBadge}
          </span>
          <UserMenu
            client:idle
            username={displayName}
            email={currentUser?.email ?? ''}
            isAdmin={currentUser?.is_admin ?? false}
            isTenantAdmin={currentUser?.is_tenant_admin ?? false}
          />
        </div>
      </header>

      <!-- Page content -->
      <main id="main-content" class="flex-1 overflow-y-auto p-6">
        <slot />
      </main>
    </div>
  </div>
  <StepUpMfaModal client:load />
</BaseLayout>

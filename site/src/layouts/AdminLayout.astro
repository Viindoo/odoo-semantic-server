---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title?: string;
}

const { title = 'Admin — Odoo Semantic MCP' } = Astro.props;

const navItems = [
  { id: 'dashboard', label: 'Dashboard', href: '/admin/', icon: '⬛' },
  { id: 'repos', label: 'Repositories', href: '/admin/repos', icon: '📦' },
  { id: 'api-keys', label: 'API Keys', href: '/admin/api-keys', icon: '🔑' },
  { id: 'ssh-keys', label: 'SSH Keys', href: '/admin/ssh-keys', icon: '🔐' },
  { id: 'operations', label: 'Operations', href: '/admin/operations', icon: '⚙️' },
  { id: 'security', label: 'Security', href: '/admin/security', icon: '🛡️' },
];

const currentPath = Astro.url.pathname;
---

<BaseLayout title={title}>
  <div class="flex h-screen bg-gray-100">
    <!-- Sidebar -->
    <aside class="w-64 flex-shrink-0 bg-gray-900 text-white flex flex-col">
      <!-- Logo / Brand -->
      <div class="flex items-center gap-3 px-6 py-5 border-b border-gray-700">
        <img src="/favicon.svg" alt="Logo" class="w-8 h-8" />
        <span class="font-semibold text-sm leading-tight">
          Odoo Semantic<br />
          <span class="text-gray-400 font-normal">MCP Admin</span>
        </span>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 px-4 py-4 space-y-1 overflow-y-auto">
        {navItems.map((item) => {
          // Dashboard (`/admin/`) is active only on the exact admin root, otherwise
          // every /admin/* path would highlight Dashboard alongside the real section.
          const isActive =
            item.href === '/admin/'
              ? currentPath === '/admin' || currentPath === '/admin/'
              : currentPath.startsWith(item.href);
          return (
            <a
              href={item.href}
              data-testid={`nav-${item.id}`}
              class:list={[
                'flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                isActive
                  ? 'bg-viindoo-primary text-viindoo-bg-0'
                  : 'text-gray-300 hover:bg-gray-800 hover:text-white',
              ]}
            >
              <span class="text-base leading-none" aria-hidden="true">{item.icon}</span>
              {item.label}
            </a>
          );
        })}
      </nav>

      <!-- Logout -->
      <div class="px-4 py-4 border-t border-gray-700">
        <a
          href="/admin/logout"
          data-testid="nav-logout"
          class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-white transition-colors w-full"
        >
          <span class="text-base leading-none" aria-hidden="true">🚪</span>
          Logout
        </a>
      </div>
    </aside>

    <!-- Main content area -->
    <div class="flex-1 flex flex-col overflow-hidden">
      <!-- Topbar -->
      <header class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between">
        <h1 class="text-lg font-semibold text-gray-800">{title}</h1>
        <div class="flex items-center gap-4">
          <span class="text-sm text-gray-500">Admin</span>
          <div class="w-8 h-8 rounded-full bg-viindoo-primary flex items-center justify-center text-viindoo-bg-0 text-sm font-bold">
            A
          </div>
        </div>
      </header>

      <!-- Page content -->
      <main class="flex-1 overflow-y-auto p-6">
        <slot />
      </main>
    </div>
  </div>
</BaseLayout>

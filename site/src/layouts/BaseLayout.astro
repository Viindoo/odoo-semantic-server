---
// SPDX-License-Identifier: AGPL-3.0-or-later
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import CookieConsentBanner from '../components/CookieConsentBanner';
import { BRAND_FULL } from '../lib/constants';
import { FASTAPI_BASE } from '../lib/fastapi';

export interface Props {
  title?: string;
  description?: string;
  theme?: 'light' | 'dark';
  /** Render the shared site footer. Pages that ship their own footer
   *  (e.g. the landing page) set this false to avoid a duplicate footer. */
  showFooter?: boolean;
  /** Wrap the slot in a `<main id="main-content">` landmark + skip-link.
   *  App shells (AdminLayout/AccountLayout/TenantLayout) supply their own
   *  `<main>` + skip-link, so they set this false to avoid a nested `<main>`
   *  and a duplicate `id="main-content"` / skip-link. */
  provideMain?: boolean;
}

const {
  title = 'Odoo Semantic MCP',
  description = 'Knowledge engine for Odoo — inheritance chain, view structure, JS patch — exposed via MCP protocol.',
  theme = 'light',
  showFooter = true,
  provideMain = true,
} = Astro.props;
const isDark = theme === 'dark';
// Fetch GA measurement ID from site-config (SSR). Empty string = analytics off.
let gaId = '';
try {
  const r = await fetch(`${FASTAPI_BASE}/api/site-config`);
  if (r.ok) {
    const d = await r.json() as { ga_measurement_id?: unknown };
    gaId = typeof d.ga_measurement_id === 'string' ? d.ga_measurement_id : '';
  }
} catch { /* site-config unavailable — proceed without analytics */ }
// Absolute URL for social-card image (OG/Twitter need absolute). Prefer the
// configured Astro.site so self-hosted deploys emit their own origin.
const siteOrigin = Astro.site ?? new URL('https://odoo-semantic.viindoo.com');
const ogImage = new URL('/og-image.png', siteOrigin).href;
// Canonical URL — strip query string to avoid duplicate-content signals.
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).href;
// JSON-LD Organization structured data.
const orgJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: BRAND_FULL,
  url: siteOrigin.toString(),
  // Google logo rich-result requires ImageObject (raster PNG), not a plain SVG URL.
  // /og-image.png (1200x630 raster) satisfies the format requirement.
  logo: {
    '@type': 'ImageObject',
    url: new URL('/og-image.png', siteOrigin).href,
  },
  sameAs: [
    'https://github.com/Viindoo',
    'https://viindoo.com',
  ],
});
---

<!doctype html>
<html lang="en" class={isDark ? 'theme-dark' : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#00BBCE" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={orgJsonLd} />
    <GoogleAnalytics gaId={gaId} />
    <slot name="head" />
  </head>
  <body>
    {provideMain ? (
      <a
        href="#main-content"
        class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:rounded focus:bg-white focus:px-4 focus:py-2 focus:font-semibold focus:text-viindoo-primary-text focus:shadow-lg"
        >Skip to main content</a
      >
      <main id="main-content">
        <slot />
      </main>
    ) : (
      <slot />
    )}
    {showFooter && <SiteFooter />}
    {gaId && <CookieConsentBanner client:load />}
  </body>
</html>
